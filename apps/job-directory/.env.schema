# Job-directory app config. The API token resolves from Proton Pass via the
# proton-pass plugin (needs an authenticated pass-cli session).
# @defaultRequired=infer @defaultSensitive=false
# @plugin(@varlock/proton-pass-plugin)
# @initProtonPass()
# ----------

# Bearer token guarding the protected write/admin endpoints — resolved from Proton Pass
# @sensitive @required
JOB_DIRECTORY_API_TOKEN=protonPass(pass://sebastian-heitmann/job-directory/api-token)

# SQLite database path (relative to the app working directory)
# @required
JOB_DIRECTORY_DB=./data/jobs.db
