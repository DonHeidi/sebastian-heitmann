# Local mail-service runtime config. Production values are injected by Terraform.
# Sensitive values resolve from Proton Pass via the proton-pass plugin (needs an
# authenticated pass-cli session). Non-secret config is committed below.
# @defaultRequired=infer @defaultSensitive=false
# @plugin(@varlock/proton-pass-plugin)
# @initProtonPass()
# ----------

# Verified TEM sender address (within tem_domain)
# @type=email @required
MAIL_SENDER=contact@contact.sebastian-heitmann.dev

# CORS allowed origins (comma-separated)
# @required
ALLOWED_ORIGINS=https://www.sebastian-heitmann.dev,https://sebastian-heitmann.dev

# TEM API region (only available in fr-par)
# @required
TEM_REGION=fr-par

# Contact form recipient (PII) — resolved from Proton Pass
# @sensitive @type=email @required
MAIL_RECIPIENT=protonPass(pass://sebastian-heitmann/mail/recipient)
