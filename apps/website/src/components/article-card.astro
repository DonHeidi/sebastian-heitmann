---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type Props = {
  title: string;
  abstract: string;
  categoryLabel: string;
  tags: string[];
  publishedAt: Date;
  slug: string;
  headerImage?: ImageMetadata;
  locale: string;
};

const { title, abstract, categoryLabel, tags, publishedAt, slug, headerImage, locale } = Astro.props;

const href = `${locale === 'de-de' ? '/de-de' : ''}/articles/${slug}/`;

const dateLocale = locale === 'de-de' ? 'de-DE' : 'en-US';
const formattedDate = publishedAt.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={href} class="article-card">
  {headerImage && (
    <div class="article-card__image-wrap">
      <Image
        src={headerImage}
        alt={title}
        width={600}
        height={340}
        class="article-card__image"
      />
    </div>
  )}

  <div class="article-card__content">
    <div class="article-card__meta">
      <span class="article-card__category">
        {categoryLabel}
      </span>
      <span class="article-card__date">{formattedDate}</span>
    </div>

    <h2 class="article-card__title">{title}</h2>

    <p class="article-card__abstract">{abstract}</p>

    {tags.length > 0 && (
      <div class="article-card__tags">
        {tags.map((tag) => (
          <span class="article-card__tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style lang="scss">
  .article-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--v8-glass-border);
    background: var(--v8-glass-bg);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    box-shadow:
      0 1px 0 var(--v8-glass-highlight) inset,
      0 24px 60px -36px rgba(0, 0, 0, 0.25);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.3s ease;
    overflow: hidden;

    &::before,
    &::after {
      content: "";
      position: absolute;
      width: 14px;
      height: 14px;
      pointer-events: none;
      color: var(--v8-text-faint);
      z-index: 2;
    }

    &::before {
      top: 6px;
      left: 6px;
      border-top: 1px solid currentColor;
      border-left: 1px solid currentColor;
    }

    &::after {
      bottom: 6px;
      right: 6px;
      border-bottom: 1px solid currentColor;
      border-right: 1px solid currentColor;
    }

    &:hover {
      border-color: var(--v8-text-muted);
    }

    &:hover .article-card__image {
      transform: scale(1.03);
    }

    &__image-wrap {
      overflow: hidden;
      flex-shrink: 0;
    }

    &__image {
      width: 100%;
      height: 340px;
      object-fit: cover;
      transition: transform 0.4s ease;
      display: block;
    }

    &__content {
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      flex: 1;
    }

    &__meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }

    &__category {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--v8-accent);
    }

    &__date {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      color: var(--v8-text-muted);
      white-space: nowrap;
    }

    &__title {
      font-family: var(--v8-font-display);
      font-size: 24px;
      font-weight: 400;
      line-height: 1.1;
      color: var(--v8-text);
    }

    &__abstract {
      font-family: var(--v8-font-body);
      font-size: 14px;
      font-weight: 300;
      line-height: 1.6;
      color: var(--v8-text-muted);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 4px;
    }

    &__tag {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.05em;
      color: var(--v8-text-muted);
      border: 1px solid var(--v8-border);
      padding: 3px 8px;
    }
  }
</style>
