---
import { getEntry, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import AuthorCard from './author-card.astro';
import ArticleCta from './article-cta.astro';
import { getStrings } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  entry: CollectionEntry<'articles'>;
  seriesParts: Array<{ slug: string; title: string; part: number }>;
}

const { entry, seriesParts } = Astro.props;
const { Content } = await render(entry);

const locale = (Astro.currentLocale ?? 'en-us') as Locale;
const s = getStrings(locale);

const authorEntry = await getEntry('authors', entry.data.author);

const dateLocale = locale === 'de-de' ? 'de-DE' : 'en-US';
const publishedDate = entry.data.publishedAt.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const publishedISO = entry.data.publishedAt.toISOString();

const wordCount = entry.body
  ? entry.body.replace(/```[\s\S]*?```/g, ' ').split(/\s+/).filter(Boolean).length
  : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const currentSlug = entry.id.replace(/^de-de\//, '');
---

<main class="article-page">
  {entry.data.headerImage && (
    <div class="article-page__hero">
      <Image
        src={entry.data.headerImage}
        alt={entry.data.title}
        width={1200}
        height={480}
        class="article-page__hero-image"
      />
    </div>
  )}

  <div class="article-page__layout">
    <article
      class:list={[
        'article-page__main',
        { 'article-page__main--no-hero': !entry.data.headerImage },
      ]}
    >
      <header
        class:list={[
          'article-page__header',
          { 'article-page__header--no-hero': !entry.data.headerImage },
          { 'article-page__header--has-detail': !!entry.data.headerDetailImage },
        ]}
      >
        {entry.data.headerDetailImage && (
          <Image
            src={entry.data.headerDetailImage}
            alt={entry.data.title}
            width={200}
            height={200}
            class:list={[
              'article-page__detail-image',
              { 'article-page__detail-image--no-hero': !entry.data.headerImage },
            ]}
          />
        )}
        <div class="article-page__title-block">
          {entry.data.series && seriesParts.length > 0 && (
            <p class="article-page__series-label">
              {entry.data.series.name} &middot; {s.article.seriesPartPrefix} {entry.data.series.part} {s.article.seriesPartOf} {seriesParts.length}
            </p>
          )}
          <p class="article-page__category">{s.categories[entry.data.category]}</p>
          <h1 class="article-page__title">{entry.data.title}</h1>
          {entry.data.subline && (
            <p class="article-page__subline">{entry.data.subline}</p>
          )}
          <p class="article-page__meta-line">
            <time class="article-page__date" datetime={publishedISO}>{publishedDate}</time>
            <span class="article-page__meta-sep" aria-hidden="true">&middot;</span>
            <span class="article-page__reading-time">{readingMinutes} {s.article.readingTimeSuffix}</span>
          </p>
        </div>
      </header>

      <div class="article-page__author-block">
        {authorEntry && (
          <AuthorCard
            name={authorEntry.data.name}
            role={authorEntry.data.role}
            description={authorEntry.data.description}
            avatar={authorEntry.data.avatar}
            email={authorEntry.data.email}
            socials={authorEntry.data.socials}
          />
        )}
        <div class="article-page__authorship">
          {entry.data.authorship === 'human' && s.article.authorship.human}
          {entry.data.authorship === 'ai-assisted' && s.article.authorship.aiAssisted}
          {entry.data.authorship === 'agent-written' && s.article.authorship.agentWritten}
          {entry.data.aiTranslated && (
            <>
              <span class="article-page__authorship-sep" aria-hidden="true">&middot;</span>
              <span>{s.article.aiTranslated}</span>
            </>
          )}
        </div>
      </div>

      <div class="article-page__body">
        <Content />
      </div>

      {entry.data.tags && entry.data.tags.length > 0 && (
        <div class="article-page__tags">
          {entry.data.tags.map((tag) => (
            <span class="article-page__tag">{tag}</span>
          ))}
        </div>
      )}

      {entry.data.series && seriesParts.length > 0 && (
        <nav class="article-page__series" aria-label={s.article.seriesNavLabel}>
          <div class="article-page__series-header">
            <span class="article-page__series-overline">{s.article.seriesOverline}</span>
            <span class="article-page__series-name">{entry.data.series.name}</span>
          </div>
          <ol class="article-page__series-list">
            {seriesParts.map((part) => (
              <li class:list={['article-page__series-item', { 'article-page__series-item--current': part.slug === currentSlug }]}>
                <span class="article-page__series-part">{String(part.part).padStart(2, '0')}</span>
                {part.slug === currentSlug ? (
                  <span class="article-page__series-title">{part.title}</span>
                ) : (
                  <a class="article-page__series-title" href={getRelativeLocaleUrl(locale, `articles/${part.slug}`)}>{part.title}</a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )}

      {authorEntry && (
        <div class="article-page__author-footer" aria-label={s.article.aboutAuthorLabel} role="complementary">
          <AuthorCard
            name={authorEntry.data.name}
            role={authorEntry.data.role}
            description={authorEntry.data.description}
            avatar={authorEntry.data.avatar}
            email={authorEntry.data.email}
            socials={authorEntry.data.socials}
          />
        </div>
      )}

      <ArticleCta
        cta={s.article.cta}
        socials={authorEntry?.data.socials}
        email={authorEntry?.data.email}
      />

      <div class="article-page__footer-row">
        <a href={getRelativeLocaleUrl(locale, 'articles')} class="article-page__back">
          &larr; {s.article.backToAll}
        </a>
      </div>
    </article>

    <aside class="article-page__sidebar" aria-label={s.article.aboutAuthorLabel}>
      {authorEntry && (
        <AuthorCard
          name={authorEntry.data.name}
          role={authorEntry.data.role}
          description={authorEntry.data.description}
          avatar={authorEntry.data.avatar}
          email={authorEntry.data.email}
          socials={authorEntry.data.socials}
        />
      )}
      <div class="article-page__authorship">
        {entry.data.authorship === 'human' && s.article.authorship.human}
        {entry.data.authorship === 'ai-assisted' && s.article.authorship.aiAssisted}
        {entry.data.authorship === 'agent-written' && s.article.authorship.agentWritten}
        {entry.data.aiTranslated && (
          <>
            <span class="article-page__authorship-sep" aria-hidden="true">&middot;</span>
            <span>{s.article.aiTranslated}</span>
          </>
        )}
      </div>
    </aside>
  </div>
</main>

<style lang="scss">
  .article-page {
    max-width: 1440px;
    margin: 0 auto;
    position: relative;

    &__hero {
      position: relative;
      margin-top: 40px;
      margin-inline: calc(50% - 50vw);
      width: 100vw;
      overflow: hidden;
      max-height: clamp(240px, 28vw, 440px);
      z-index: 1;
    }

    &__hero-image {
      width: 100%;
      height: clamp(240px, 28vw, 440px);
      max-height: clamp(240px, 28vw, 440px);
      object-fit: cover;
    }

    &__layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 64px;
      padding: 0 80px 120px;
      position: relative;
      z-index: 2;
      isolation: isolate;

      & > .article-page__main {
        grid-column: 1;
      }

      &::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: calc(50% - 50vw);
        right: calc(50% - 50vw);
        z-index: -1;
        pointer-events: none;
        background-image: radial-gradient(
          circle at center,
          var(--v8-dot-color) 1px,
          transparent 1.5px
        );
        background-size: 24px 24px;
        background-position: 0 0;
        opacity: 0.55;
      }
    }

    &__main {
      min-width: 0;
      margin-top: -220px;
      padding: 48px 56px 56px;
      background: var(--v8-glass-bg);
      backdrop-filter: blur(24px) saturate(1.35);
      -webkit-backdrop-filter: blur(24px) saturate(1.35);
      border: 1px solid var(--v8-glass-border);
      box-shadow:
        0 1px 0 var(--v8-glass-highlight) inset,
        0 30px 80px -40px rgba(0, 0, 0, 0.35);

      &--no-hero {
        margin-top: 60px;
      }
    }

    &__header {
      position: relative;
      margin-bottom: 56px;
      padding-bottom: 32px;
      border-bottom: 1px solid var(--v8-glass-border);
      text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.9);

      :global(html.light) & {
        text-shadow: 1px 1px 0 rgba(255, 255, 255, 0.7);
      }

      &--has-detail {
        min-height: 272px;
      }

      &--no-hero {
        padding-top: 16px;
      }
    }

    &__detail-image {
      position: absolute;
      top: 0;
      right: -180px;
      width: 240px;
      height: 240px;
      object-fit: cover;
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.35) inset,
        0 10px 30px -10px rgba(0, 0, 0, 0.25);
      z-index: 3;

      &--no-hero {
        position: static;
        float: inline-end;
        width: 200px;
        height: 200px;
        margin: 0 0 16px 24px;
        border: 1px solid var(--v8-border);
        box-shadow: 0 6px 20px -8px rgba(0, 0, 0, 0.15);
      }
    }

    &__title-block {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 0 80px 0 0;
    }

    &__category {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--v8-accent);
      display: inline-flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 4px;

      &::before {
        content: '';
        width: 56px;
        height: 2px;
        background: var(--v8-accent);
      }
    }

    &__title {
      font-family: var(--v8-font-display);
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 400;
      line-height: 1.05;
      color: var(--v8-text);
    }

    &__subline {
      font-family: var(--v8-font-body);
      font-size: 18px;
      font-weight: 300;
      line-height: 1.5;
      color: var(--v8-text-secondary);
    }

    &__meta-line {
      display: flex;
      align-items: center;
      gap: 10px;
      padding-top: 20px;
      margin-top: 24px;
      border-top: 1px solid var(--v8-border);
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.04em;
      color: var(--v8-text-muted);
    }

    &__date,
    &__reading-time {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      color: var(--v8-text-muted);
    }

    &__meta-sep {
      color: var(--v8-text-faint);
    }

    &__body {
      font-family: var(--v8-font-body);
      font-size: 24px;
      font-weight: 300;
      line-height: 1.7;
      color: var(--v8-text-secondary);
      max-width: 53ch;

      :global(h2) {
        font-family: var(--v8-font-display);
        font-size: 36px;
        font-weight: 400;
        line-height: 1.15;
        color: var(--v8-text);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
      }

      :global(h3) {
        font-family: var(--v8-font-display);
        font-size: 28px;
        font-weight: 400;
        line-height: 1.2;
        color: var(--v8-text);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      :global(p) {
        margin-bottom: 1.25rem;
      }

      :global(blockquote) {
        font-style: italic;
        border-left: 3px solid var(--v8-accent);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--v8-text-muted);
      }

      :global(code) {
        font-family: var(--v8-font-mono);
        font-size: 0.9em;
        background-color: var(--v8-bg-surface);
        padding: 0.1em 0.35em;
        border-radius: 2px;
      }

      :global(pre) {
        background-color: var(--v8-bg-surface);
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1.5rem 0;
        border-radius: 2px;

        :global(code) {
          background: none;
          padding: 0;
          font-size: 14px;
        }
      }

      :global(img) {
        max-width: 100%;
        height: auto;
      }

      :global(ul),
      :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }

      :global(li) {
        margin-bottom: 0.5rem;
      }

      :global(a) {
        color: var(--v8-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    }

    &__series-label {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
      margin-bottom: 4px;
    }

    &__series {
      margin-top: 56px;
      padding: 28px 0 0;
      border-top: 1px solid var(--v8-text);
    }

    &__series-header {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 20px;
      padding-bottom: 0;
      border-bottom: none;
    }

    &__series-overline {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
    }

    &__series-name {
      font-family: var(--v8-font-display);
      font-size: 20px;
      line-height: 1.2;
      color: var(--v8-text);
    }

    &__series-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    &__series-item {
      display: flex;
      gap: 16px;
      align-items: baseline;
      padding: 10px 0;
      border-bottom: 1px solid var(--v8-border);

      &:last-child {
        border-bottom: none;
      }

      &--current .article-page__series-part {
        color: var(--v8-accent);
      }

      &--current .article-page__series-title {
        color: var(--v8-text);
      }
    }

    &__series-part {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      color: var(--v8-text-muted);
      flex-shrink: 0;
      letter-spacing: 0.04em;
    }

    &__series-title {
      font-family: var(--v8-font-body);
      font-size: 15px;
      color: var(--v8-text-tertiary);
      text-decoration: none;
      transition: color 0.2s ease;

      &:is(a):hover {
        color: var(--v8-text);
      }
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 20px;
      padding-top: 20px;
      padding-bottom: 24px;
      border-top: 1px solid var(--v8-border);
      margin-top: 56px;
    }

    &__tag {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
      padding: 0;

      &::before {
        content: '+ ';
        color: var(--v8-accent);
      }
    }

    &__author-footer {
      display: none;
      margin-top: 56px;
      padding-top: 32px;
      border-top: 1px solid var(--v8-border);
    }

    &__footer-row {
      margin-top: 32px;
    }

    &__back {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.05em;
      color: var(--v8-accent);
      text-decoration: none;
      transition: opacity 0.2s ease;

      &:hover {
        opacity: 0.7;
      }
    }

    &__author-block {
      display: none;
    }

    &__sidebar {
      position: sticky;
      top: 100px;
      align-self: start;
      padding-top: 80px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-right: -20px;

      :global(.author-card) {
        background: var(--v8-glass-bg);
        backdrop-filter: blur(24px) saturate(1.35);
        -webkit-backdrop-filter: blur(24px) saturate(1.35);
        box-shadow:
          0 1px 0 var(--v8-glass-highlight) inset,
          0 30px 80px -40px rgba(0, 0, 0, 0.35);
      }
    }

    &__authorship {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-faint);
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    &__authorship-sep {
      color: var(--v8-text-faint);
      opacity: 0.6;
    }
  }

  @media (max-width: 1024px) {
    .article-page {
      &__layout {
        grid-template-columns: 1fr;
        gap: 0;
      }

      &__sidebar {
        display: none;
      }

      &__author-block {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 48px;
      }

      &__title-block {
        margin-top: 0;
        padding: 0;
      }

      &__body {
        font-size: 17px;
        max-width: none;
      }

      &__main {
        margin-top: -120px;
        padding: 40px 40px 48px;

        &--no-hero {
          margin-top: 40px;
        }
      }

      &__header {
        padding-top: 8px;

        &--no-hero {
          padding-top: 16px;
        }
      }

      &__detail-image {
        display: none;
      }
    }
  }

  @media (max-width: 768px) {
    .article-page {
      &__hero {
        margin-top: 40px;
      }

      &__layout {
        padding: 0 0 60px;
      }

      &__main {
        margin-top: -64px;
        padding: 32px 24px 36px;
        border-left: none;
        border-right: none;

        &--no-hero {
          margin-top: 24px;
        }
      }

      &__author-block {
        margin-bottom: 32px;

        :global(.author-card) {
          border: none;
          padding: 0;
          display: grid;
          grid-template-columns: 40px 1fr;
          align-items: center;
          column-gap: 12px;
          row-gap: 2px;
        }

        :global(.author-card__avatar-wrap) {
          grid-row: span 2;
          width: 40px;
          height: 40px;
        }

        :global(.author-card__avatar) {
          width: 40px;
          height: 40px;
        }

        :global(.author-card__name) {
          font-size: 15px;
          margin-top: 0;
          line-height: 1.2;
          align-self: end;
        }

        :global(.author-card__role) {
          font-size: 10px;
          align-self: start;
        }

        :global(.author-card__description),
        :global(.author-card__socials) {
          display: none;
        }
      }

      &__authorship {
        font-size: 9px;
      }

      &__author-footer {
        display: block;
      }
    }
  }
</style>
