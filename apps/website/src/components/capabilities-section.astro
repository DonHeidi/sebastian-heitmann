---
import type { Strings } from '../i18n/types';

type Props = {
    capabilities: Strings['capabilities'];
};

const { capabilities } = Astro.props;
---

<section class="cap reveal">
    <div class="cap-header">
        <span class="cap-eyebrow">{capabilities.eyebrow}</span>
        <div class="cap-rule"></div>
    </div>

    <div class="cap-grid">
        {capabilities.categories.map((cat, i) => (
            <div class="cap-category">
                <div class="cap-category-head">
                    <span class="cap-num">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="cap-title">{cat.title}</h3>
                </div>
                <ul class="cap-items">
                    {cat.items.map(item => (
                        <li class="cap-item">{item}</li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</section>

<style lang="scss">
    .cap {
        max-width: 1440px;
        margin: 0 auto;
        padding: 80px 80px;
    }

    .cap-header {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 0;
        padding-bottom: 32px;
    }

    .cap-eyebrow {
        font-family: var(--v8-font-mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--v8-text-muted);
        flex-shrink: 0;
    }

    .cap-rule {
        flex: 1;
        height: 8px;
        background-image: radial-gradient(circle, var(--v8-text-muted) 0.85px, transparent 1.4px);
        background-size: 6px 8px;
        background-repeat: repeat-x;
        background-position: 0 50%;
        opacity: 0.85;
    }

    .cap-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .cap-category {
        display: grid;
        grid-row: span 2;
        grid-template-rows: subgrid;
        padding: 32px;
        background: var(--v8-glass-bg);
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
        border: 1px solid var(--v8-glass-border);
        box-shadow:
            0 1px 0 var(--v8-glass-highlight) inset,
            0 24px 60px -36px rgba(0, 0, 0, 0.25);
    }

    .cap-category-head {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 28px;
    }

    .cap-num {
        font-family: var(--v8-font-mono);
        font-size: 10px;
        letter-spacing: 0.14em;
        color: var(--v8-accent);
    }

    .cap-title {
        font-family: var(--v8-font-display);
        font-style: italic;
        font-size: clamp(22px, 2.4vw, 30px);
        font-weight: 400;
        line-height: 1.1;
        letter-spacing: -0.01em;
        color: var(--v8-text);
        margin: 0;
    }

    .cap-items {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .cap-item {
        font-family: var(--v8-font-mono);
        font-size: 12px;
        letter-spacing: 0.04em;
        color: var(--v8-text-secondary);
        padding: 10px 0;
        border-top: 1px solid var(--v8-glass-border);
        transition: color 0.2s ease, padding-left 0.3s cubic-bezier(0.22, 1, 0.36, 1);
        cursor: default;

        &:hover {
            color: var(--v8-text);
            padding-left: 8px;
        }
    }

    @media (max-width: 1024px) {
        .cap { padding: 60px 48px; }

        .cap-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .cap { padding: 40px 24px; }
        .cap-header { margin-bottom: 40px; }

        .cap-grid {
            grid-template-columns: 1fr;
        }

        .cap-category {
            padding: 28px;
        }
    }
</style>
