---
import type { Strings } from '../i18n/types';

type Props = {
    contact: Strings['contact'];
};

const { contact } = Astro.props;
const endpoint = import.meta.env.PUBLIC_MAIL_ENDPOINT || '';
---

<section class="contact" id="contact">
    <div class="contact-inner">
        <div class="contact-left">
            <h2 class="contact-headline" set:html={contact.headline.replace(/\n/g, '<br/>')} />
            <p class="contact-intro">{contact.intro}</p>
        </div>

        <div class="contact-right">
            <form
                class="contact-form"
                data-endpoint={endpoint}
                data-sending={contact.sendingLabel}
                data-submit={contact.submitLabel}
                data-success={contact.successMessage}
                data-error={contact.errorMessage}
            >
                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" for="name">{contact.nameLabel}</label>
                        <input class="form-input" type="text" id="name" name="name" required autocomplete="name" />
                    </div>
                    <div class="form-field">
                        <label class="form-label" for="email">{contact.emailLabel}</label>
                        <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
                    </div>
                </div>

                <div class="form-field">
                    <label class="form-label" for="context">{contact.contextLabel}</label>
                    <input class="form-input" type="text" id="context" name="context" placeholder={contact.contextPlaceholder} />
                </div>

                <div class="form-field">
                    <label class="form-label" for="message">{contact.messageLabel}</label>
                    <textarea class="form-input form-input--textarea" id="message" name="message" rows="4" required></textarea>
                </div>

                <div class="form-footer">
                    <button class="form-submit" type="submit">
                        <span class="form-submit__text">{contact.submitLabel}</span>
                        <span class="form-submit__arrow">&rarr;</span>
                    </button>
                    <p class="form-status" aria-live="polite"></p>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    const form = document.querySelector('.contact-form') as HTMLFormElement;
    if (form) {
        const endpoint = form.dataset.endpoint;
        const sendingLabel = form.dataset.sending!;
        const submitLabel = form.dataset.submit!;
        const successMsg = form.dataset.success!;
        const errorMsg = form.dataset.error!;
        const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement;
        const submitText = form.querySelector('.form-submit__text') as HTMLElement;
        const status = form.querySelector('.form-status') as HTMLElement;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            status.textContent = '';
            status.className = 'form-status';

            if (!endpoint) {
                status.textContent = errorMsg;
                status.classList.add('form-status--error');
                return;
            }

            submitBtn.disabled = true;
            submitText.textContent = sendingLabel;

            const data = {
                name: (form.elements.namedItem('name') as HTMLInputElement).value,
                email: (form.elements.namedItem('email') as HTMLInputElement).value,
                context: (form.elements.namedItem('context') as HTMLInputElement).value || undefined,
                message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
            };

            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                });

                if (res.ok) {
                    status.textContent = successMsg;
                    status.classList.add('form-status--success');
                    form.reset();
                } else {
                    status.textContent = errorMsg;
                    status.classList.add('form-status--error');
                }
            } catch {
                status.textContent = errorMsg;
                status.classList.add('form-status--error');
            } finally {
                submitBtn.disabled = false;
                submitText.textContent = submitLabel;
            }
        });
    }
</script>

<style lang="scss">
    .contact {
        padding: 120px 80px;
        background: var(--v8-bg-alt);

        &-inner {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: start;
            max-width: 1440px;
            margin: 0 auto;
        }

        &-left {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        &-headline {
            font-family: var(--v8-font-display);
            font-size: clamp(64px, 8vw, 120px);
            font-weight: 400;
            line-height: 0.9;
            color: var(--v8-text);
            letter-spacing: -0.02em;
        }

        &-intro {
            font-family: var(--v8-font-body);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-muted);
            max-width: 400px;
        }

        &-form {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
    }

    .form {
        &-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        &-field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
        }

        &-optional {
            color: var(--v8-text-faint);
        }

        &-input {
            background: transparent;
            border: none;
            border-bottom: 1px solid var(--v8-border);
            color: var(--v8-text);
            font-family: var(--v8-font-body);
            font-size: 16px;
            font-weight: 300;
            padding: 14px 0;
            outline: none;
            transition: border-color 0.2s ease;
            border-radius: 0;

            &::placeholder {
                color: var(--v8-text-faint);
                font-weight: 300;
            }

            &:focus {
                border-bottom-color: var(--v8-accent);
            }

            &--textarea {
                resize: vertical;
                min-height: 100px;
            }

        }

        &-submit {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 16px 0;
            border-bottom: 1px solid var(--v8-accent);
            align-self: flex-start;
            transition: gap 0.3s cubic-bezier(0.22, 1, 0.36, 1);

            &:hover {
                gap: 20px;
            }

            &__text {
                font-family: var(--v8-font-mono);
                font-size: 12px;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--v8-text);
            }

            &__arrow {
                font-size: 16px;
                color: var(--v8-accent);
                transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            }

            &:hover &__arrow {
                transform: translateX(4px);
            }

            &:disabled {
                opacity: 0.5;
                cursor: default;
            }
        }

        &-footer {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        &-status {
            font-family: var(--v8-font-mono);
            font-size: 11px;
            letter-spacing: 0.02em;
            color: var(--v8-text-muted);

            &--success {
                color: var(--v8-accent-status);
            }

            &--error {
                color: var(--v8-accent);
            }
        }
    }

    @media (max-width: 1024px) {
        .contact {
            padding: 80px 48px;
            border-top: none;

            &-inner {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            &-headline {
                font-size: clamp(48px, 8vw, 80px);
            }
        }
    }

    @media (max-width: 768px) {
        .contact {
            padding: 60px 24px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>
