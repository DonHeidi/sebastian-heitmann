---
import { Icon } from 'astro-icon/components';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Strings } from '../i18n/types';

type Props = {
    footer: Strings['footer'];
};

const { footer } = Astro.props;
const locale = Astro.currentLocale ?? 'en-us';
---

<footer class="footer">
    <div class="footer-inner">
        <span class="footer-copy">{footer.copyright}</span>
        <div class="footer-links">
            <a href={getRelativeLocaleUrl(locale, 'privacy')} class="footer-link">{footer.privacyLabel}</a>
            <a href={getRelativeLocaleUrl(locale, 'imprint')} class="footer-link">{footer.imprintLabel}</a>
        </div>
        <div class="footer-socials">
            <a href="https://www.linkedin.com/in/sebastian-heitmann/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <Icon name="simple-icons:linkedin" width={14} height={14} />
            </a>
            <a href="https://github.com/DonHeidi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <Icon name="simple-icons:github" width={14} height={14} />
            </a>
            <a href="https://www.bluesky.com/e2e_developer" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                <Icon name="simple-icons:bluesky" width={14} height={14} />
            </a>
        </div>
    </div>
</footer>

<style lang="scss">
    .footer {
        padding: 40px 80px;
        max-width: 1440px;
        margin: 0 auto;
        border-top: 2px solid var(--v8-accent);

        &-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        &-copy {
            font-family: var(--v8-font-mono);
            font-size: 11px;
            color: var(--v8-text-muted);
            flex: 1;
        }

        &-links {
            display: flex;
            gap: 24px;
            justify-content: center;
            flex: 1;
        }

        &-link {
            font-family: var(--v8-font-mono);
            font-size: 11px;
            color: var(--v8-text-muted);
            text-decoration: none;
            transition: color 0.2s ease;

            &:hover {
                color: var(--v8-text);
            }
        }

        &-socials {
            display: flex;
            gap: 16px;
            flex: 1;
            justify-content: flex-end;

            a {
                color: var(--v8-text-muted);
                display: flex;
                align-items: center;
                text-decoration: none;
                transition: color 0.2s ease;

                &:hover {
                    color: var(--v8-text);
                }

                :global(svg) {
                    fill: currentColor;
                }
            }
        }
    }

    @media (max-width: 768px) {
        .footer {
            padding: 24px;

            &-inner {
                flex-direction: column;
                gap: 16px;
                align-items: flex-start;
            }
        }
    }
</style>
