---
import type { Strings } from '../i18n/types';
import { Image } from 'astro:assets';

import poolPositionLogo from '../assets/logos/pool-position.png';
import jvmLogo from '../assets/logos/jvm.svg';
import synvertLogo from '../assets/logos/synvert.png';
import grannySmithLogo from '../assets/logos/granny-smith.jpg';
import offisLogo from '../assets/logos/offis.svg';

type Props = {
    logos: Strings['logos'];
};

const { logos } = Astro.props;

// Logos that should keep their original colors (no invert filter)
const noInvert = new Set(['Granny & Smith']);

// Per-logo config to compensate for varying whitespace baked into source images
// height: render height (taller = more internal whitespace to compensate for)
// spacing: vertical margin in mobile stacked layout (px) — less for logos with
//          built-in whitespace, more for tightly cropped logos
const logoMap: Record<string, { src: ImageMetadata; height: number; spacing: number }> = {
    'Pool Position GmbH': { src: poolPositionLogo, height: 70, spacing: 0 },
    'Jung von Matt':      { src: jvmLogo,          height: 24, spacing: 14 },
    'synvert':            { src: synvertLogo,       height: 31, spacing: 10 },
    'Granny & Smith':     { src: grannySmithLogo,   height: 53, spacing: 0 },
    'OFFIS':              { src: offisLogo,         height: 48, spacing: 4 },
};
---

<section class="logos">
    <div class="logos-inner">
        <div class="logos-group">
            <span class="logos-label">{logos.workingWithLabel}</span>
            <div class="logos-marks">
                {logos.workingWith.map(name => (
                    <span class="logos-mark" title={name} style={logoMap[name] ? `--logo-spacing: ${logoMap[name].spacing}px` : ''}>
                        {logoMap[name] ? (
                            <Image
                                src={logoMap[name].src}
                                alt={name}
                                height={logoMap[name].height}
                                class={`logos-img${noInvert.has(name) ? ' no-invert' : ''}`}
                            />
                        ) : (
                            <span class="logos-name">{name}</span>
                        )}
                    </span>
                ))}
            </div>
        </div>
        <div class="logos-divider"></div>
        <div class="logos-group">
            <span class="logos-label">{logos.previouslyAtLabel}</span>
            <div class="logos-marks">
                {logos.previouslyAt.map(name => (
                    <span class="logos-mark" title={name} style={logoMap[name] ? `--logo-spacing: ${logoMap[name].spacing}px` : ''}>
                        {logoMap[name] ? (
                            <Image
                                src={logoMap[name].src}
                                alt={name}
                                height={logoMap[name].height}
                                class={`logos-img${noInvert.has(name) ? ' no-invert' : ''}`}
                            />
                        ) : (
                            <span class="logos-name">{name}</span>
                        )}
                    </span>
                ))}
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .logos {
        background: #0C0C0C;
        padding: 0 80px;
        max-width: none;
        margin: 0;

        &-inner {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 48px;
            padding: 32px 0;
            max-width: 1440px;
            margin: 0 auto;
        }

        &-group {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.5);
            flex-shrink: 0;
            white-space: nowrap;
        }

        &-marks {
            display: flex;
            align-items: center;
            gap: 36px;
        }

        &-mark {
            display: flex;
            align-items: center;
            cursor: default;
        }

        &-img {
            width: auto;
            filter: invert(1) saturate(0) brightness(2) contrast(0.8);

            &.no-invert {
                filter: none;
                mix-blend-mode: lighten;
            }
        }

        &-name {
            font-family: var(--v8-font-display);
            font-size: 18px;
            color: rgba(255, 255, 255, 0.7);
            white-space: nowrap;
        }

        &-divider {
            width: 1px;
            height: 28px;
            background: rgba(255, 255, 255, 0.15);
            flex-shrink: 0;
        }
    }

    @media (max-width: 1024px) {
        .logos {
            padding: 0 48px;

            &-inner {
                gap: 32px;
            }

            &-marks {
                gap: 24px;
            }
        }
    }

    @media (max-width: 768px) {
        .logos {
            padding: 0 24px;

            &-inner {
                flex-direction: column;
                align-items: center;
                gap: 28px;
                padding: 32px 0;
            }

            &-group {
                flex-direction: column;
                align-items: center;
                gap: 16px;
            }

            &-marks {
                flex-direction: column;
                align-items: center;
                gap: 0;
            }

            &-mark {
                margin-block: var(--logo-spacing, 0);
            }

            &-divider {
                width: 40px;
                height: 1px;
            }
        }
    }
</style>
