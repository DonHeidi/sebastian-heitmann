---
import type { Strings } from '../i18n/types';

type Props = {
    proof: Strings['proof'];
};

const { proof } = Astro.props;
---

<section class="proof" id="proof">
    <div class="proof-inner">
        <div class="proof-header reveal">
            <span class="proof-label">{proof.resultsLabel}</span>
            <div class="proof-rule"></div>
        </div>

        <div class="proof-cases">
            {proof.cases.map((c, i) => (
                <article class="case reveal" style={`transition-delay: ${i * 0.08}s`}>
                    <div class="case-metric">
                        <span class="case-metric__number">{c.metric}</span>
                        <span class="case-metric__label">{c.metricLabel}</span>
                    </div>
                    <p class="case-description">{c.description}</p>
                    <span class="case-tag">{c.tag}</span>
                </article>
            ))}
        </div>

        <div class="proof-engagements reveal">
            <span class="proof-label">{proof.engagementLabel}</span>
            <div class="engagements-grid">
                {proof.engagements.map((e) => (
                    <div class:list={['engagement', { 'engagement--featured': e.featured }]}>
                        <span class="engagement-model">{e.model}</span>
                        <div class="engagement-price">
                            <span class="engagement-price__amount">{e.price}</span>
                            <span class="engagement-price__unit">{e.unit}</span>
                        </div>
                        {e.cycleNote && <span class="engagement-cycle-note">{e.cycleNote}</span>}
                        <p class="engagement-desc">{e.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .proof {
        padding: 120px 80px;
        max-width: 1440px;
        margin: 0 auto;
        border-top: 1px solid var(--v8-border);

        &-inner {
            display: flex;
            flex-direction: column;
            gap: 64px;
        }

        &-header {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            flex-shrink: 0;
        }

        &-rule {
            flex: 1;
            height: 1px;
            background: var(--v8-border);
        }

        &-cases {
            display: flex;
            flex-direction: column;
        }

        &-engagements {
            display: flex;
            flex-direction: column;
            gap: 24px;
            padding-top: 64px;
            border-top: 1px solid var(--v8-border);
        }
    }

    .case {
        display: grid;
        grid-template-columns: 280px 1fr auto;
        gap: 48px;
        align-items: baseline;
        padding: 32px 0;
        border-bottom: 1px solid var(--v8-border);

        &:first-child {
            border-top: 1px solid var(--v8-border);
        }

        &-metric {
            display: flex;
            flex-direction: column;
            gap: 4px;

            &__number {
                font-family: var(--v8-font-display);
                font-size: 56px;
                line-height: 1;
                color: var(--v8-metric-color);
                letter-spacing: -0.02em;
            }

            &__label {
                font-family: var(--v8-font-body);
                font-size: 14px;
                font-weight: 300;
                color: var(--v8-metric-label-color);
            }
        }

        &-description {
            font-family: var(--v8-font-body);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-tertiary);
            max-width: 520px;
        }

        &-tag {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            justify-self: end;
        }
    }

    .engagements-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--v8-border);
    }

    .engagement {
        background: var(--v8-bg);
        padding: 40px 32px;
        display: flex;
        flex-direction: column;
        gap: 16px;

        &--featured {
            background: var(--v8-bg-surface);

            .engagement-price__amount {
                color: var(--v8-accent);
            }
        }

        &-model {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
        }

        &-price {
            display: flex;
            align-items: baseline;
            gap: 4px;

            &__amount {
                font-family: var(--v8-font-display);
                font-size: 40px;
                line-height: 1;
                color: var(--v8-text);
            }

            &__unit {
                font-family: var(--v8-font-mono);
                font-size: 12px;
                color: var(--v8-text-muted);
            }
        }

        &-cycle-note {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.08em;
            color: var(--v8-text-muted);
            margin-top: -8px;
        }

        &-desc {
            font-family: var(--v8-font-body);
            font-size: 14px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--v8-text-dim);
        }
    }

    @media (max-width: 1024px) {
        .proof {
            padding: 48px 48px;
            border-top: none;
        }

        .case {
            grid-template-columns: 200px 1fr auto;
            gap: 32px;

            &-metric__number {
                font-size: 44px;
            }
        }
    }

    @media (max-width: 768px) {
        .proof {
            padding: 60px 24px;
        }

        .case {
            grid-template-columns: 1fr;
            gap: 12px;
            padding: 24px 0;

            &-tag {
                justify-self: start;
            }
        }

        .engagements-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
