---
import type { Strings } from '../i18n/types';
import type { Locale } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

type Props = {
    proof: Strings['proof'];
    locale?: Locale;
    webDevLink?: { label: string; href: string };
    tpmLink?: { label: string; href: string };
};

const { proof, locale, webDevLink, tpmLink } = Astro.props;
---

<section class="proof" id="proof">
    <span class="proof-corner proof-corner--tl" aria-hidden="true"></span>
    <span class="proof-corner proof-corner--tr" aria-hidden="true"></span>
    <span class="proof-corner proof-corner--bl" aria-hidden="true"></span>
    <span class="proof-corner proof-corner--br" aria-hidden="true"></span>

    <div class="proof-inner">
        <div class="proof-header reveal">
            <span class="proof-label">{proof.resultsLabel}</span>
            <div class="proof-rule"></div>
        </div>

        <div class="proof-cases">
            {proof.cases.map((c, i) => (
                <article class="case reveal" style={`transition-delay: ${i * 0.08}s`}>
                    <div class="case-metric">
                        <span class="case-metric__number">{c.metric}</span>
                        <span class="case-metric__label">{c.metricLabel}</span>
                    </div>
                    <p class="case-description">{c.description}</p>
                    <span class="case-tag">{c.tag}</span>
                </article>
            ))}
        </div>

        <div class="proof-engagements reveal">
            <div class="proof-header proof-header--inline">
                <span class="proof-label">{proof.engagementLabel}</span>
                <div class="proof-rule"></div>
            </div>
            <div class="engagements-grid">
                {proof.engagements.map((e, i) => (
                    <div class:list={['engagement', { 'engagement--featured': e.featured }]}>
                        <span class="engagement-corner engagement-corner--tl" aria-hidden="true"></span>
                        <span class="engagement-corner engagement-corner--br" aria-hidden="true"></span>
                        <span class="engagement-model">{e.model}</span>
                        <span class="engagement-billing">{e.billing}</span>
                        <p class="engagement-desc">{e.description}</p>
                        {i === 0 && tpmLink && (
                            <a class="engagement-link" href={tpmLink.href}>
                                <span>{tpmLink.label}</span>
                                <span class="engagement-link__arrow">&rarr;</span>
                            </a>
                        )}
                        {e.featured && webDevLink && (
                            <a class="engagement-link" href={webDevLink.href}>
                                <span>{webDevLink.label}</span>
                                <span class="engagement-link__arrow">&rarr;</span>
                            </a>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .proof {
        position: relative;
        padding: 120px 80px;
        max-width: 1440px;
        margin: 0 auto;
        border-top: 1px solid var(--v8-border);

        &-inner {
            display: flex;
            flex-direction: column;
            gap: 72px;
        }

        &-corner {
            position: absolute;
            width: 36px;
            height: 36px;
            color: var(--v8-text-faint);
            pointer-events: none;

            &--tl {
                top: 40px;
                left: 40px;
                border-top: 1px solid currentColor;
                border-left: 1px solid currentColor;
            }
            &--tr {
                top: 40px;
                right: 40px;
                border-top: 1px solid currentColor;
                border-right: 1px solid currentColor;
            }
            &--bl {
                bottom: 40px;
                left: 40px;
                border-bottom: 1px solid currentColor;
                border-left: 1px solid currentColor;
            }
            &--br {
                bottom: 40px;
                right: 40px;
                border-bottom: 1px solid currentColor;
                border-right: 1px solid currentColor;
            }
        }

        &-header {
            display: flex;
            align-items: center;
            gap: 24px;

            &--inline {
                margin-bottom: 24px;
            }
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            flex-shrink: 0;
        }

        &-rule {
            flex: 1;
            height: 8px;
            background-image: radial-gradient(circle, var(--v8-text-muted) 0.85px, transparent 1.4px);
            background-size: 6px 8px;
            background-repeat: repeat-x;
            background-position: 0 50%;
            opacity: 0.85;
        }

        &-cases {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        &-engagements {
            display: flex;
            flex-direction: column;
        }
    }

    .case {
        display: grid;
        grid-template-columns: 280px 1fr auto;
        gap: 48px;
        align-items: baseline;
        padding: 36px 32px;
        background: var(--v8-glass-bg);
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
        border: 1px solid var(--v8-glass-border);
        box-shadow:
            0 1px 0 var(--v8-glass-highlight) inset,
            0 24px 60px -36px rgba(0, 0, 0, 0.25);
        transition: border-color 0.2s ease;

        &:hover {
            border-color: var(--v8-text-muted);
        }

        &-metric {
            display: flex;
            flex-direction: column;
            gap: 4px;

            &__number {
                font-family: var(--v8-font-display);
                font-size: 56px;
                line-height: 1;
                color: var(--v8-metric-color);
                letter-spacing: -0.02em;
            }

            &__label {
                font-family: var(--v8-font-body);
                font-size: 14px;
                font-weight: 300;
                color: var(--v8-metric-label-color);
            }
        }

        &-description {
            font-family: var(--v8-font-body);
            font-size: 18px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-tertiary);
            max-width: 520px;
        }

        &-tag {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            justify-self: end;
        }
    }

    .engagements-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .engagement {
        position: relative;
        background: var(--v8-glass-bg);
        backdrop-filter: blur(12px) saturate(1.4);
        -webkit-backdrop-filter: blur(12px) saturate(1.4);
        border: 1px solid var(--v8-glass-border);
        padding: 44px 32px 36px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        box-shadow:
            0 1px 0 var(--v8-glass-highlight) inset,
            0 24px 60px -36px rgba(0, 0, 0, 0.25);
        transition: border-color 0.3s ease;

        &-corner {
            position: absolute;
            width: 12px;
            height: 12px;
            pointer-events: none;
            color: var(--v8-text-faint);

            &--tl {
                top: 8px;
                left: 8px;
                border-top: 1px solid currentColor;
                border-left: 1px solid currentColor;
            }
            &--br {
                bottom: 8px;
                right: 8px;
                border-bottom: 1px solid currentColor;
                border-right: 1px solid currentColor;
            }
        }

        &--featured {
            border-color: var(--v8-border-accent);

            .engagement-corner {
                color: var(--v8-accent);
            }

            .engagement-billing {
                color: var(--v8-accent);
            }
        }

        &-model {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
        }

        &-billing {
            font-family: var(--v8-font-display);
            font-size: 36px;
            line-height: 1.1;
            color: var(--v8-text);
            letter-spacing: -0.01em;
        }

        &-desc {
            font-family: var(--v8-font-body);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-tertiary);
        }

        &-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            margin-top: auto;
            padding-top: 16px;
            border-top: 1px solid var(--v8-border);
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--v8-accent);
            transition: gap 0.3s cubic-bezier(0.22, 1, 0.36, 1);

            &:hover { gap: 16px; }

            &__arrow {
                font-size: 13px;
                transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            }

            &:hover &__arrow { transform: translateX(3px); }
        }
    }

    @media (max-width: 1024px) {
        .proof {
            padding: 80px 48px;
            border-top: none;

            &-corner {
                &--tl, &--tr { top: 24px; }
                &--bl, &--br { bottom: 24px; }
                &--tl, &--bl { left: 24px; }
                &--tr, &--br { right: 24px; }
            }
        }

        .case {
            grid-template-columns: 200px 1fr auto;
            gap: 32px;
            padding: 28px 24px;

            &-metric__number {
                font-size: 44px;
            }
        }
    }

    @media (max-width: 768px) {
        .proof {
            padding: 60px 24px;

            &-corner {
                width: 24px;
                height: 24px;

                &--tl, &--tr { top: 16px; }
                &--bl, &--br { bottom: 16px; }
                &--tl, &--bl { left: 16px; }
                &--tr, &--br { right: 16px; }
            }
        }

        .case {
            grid-template-columns: 1fr;
            gap: 12px;
            padding: 24px 20px;

            &-tag {
                justify-self: start;
            }
        }

        .engagements-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
