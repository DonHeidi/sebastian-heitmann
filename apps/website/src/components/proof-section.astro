---
import type { Strings } from '../i18n/types';
import type { Locale } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

type Props = {
    proof: Strings['proof'];
    locale?: Locale;
    webDevLink?: { label: string; href: string };
    tpmLink?: { label: string; href: string };
};

const { proof, locale, webDevLink, tpmLink } = Astro.props;
---

<section class="proof" id="proof">
    <div class="proof-inner">
        <div class="proof-header reveal">
            <span class="proof-label">{proof.resultsLabel}</span>
            <div class="proof-rule"></div>
        </div>

        <div class="proof-cases">
            {proof.cases.map((c, i) => (
                <article class="case reveal" style={`transition-delay: ${i * 0.08}s`}>
                    <div class="case-metric">
                        <span class="case-metric__number">{c.metric}</span>
                        <span class="case-metric__label">{c.metricLabel}</span>
                    </div>
                    <p class="case-description">{c.description}</p>
                    <span class="case-tag">{c.tag}</span>
                </article>
            ))}
        </div>

        <div class="proof-engagements reveal">
            <span class="proof-label">{proof.engagementLabel}</span>
            <div class="engagements-grid">
                {proof.engagements.map((e, i) => (
                    <div class:list={['engagement', { 'engagement--featured': e.featured }]}>
                        <span class="engagement-model">{e.model}</span>
                        <span class="engagement-billing">{e.billing}</span>
                        <p class="engagement-desc">{e.description}</p>
                        {i === 0 && tpmLink && (
                            <a class="engagement-link" href={tpmLink.href}>
                                <span>{tpmLink.label}</span>
                                <span class="engagement-link__arrow">&rarr;</span>
                            </a>
                        )}
                        {e.featured && webDevLink && (
                            <a class="engagement-link" href={webDevLink.href}>
                                <span>{webDevLink.label}</span>
                                <span class="engagement-link__arrow">&rarr;</span>
                            </a>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .proof {
        padding: 120px 80px;
        max-width: 1440px;
        margin: 0 auto;
        border-top: 1px solid var(--v8-border);

        &-inner {
            display: flex;
            flex-direction: column;
            gap: 64px;
        }

        &-header {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            flex-shrink: 0;
        }

        &-rule {
            flex: 1;
            height: 1px;
            background: var(--v8-border);
        }

        &-cases {
            display: flex;
            flex-direction: column;
        }

        &-engagements {
            display: flex;
            flex-direction: column;
            gap: 24px;
            padding-top: 64px;
            border-top: 1px solid var(--v8-border);
        }
    }

    .case {
        display: grid;
        grid-template-columns: 280px 1fr auto;
        gap: 48px;
        align-items: baseline;
        padding: 32px 0;
        border-bottom: 1px solid var(--v8-border);

        &:first-child {
            border-top: 1px solid var(--v8-border);
        }

        &-metric {
            display: flex;
            flex-direction: column;
            gap: 4px;

            &__number {
                font-family: var(--v8-font-display);
                font-size: 56px;
                line-height: 1;
                color: var(--v8-metric-color);
                letter-spacing: -0.02em;
            }

            &__label {
                font-family: var(--v8-font-body);
                font-size: 14px;
                font-weight: 300;
                color: var(--v8-metric-label-color);
            }
        }

        &-description {
            font-family: var(--v8-font-body);
            font-size: 18px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-tertiary);
            max-width: 520px;
        }

        &-tag {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            justify-self: end;
        }
    }

    .engagements-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--v8-border);
    }

    .engagement {
        background: var(--v8-bg);
        padding: 48px 32px;
        display: flex;
        flex-direction: column;
        gap: 20px;

        &--featured {
            background: var(--v8-bg-surface);

            .engagement-billing {
                color: var(--v8-accent);
            }
        }

        &-model {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
        }

        &-billing {
            font-family: var(--v8-font-display);
            font-size: 36px;
            line-height: 1.1;
            color: var(--v8-text);
            letter-spacing: -0.01em;
        }

        &-desc {
            font-family: var(--v8-font-body);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-tertiary);
        }

        &-link {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            margin-top: auto;
            padding-top: 8px;
            border-top: 1px solid var(--v8-border);
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--v8-accent);
            transition: gap 0.3s cubic-bezier(0.22, 1, 0.36, 1);

            &:hover { gap: 16px; }

            &__arrow {
                font-size: 13px;
                transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            }

            &:hover &__arrow { transform: translateX(3px); }
        }
    }

    @media (max-width: 1024px) {
        .proof {
            padding: 48px 48px;
            border-top: none;
        }

        .case {
            grid-template-columns: 200px 1fr auto;
            gap: 32px;

            &-metric__number {
                font-size: 44px;
            }
        }
    }

    @media (max-width: 768px) {
        .proof {
            padding: 60px 24px;
        }

        .case {
            grid-template-columns: 1fr;
            gap: 12px;
            padding: 24px 0;

            &-tag {
                justify-self: start;
            }
        }

        .engagements-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
