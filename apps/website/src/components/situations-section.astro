---
import type { Strings } from '../i18n/types';

type Props = {
    situations: Strings['situations'];
};

const { situations } = Astro.props;
---

<section class="situations reveal">
    <div class="situations-inner">
        <div class="situations-header">
            <span class="situations-label">{situations.label}</span>
            <div class="situations-rule"></div>
        </div>
        <ul class="situations-list">
            {situations.items.map((item, i) => (
                <li class="situations-item" style={`transition-delay: ${i * 0.06}s`}>{item}</li>
            ))}
        </ul>
    </div>
</section>

<style lang="scss">
    .situations {
        padding: 80px 80px 80px;
        margin-top: 64px;
        max-width: 100%;
        background: var(--v8-bg-alt);

        &-inner {
            display: flex;
            flex-direction: column;
            gap: 24px;
            max-width: 1440px;
            margin: 0 auto;
        }

        &-header {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            flex-shrink: 0;
        }

        &-rule {
            flex: 1;
            height: 8px;
            background-image: radial-gradient(circle, var(--v8-text-muted) 0.85px, transparent 1.4px);
            background-size: 6px 8px;
            background-repeat: repeat-x;
            background-position: 0 50%;
            opacity: 0.85;
        }

        &-list {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        &-item {
            font-family: var(--v8-font-body);
            font-size: 20px;
            font-weight: 300;
            line-height: 1.6;
            color: var(--v8-text-tertiary);
            padding: 24px 0 24px 32px;
            border-bottom: 1px solid var(--v8-border);
            position: relative;
            transition: color 0.3s ease;

            &::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 8px;
                height: 8px;
                border-radius: 50%;
                border: 1px solid var(--v8-accent);
                transition: background 0.3s ease;
            }

            &:hover {
                color: var(--v8-text);

                &::before {
                    background: var(--v8-accent);
                }
            }

            &:first-child {
                border-top: 1px solid var(--v8-border);
            }
        }
    }

    @media (max-width: 1024px) {
        .situations {
            padding: 40px 48px;
        }
    }

    @media (max-width: 768px) {
        .situations {
            padding: 40px 24px;

            &-item {
                font-size: 15px;
            }
        }
    }
</style>
