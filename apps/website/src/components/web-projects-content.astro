    /* ────────────────────────────────────────────────
       SECTION THEMING — light/dark alternation
       ──────────────────────────────────────────────── */
    $lt-bg: #F5F4F0;
    $lt-accent: #B82A00;

    @mixin lt {
        --v8-bg: #{$lt-bg};
        --v8-bg-alt: #EDECEA;
        --v8-bg-surface: #E8E7E3;
        --v8-text: #141413;
        --v8-text-muted: rgba(20, 20, 19, 0.50);
        --v8-text-secondary: rgba(20, 20, 19, 0.70);
        --v8-text-tertiary: rgba(20, 20, 19, 0.65);
        --v8-text-dim: rgba(20, 20, 19, 0.6);
        --v8-text-faint: rgba(20, 20, 19, 0.32);
        --v8-accent: #{$lt-accent};
        --v8-accent-status: #1A7A52;
        --v8-border: rgba(20, 20, 19, 0.10);
        --v8-border-accent: rgba(184, 42, 0, 0.35);
    }

    @mixin dk {
        --v8-bg: #0C0C0C;
        --v8-bg-alt: #101010;
        --v8-bg-surface: #141414;
        --v8-text: #F2F0EB;
        --v8-text-muted: rgba(242, 240, 235, 0.65);
        --v8-text-secondary: rgba(242, 240, 235, 0.75);
        --v8-text-tertiary: rgba(242, 240, 235, 0.68);
        --v8-text-dim: rgba(242, 240, 235, 0.62);
        --v8-text-faint: rgba(242, 240, 235, 0.45);
        --v8-accent: #FF3B00;
        --v8-accent-status: #00DC82;
        --v8-border: rgba(242, 240, 235, 0.08);
        --v8-border-accent: rgba(255, 59, 0, 0.3);
    }

    @mixin bleed-bg($bg) {
        position: relative;
        z-index: 0;

        &::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50%;
            width: 100vw;
            transform: translateX(-50%);
            background: #{$bg};
            z-index: -2;
        }
    }

    /*
     * Section order (children of <main>):
     *   1  .wp-hero        — Hero (photo bg)
     *   2  .wp-section     — Packages        LIGHT
     *   3  .wp-section     — Add-ons         LIGHT
     *   4  .wp-section     — Problem         LIGHT
     *   5  .wp-section     — Approach        LIGHT
     *   6  .wp-section     — Comparison      DARK
     *   7  .wp-section     — AI              DARK
     *   8  .wp-section     — Scope           DARK
     *   9  .wp-consulting  — Bridge          DARK
     *  10  .wp-section     — FAQ             LIGHT
     *  11  .contact        — Contact form
     */

    /* Hero: glass card */
    .wp-hero {
        min-height: 85vh;
        justify-content: flex-end;

        .wp-hero__content {
            background: var(--v8-glass-bg);
            backdrop-filter: blur(24px) saturate(1.35);
            -webkit-backdrop-filter: blur(24px) saturate(1.35);
            border: 1px solid var(--v8-glass-border);
            box-shadow:
                0 1px 0 var(--v8-glass-highlight) inset,
                0 30px 80px -40px rgba(0, 0, 0, 0.35);
            padding: 48px 56px;
            max-width: 800px;
            margin: 0 !important;
        }

        @media (max-width: 768px) {
            min-height: 70vh;
            padding-bottom: 40px;

            &::before { background-position: 65% center; }

            .wp-hero__content {
                padding: 24px 20px;
                max-width: 100%;

                .wp-hero__headline { font-size: clamp(28px, 7vw, 40px); }
                .wp-hero__subline { font-size: 15px; }
            }
        }
    }

    /* Light band: Packages, Add-ons, Problem, Approach (2-5) */
    .wp-section:nth-child(2),
    .wp-section:nth-child(3),
    .wp-section:nth-child(4),
    .wp-section:nth-child(5) {
        @include lt;
        @include bleed-bg($lt-bg);

        & > * { position: relative; z-index: 1; }
    }

    .wp-section:nth-child(2) { padding-top: 100px; }

    /* Dark band: Comparison (6), AI (7), Scope (8) */
    .wp-section:nth-child(6),
    .wp-section:nth-child(7),
    .wp-section:nth-child(8) {
        @include dk;
        @include bleed-bg(#0C0C0C);

        & > * { position: relative; z-index: 1; }
    }

    .wp-section:nth-child(6) { padding-top: 100px; }

    /* Consulting bridge (9) */
    .wp-consulting {
        @include dk;
        @include bleed-bg(#101010);
    }

    /* Light band: FAQ (10) */
    .wp-section:nth-child(10) {
        @include lt;
        @include bleed-bg($lt-bg);
        padding-top: 100px;

        & > * { position: relative; z-index: 1; }
    }

    /* Card hover effects */
    .wp-package {
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s ease;
        &:hover { transform: translateY(-4px); border-color: var(--v8-text-muted) !important; }
    }

    .wp-addon {
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s ease;
        &:hover { transform: translateY(-3px); border-color: var(--v8-text-muted) !important; }
    }

    .wp-faq__item {
        transition: background-color 0.2s ease;
        &:hover { background-color: var(--v8-bg-alt); }
    }

    /* Comparison: highlight "This offering" column */
    .wp-comparison__cell:last-child { color: var(--v8-text); font-weight: 400; }
    .wp-comparison__header:last-child { color: var(--v8-accent); }
