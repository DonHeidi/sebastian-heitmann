---
import { localeConfig } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

type Props = {
  locale: Locale;
  title: string;
  description: string;
  alternates?: Array<{ hreflang: string; href: string }>;
  includeRedirectScript?: boolean;
  ogType?: string;
  ogImage?: string;
  canonical?: string;
};

const {
  locale,
  title,
  description,
  alternates = [],
  includeRedirectScript = false,
  ogType = 'website',
  ogImage,
  canonical,
} = Astro.props;
const htmlLang = localeConfig[locale].htmlLang;
const siteOrigin = 'https://www.sebastian-heitmann.dev';
const canonicalUrl = canonical ?? `${siteOrigin}${Astro.url.pathname}`;
const resolvedOgImage = ogImage ?? (ogType === 'website' ? `${siteOrigin}/og-image.jpg` : undefined);
---

<html lang={htmlLang}>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" type="image/svg+xml" href="/favicon.svg">
        <link rel="apple-touch-icon" href="/favicon.svg">
        <meta name="theme-color" content="#0C0C0C">
        <title>{title}</title>
        <meta name="description" content={description}>
        <link rel="canonical" href={canonicalUrl}>
        <meta property="og:type" content={ogType}>
        <meta property="og:title" content={title}>
        <meta property="og:description" content={description}>
        <meta property="og:url" content={canonicalUrl}>
        {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}
        <meta property="og:locale" content={locale === 'de-de' ? 'de_DE' : 'en_US'}>
        <meta property="og:locale:alternate" content={locale === 'de-de' ? 'en_US' : 'de_DE'}>
        <meta name="twitter:card" content={resolvedOgImage ? 'summary_large_image' : 'summary'}>
        <meta name="twitter:title" content={title}>
        <meta name="twitter:description" content={description}>
        {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}
        <link rel="preload" href="/fonts/InstrumentSerif-Regular.woff2" as="font" type="font/woff2" crossorigin>
        <link rel="preload" href="/fonts/DMSans-Regular.woff2" as="font" type="font/woff2" crossorigin>
        <link rel="preload" href="/fonts/IBMPlexMono-Regular.woff2" as="font" type="font/woff2" crossorigin>
        {alternates.map(alt => (
            <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
        ))}
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Sebastian Heitmann",
            "description": description,
            "url": "https://www.sebastian-heitmann.dev",
            "founder": {
                "@type": "Person",
                "name": "Sebastian Heitmann",
                "jobTitle": "Technology Consultant",
                "url": "https://www.sebastian-heitmann.dev",
                "sameAs": [
                    "https://www.linkedin.com/in/sebastian-heitmann/",
                    "https://github.com/DonHeidi"
                ]
            },
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Kastanienallee 24",
                "addressLocality": "Tostedt",
                "postalCode": "21255",
                "addressCountry": "DE"
            },
            "email": "me@sebastian-heitmann.dev",
            "areaServed": ["DE", "AT", "CH", "EU"],
            "knowsLanguage": ["de", "en"],
            "priceRange": "$$"
        })} />
        <script is:inline>
            (function() {
                var stored = localStorage.getItem('theme');
                if (stored === 'dark' || stored === 'light') {
                    document.documentElement.classList.add(stored);
                } else {
                    document.documentElement.classList.add(
                        window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
                    );
                }
            })();
        </script>
        <slot name="head" />
        {includeRedirectScript && (
            <script is:inline>
                (function() {
                    if (localStorage.getItem('locale')) return;
                    var lang = (navigator.language || '').toLowerCase();
                    var target;
                    if (lang.startsWith('de')) target = 'de-de';
                    if (target) {
                        localStorage.setItem('locale', target);
                        window.location.replace('/' + target + '/');
                    } else {
                        localStorage.setItem('locale', 'en-us');
                    }
                })();
            </script>
        )}
    </head>
    <body>
        <slot />
    </body>
</html>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    });
</script>

<style lang="scss" is:global>
    @font-face {
        font-family: 'Instrument Serif';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/InstrumentSerif-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'Instrument Serif';
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/InstrumentSerif-Italic.woff2') format('woff2');
    }
    @font-face {
        font-family: 'DM Sans';
        font-style: normal;
        font-weight: 300 500;
        font-display: swap;
        src: url('/fonts/DMSans-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'DM Sans';
        font-style: italic;
        font-weight: 300 400;
        font-display: swap;
        src: url('/fonts/DMSans-Italic.woff2') format('woff2');
    }
    @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/IBMPlexMono-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/fonts/IBMPlexMono-Bold.woff2') format('woff2');
    }

    *, *::before, *::after { box-sizing: border-box; }
    * { margin: 0; }

    html {
        scrollbar-gutter: stable;
        width: 100%;
        height: 100%;
    }

    @media (prefers-reduced-motion: no-preference) {
        html { interpolate-size: allow-keywords; }
    }

    body {
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
    }
    img, picture, video, canvas, svg { display: block; max-width: 100%; }
    input, button, textarea, select { font: inherit; }
    p, h1, h2, h3, h4, h5, h6 { overflow-wrap: break-word; }
    p { text-wrap: pretty; }
    h1, h2, h3, h4, h5, h6 { text-wrap: balance; }

    html.dark {
        --v8-bg: #0C0C0C;
        --v8-bg-alt: #101010;
        --v8-bg-surface: #141414;
        --v8-text: #F2F0EB;
        --v8-text-muted: rgba(242, 240, 235, 0.65);
        --v8-text-secondary: rgba(242, 240, 235, 0.75);
        --v8-text-tertiary: rgba(242, 240, 235, 0.68);
        --v8-text-dim: rgba(242, 240, 235, 0.62);
        --v8-text-faint: rgba(242, 240, 235, 0.45);
        --v8-accent: #FF3B00;
        --v8-accent-status: #00DC82;
        --v8-border: rgba(242, 240, 235, 0.08);
        --v8-border-accent: rgba(255, 59, 0, 0.3);
        --v8-metric-color: var(--v8-text);
        --v8-metric-label-color: var(--v8-text-muted);
        --v8-photo-filter: saturate(0) contrast(1.1) brightness(0.9);
        --v8-photo-filter-hover: saturate(0.8) contrast(1.05);
        --v8-glass-bg: rgba(18, 18, 18, 0.55);
        --v8-glass-border: rgba(242, 240, 235, 0.12);
        --v8-glass-highlight: rgba(242, 240, 235, 0.08);
        --v8-dot-color: rgba(242, 240, 235, 0.22);
        --v8-bp-dot: rgba(140, 195, 230, 0.085);
        --v8-bp-line: rgba(140, 195, 230, 0.022);
        --v8-bp-line-minor: rgba(140, 195, 230, 0.008);
        --v8-bp-fiducial: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='112' height='112'><g fill='%238CC3E6' fill-opacity='0.13'><rect x='0' y='0' width='6' height='1'/><rect x='0' y='0' width='1' height='6'/><rect x='106' y='0' width='6' height='1'/><rect x='111' y='0' width='1' height='6'/><rect x='0' y='106' width='1' height='6'/><rect x='0' y='111' width='6' height='1'/><rect x='106' y='111' width='6' height='1'/><rect x='111' y='106' width='1' height='6'/></g></svg>");
        --v8-bp-reticle: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160' viewBox='0 0 160 160'><g fill='none' stroke='%238CC3E6' stroke-opacity='0.05' stroke-width='1'><circle cx='80' cy='80' r='56'/><circle cx='80' cy='80' r='36'/><line x1='80' y1='8' x2='80' y2='32'/><line x1='80' y1='128' x2='80' y2='152'/><line x1='8' y1='80' x2='32' y2='80'/><line x1='128' y1='80' x2='152' y2='80'/></g><circle cx='80' cy='80' r='1.5' fill='%238CC3E6' fill-opacity='0.1'/></svg>");
        --v8-bp-bracket: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120' viewBox='0 0 120 120'><g fill='none' stroke='%238CC3E6' stroke-opacity='0.12' stroke-width='1'><polyline points='0,28 0,0 28,0'/><polyline points='92,0 120,0 120,28'/><polyline points='120,92 120,120 92,120'/><polyline points='28,120 0,120 0,92'/></g></svg>");
    }

    html.light {
        --v8-bg: #F7F6F2;
        --v8-bg-alt: #E9E6DE;
        --v8-bg-surface: #ECEAE4;
        --v8-text: #141413;
        --v8-text-muted: rgba(20, 20, 19, 0.6);
        --v8-text-secondary: rgba(20, 20, 19, 0.75);
        --v8-text-tertiary: rgba(20, 20, 19, 0.65);
        --v8-text-dim: rgba(20, 20, 19, 0.6);
        --v8-text-faint: rgba(20, 20, 19, 0.4);
        --v8-accent: #B82A00;
        --v8-accent-status: #1A7A52;
        --v8-metric-color: #B82A00;
        --v8-metric-label-color: rgba(20, 20, 19, 0.6);
        --v8-border: rgba(20, 20, 19, 0.16);
        --v8-border-accent: rgba(184, 42, 0, 0.35);
        --v8-photo-filter: saturate(0.85) contrast(1.08);
        --v8-photo-filter-hover: saturate(1) contrast(1);
        --v8-glass-bg: rgba(247, 246, 242, 0.55);
        --v8-glass-border: rgba(20, 20, 19, 0.1);
        --v8-glass-highlight: rgba(255, 255, 255, 0.5);
        --v8-dot-color: rgba(20, 20, 19, 0.22);
        --v8-bp-dot: rgba(120, 75, 35, 0.16);
        --v8-bp-line: rgba(120, 75, 35, 0.045);
        --v8-bp-line-minor: rgba(120, 75, 35, 0.014);
        --v8-bp-fiducial: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='112' height='112'><g fill='%23784B23' fill-opacity='0.2'><rect x='0' y='0' width='6' height='1'/><rect x='0' y='0' width='1' height='6'/><rect x='106' y='0' width='6' height='1'/><rect x='111' y='0' width='1' height='6'/><rect x='0' y='106' width='1' height='6'/><rect x='0' y='111' width='6' height='1'/><rect x='106' y='111' width='6' height='1'/><rect x='111' y='106' width='1' height='6'/></g></svg>");
        --v8-bp-reticle: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160' viewBox='0 0 160 160'><g fill='none' stroke='%23784B23' stroke-opacity='0.07' stroke-width='1'><circle cx='80' cy='80' r='56'/><circle cx='80' cy='80' r='36'/><line x1='80' y1='8' x2='80' y2='32'/><line x1='80' y1='128' x2='80' y2='152'/><line x1='8' y1='80' x2='32' y2='80'/><line x1='128' y1='80' x2='152' y2='80'/></g><circle cx='80' cy='80' r='1.5' fill='%23784B23' fill-opacity='0.14'/></svg>");
        --v8-bp-bracket: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120' viewBox='0 0 120 120'><g fill='none' stroke='%23784B23' stroke-opacity='0.18' stroke-width='1'><polyline points='0,28 0,0 28,0'/><polyline points='92,0 120,0 120,28'/><polyline points='120,92 120,120 92,120'/><polyline points='28,120 0,120 0,92'/></g></svg>");
    }

    :root {
        --v8-font-display: 'Instrument Serif', Georgia, serif;
        --v8-font-body: 'DM Sans', system-ui, sans-serif;
        --v8-font-mono: 'IBM Plex Mono', monospace;
    }

    .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.revealed { opacity: 1; transform: translateY(0); }

    @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
    }
</style>

<style lang="scss">
    body {
        background-color: var(--v8-bg);
        background-image:
            var(--v8-bp-reticle),
            var(--v8-bp-reticle),
            var(--v8-bp-reticle),
            var(--v8-bp-bracket),
            var(--v8-bp-bracket),
            var(--v8-bp-bracket);
        background-position:
            right 6% top 320px,
            left 7% top 1480px,
            right 11% top 2840px,
            left 4% top 760px,
            right 4% top 2080px,
            left 9% top 3520px;
        background-repeat: no-repeat;
        background-size:
            160px 160px,
            128px 128px,
            104px 104px,
            120px 120px,
            96px 96px,
            140px 140px;
        color: var(--v8-text);
        width: 100%;
        min-height: 100%;
        transition: background-color 0.3s ease, color 0.3s ease;
        position: relative;
        isolation: isolate;
    }

    body::before,
    body::after {
        content: '';
        position: absolute;
        inset: 0;
        height: 100%;
        z-index: -1;
        pointer-events: none;
    }

    body::before {
        background-image:
            radial-gradient(circle at 1px 1px, var(--v8-bp-dot) 1px, transparent 1.5px);
        background-size: 28px 28px;
        -webkit-mask-image:
            radial-gradient(ellipse 70% 22% at 20% 8%, #000 0%, transparent 75%),
            radial-gradient(ellipse 55% 18% at 85% 32%, rgba(0, 0, 0, 0.85) 0%, transparent 70%),
            radial-gradient(ellipse 80% 25% at 15% 68%, rgba(0, 0, 0, 0.7) 0%, transparent 75%),
            radial-gradient(ellipse 50% 16% at 90% 92%, rgba(0, 0, 0, 0.6) 0%, transparent 70%);
        mask-image:
            radial-gradient(ellipse 70% 22% at 20% 8%, #000 0%, transparent 75%),
            radial-gradient(ellipse 55% 18% at 85% 32%, rgba(0, 0, 0, 0.85) 0%, transparent 70%),
            radial-gradient(ellipse 80% 25% at 15% 68%, rgba(0, 0, 0, 0.7) 0%, transparent 75%),
            radial-gradient(ellipse 50% 16% at 90% 92%, rgba(0, 0, 0, 0.6) 0%, transparent 70%);
        -webkit-mask-composite: source-over;
        mask-composite: add;
    }

    body::after {
        background-image:
            var(--v8-bp-fiducial),
            linear-gradient(to right, var(--v8-bp-line) 1px, transparent 1px),
            linear-gradient(to bottom, var(--v8-bp-line) 1px, transparent 1px),
            linear-gradient(to right, var(--v8-bp-line-minor) 1px, transparent 1px),
            linear-gradient(to bottom, var(--v8-bp-line-minor) 1px, transparent 1px);
        background-size:
            112px 112px,
            112px 112px,
            112px 112px,
            28px 28px,
            28px 28px;
        background-repeat: repeat;
        -webkit-mask-image:
            radial-gradient(ellipse 60% 18% at 80% 14%, #000 0%, transparent 75%),
            radial-gradient(ellipse 75% 22% at 25% 42%, rgba(0, 0, 0, 0.85) 0%, transparent 75%),
            radial-gradient(ellipse 55% 18% at 75% 72%, rgba(0, 0, 0, 0.75) 0%, transparent 75%),
            radial-gradient(ellipse 70% 20% at 30% 96%, rgba(0, 0, 0, 0.65) 0%, transparent 75%);
        mask-image:
            radial-gradient(ellipse 60% 18% at 80% 14%, #000 0%, transparent 75%),
            radial-gradient(ellipse 75% 22% at 25% 42%, rgba(0, 0, 0, 0.85) 0%, transparent 75%),
            radial-gradient(ellipse 55% 18% at 75% 72%, rgba(0, 0, 0, 0.75) 0%, transparent 75%),
            radial-gradient(ellipse 70% 20% at 30% 96%, rgba(0, 0, 0, 0.65) 0%, transparent 75%);
        -webkit-mask-composite: source-over;
        mask-composite: add;
    }

    @media (max-width: 768px) {
        body::before { background-size: 22px 22px; }
        body::after { background-size: 88px 88px, 88px 88px, 88px 88px, 22px 22px, 22px 22px; }
    }
</style>
