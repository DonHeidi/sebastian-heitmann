---
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/navigation.astro';
import Footer from '../../components/footer.astro';
import AuthorCard from '../../components/author-card.astro';
import { getStrings } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ id, data }) =>
    !id.startsWith('de-de/') && !data.draft
  );
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const locale = (Astro.currentLocale ?? 'en-us') as Locale;
const s = getStrings(locale);

const authorEntry = await getEntry('authors', entry.data.author);
const publishedDate = entry.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const publishedISO = entry.data.publishedAt.toISOString();
const modifiedISO = entry.data.updatedAt?.toISOString();

const wordCount = entry.body
  ? entry.body.replace(/```[\s\S]*?```/g, ' ').split(/\s+/).filter(Boolean).length
  : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const siteOrigin = 'https://www.sebastian-heitmann.dev';
const canonicalUrl = `${siteOrigin}${Astro.url.pathname}`;
const heroImageUrl = entry.data.headerImage
  ? `${siteOrigin}${entry.data.headerImage.src}`
  : `${siteOrigin}/og-image.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.abstract,
  image: [heroImageUrl],
  datePublished: publishedISO,
  ...(modifiedISO ? { dateModified: modifiedISO } : {}),
  author: authorEntry
    ? {
        '@type': 'Person',
        name: authorEntry.data.name,
        url: siteOrigin,
      }
    : undefined,
  publisher: {
    '@type': 'Organization',
    name: 'Sebastian Heitmann',
    logo: {
      '@type': 'ImageObject',
      url: `${siteOrigin}/og-image.jpg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  inLanguage: locale === 'de-de' ? 'de-DE' : 'en-US',
  ...(entry.data.tags && entry.data.tags.length > 0
    ? { keywords: entry.data.tags.join(', ') }
    : {}),
};

// Series lookup
let seriesParts: Array<{ slug: string; title: string; part: number }> = [];
if (entry.data.series) {
  const seriesName = entry.data.series.name;
  const allArticles = await getCollection('articles', ({ id, data }) =>
    !id.startsWith('de-de/') && !data.draft && data.series?.name === seriesName
  );
  seriesParts = allArticles
    .map((a) => ({ slug: a.id, title: a.data.title, part: a.data.series!.part }))
    .sort((a, b) => a.part - b.part);
}
---

<Layout
  locale={locale}
  title={`${entry.data.title} — Sebastian Heitmann`}
  description={entry.data.abstract ?? s.meta.description}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Navigation nav={s.nav} languagePicker={s.languagePicker} />

  <main class="article-page">
    {entry.data.headerImage && (
      <div class="article-page__hero">
        <Image
          src={entry.data.headerImage}
          alt={entry.data.title}
          width={1200}
          height={480}
          class="article-page__hero-image"
        />
      </div>
    )}

    <div class="article-page__layout">
      <article class="article-page__main">
        <header class="article-page__header">
          {entry.data.headerDetailImage && (
            <Image
              src={entry.data.headerDetailImage}
              alt={entry.data.title}
              width={200}
              height={200}
              class="article-page__detail-image"
            />
          )}
          <div class="article-page__title-block">
            {entry.data.series && seriesParts.length > 0 && (
              <p class="article-page__series-label">
                {entry.data.series.name} &middot; Part {entry.data.series.part} of {seriesParts.length}
              </p>
            )}
            <p class="article-page__category">{s.categories[entry.data.category]}</p>
            <h1 class="article-page__title">{entry.data.title}</h1>
            {entry.data.subline && (
              <p class="article-page__subline">{entry.data.subline}</p>
            )}
            <p class="article-page__meta-line">
              <time class="article-page__date" datetime={publishedISO}>{publishedDate}</time>
              <span class="article-page__meta-sep" aria-hidden="true">&middot;</span>
              <span class="article-page__reading-time">{readingMinutes} min read</span>
            </p>
          </div>
        </header>

        <div class="article-page__body">
          <Content />
        </div>

        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="article-page__tags">
            {entry.data.tags.map((tag) => (
              <span class="article-page__tag">{tag}</span>
            ))}
          </div>
        )}

        {entry.data.series && seriesParts.length > 0 && (
          <nav class="article-page__series" aria-label="Series navigation">
            <div class="article-page__series-header">
              <span class="article-page__series-overline">Series</span>
              <span class="article-page__series-name">{entry.data.series.name}</span>
            </div>
            <ol class="article-page__series-list">
              {seriesParts.map((part) => (
                <li class:list={['article-page__series-item', { 'article-page__series-item--current': part.slug === entry.id }]}>
                  <span class="article-page__series-part">{String(part.part).padStart(2, '0')}</span>
                  {part.slug === entry.id ? (
                    <span class="article-page__series-title">{part.title}</span>
                  ) : (
                    <a class="article-page__series-title" href={getRelativeLocaleUrl(locale, `articles/${part.slug}`)}>{part.title}</a>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        )}

        <div class="article-page__footer-row">
          <a href={getRelativeLocaleUrl(locale, 'articles')} class="article-page__back">
            &larr; All articles
          </a>
        </div>
      </article>

      <aside class="article-page__sidebar">
        {authorEntry && (
          <AuthorCard
            name={authorEntry.data.name}
            role={authorEntry.data.role}
            description={authorEntry.data.description}
            avatar={authorEntry.data.avatar}
            email={authorEntry.data.email}
            socials={authorEntry.data.socials}
          />
        )}
        <div class="article-page__authorship">
          {entry.data.authorship === 'human' && 'Written by a human'}
          {entry.data.authorship === 'ai-assisted' && 'AI-assisted'}
          {entry.data.authorship === 'agent-written' && 'Written by an AI agent'}
        </div>
      </aside>
    </div>
  </main>

  <Footer footer={s.footer} />
</Layout>

<style lang="scss">
  .article-page {
    max-width: 1440px;
    margin: 0 auto;

    &__hero {
      margin-top: 80px;
      padding: 0 80px;
      overflow: hidden;
      max-height: 480px;
    }

    &__hero-image {
      width: 100%;
      max-height: 480px;
      object-fit: cover;
    }

    &__layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 64px;
      padding: 0 80px 120px;
    }

    &__main {
      min-width: 0;
    }

    &__header {
      padding-top: 48px;
      margin-bottom: 48px;
      position: relative;
    }

    &__detail-image {
      float: inline-end;
      width: 200px;
      height: 200px;
      object-fit: cover;
      border: 4px solid var(--v8-bg);
      margin: 0 0 16px 24px;
      position: relative;
      top: -120px;
      margin-bottom: -104px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    &__title-block {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    &__category {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--v8-accent);
    }

    &__title {
      font-family: var(--v8-font-display);
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 400;
      line-height: 1.05;
      color: var(--v8-text);
    }

    &__subline {
      font-family: var(--v8-font-body);
      font-size: 18px;
      font-weight: 300;
      line-height: 1.5;
      color: var(--v8-text-secondary);
    }

    &__meta-line {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--v8-font-mono);
      font-size: 12px;
      color: var(--v8-text-muted);
    }

    &__date,
    &__reading-time {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      color: var(--v8-text-muted);
    }

    &__meta-sep {
      color: var(--v8-text-faint);
    }

    &__body {
      font-family: var(--v8-font-body);
      font-size: 17px;
      font-weight: 300;
      line-height: 1.7;
      color: var(--v8-text-secondary);

      :global(h2) {
        font-family: var(--v8-font-display);
        font-size: 28px;
        font-weight: 400;
        color: var(--v8-text);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
      }

      :global(h3) {
        font-family: var(--v8-font-display);
        font-size: 22px;
        font-weight: 400;
        color: var(--v8-text);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      :global(p) {
        margin-bottom: 1.25rem;
      }

      :global(blockquote) {
        font-style: italic;
        border-left: 3px solid var(--v8-accent);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--v8-text-muted);
      }

      :global(code) {
        font-family: var(--v8-font-mono);
        font-size: 0.9em;
        background-color: var(--v8-bg-surface);
        padding: 0.1em 0.35em;
        border-radius: 2px;
      }

      :global(pre) {
        background-color: var(--v8-bg-surface);
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1.5rem 0;
        border-radius: 2px;

        :global(code) {
          background: none;
          padding: 0;
          font-size: 14px;
        }
      }

      :global(img) {
        max-width: 100%;
        height: auto;
      }

      :global(ul),
      :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }

      :global(li) {
        margin-bottom: 0.5rem;
      }

      :global(a) {
        color: var(--v8-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    }

    &__series-label {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
      margin-bottom: 4px;
    }

    &__series {
      margin-top: 48px;
      padding: 24px;
      border: 1px solid var(--v8-border);
    }

    &__series-header {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-bottom: 16px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--v8-border);
    }

    &__series-overline {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
    }

    &__series-name {
      font-family: var(--v8-font-display);
      font-size: 20px;
      line-height: 1.2;
      color: var(--v8-text);
    }

    &__series-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    &__series-item {
      display: flex;
      gap: 16px;
      align-items: baseline;
      padding: 10px 0;
      border-bottom: 1px solid var(--v8-border);

      &:last-child {
        border-bottom: none;
      }

      &--current .article-page__series-part {
        color: var(--v8-accent);
      }

      &--current .article-page__series-title {
        color: var(--v8-text);
      }
    }

    &__series-part {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      color: var(--v8-text-muted);
      flex-shrink: 0;
      letter-spacing: 0.04em;
    }

    &__series-title {
      font-family: var(--v8-font-body);
      font-size: 15px;
      color: var(--v8-text-tertiary);
      text-decoration: none;
      transition: color 0.2s ease;

      &:is(a):hover {
        color: var(--v8-text);
      }
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--v8-border);
      margin-top: 48px;
    }

    &__tag {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      letter-spacing: 0.05em;
      color: var(--v8-text-muted);
      border: 1px solid var(--v8-border);
      padding: 4px 10px;
    }

    &__footer-row {
      margin-top: 32px;
    }

    &__back {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.05em;
      color: var(--v8-accent);
      text-decoration: none;
      transition: opacity 0.2s ease;

      &:hover {
        opacity: 0.7;
      }
    }

    &__sidebar {
      padding-top: 80px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    &__authorship {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-faint);
    }
  }

  @media (max-width: 1024px) {
    .article-page {
      &__layout {
        grid-template-columns: 1fr;
        gap: 0;
      }

      &__sidebar {
        order: -1;
        padding-top: 40px;
        padding-bottom: 0;
      }

      &__header {
        padding-top: 40px;
      }

      &__title-block {
        margin-top: 0;
      }
    }
  }

  @media (max-width: 768px) {
    .article-page {
      &__hero {
        padding: 0 24px;
        margin-top: 40px;
      }

      &__layout {
        padding: 0 24px 60px;
      }

      &__detail-image {
        width: 120px;
        height: 120px;
        top: -80px;
        margin-bottom: -64px;
      }
    }
  }
</style>
