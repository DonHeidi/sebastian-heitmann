---
import { getCollection, getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/navigation.astro';
import Footer from '../../../components/footer.astro';
import AuthorCard from '../../../components/author-card.astro';
import { getStrings } from '../../../i18n/utils';
import type { Locale } from '../../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles', ({ data }) => !data.draft);
  const enArticles = allArticles.filter(({ id }) => !id.startsWith('de-de/'));
  const deArticles = allArticles.filter(({ id }) => id.startsWith('de-de/'));
  const deSlugs = new Set(deArticles.map(({ id }) => id.replace('de-de/', '')));

  const paths = [];
  // German versions
  for (const entry of deArticles) {
    paths.push({ params: { slug: entry.id.replace('de-de/', '') }, props: { entry } });
  }
  // Fallback: English articles without German version
  for (const entry of enArticles) {
    if (!deSlugs.has(entry.id)) {
      paths.push({ params: { slug: entry.id }, props: { entry } });
    }
  }
  return paths;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const locale = (Astro.currentLocale ?? 'de-de') as Locale;
const s = getStrings(locale);

const authorEntry = await getEntry('authors', entry.data.author);
const publishedDate = entry.data.publishedAt.toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const publishedISO = entry.data.publishedAt.toISOString();
const modifiedISO = entry.data.updatedAt?.toISOString();

const wordCount = entry.body
  ? entry.body.replace(/```[\s\S]*?```/g, ' ').split(/\s+/).filter(Boolean).length
  : 0;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const siteOrigin = 'https://www.sebastian-heitmann.dev';
const canonicalUrl = `${siteOrigin}${Astro.url.pathname}`;
const heroImageUrl = entry.data.headerImage
  ? `${siteOrigin}${entry.data.headerImage.src}`
  : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.abstract,
  ...(heroImageUrl ? { image: [heroImageUrl] } : {}),
  datePublished: publishedISO,
  ...(modifiedISO ? { dateModified: modifiedISO } : {}),
  author: authorEntry
    ? {
        '@type': 'Person',
        name: authorEntry.data.name,
        url: siteOrigin,
      }
    : undefined,
  publisher: {
    '@type': 'Organization',
    name: 'Sebastian Heitmann',
    logo: {
      '@type': 'ImageObject',
      url: `${siteOrigin}/og-image.jpg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  inLanguage: 'de-DE',
  ...(entry.data.tags && entry.data.tags.length > 0
    ? { keywords: entry.data.tags.join(', ') }
    : {}),
};

// Series lookup — prefer German articles, fall back to English
let seriesParts: Array<{ slug: string; title: string; part: number }> = [];
if (entry.data.series) {
  const seriesName = entry.data.series.name;
  const all = await getCollection('articles', ({ data }) => !data.draft && data.series?.name === seriesName);
  const deParts = all.filter(({ id }) => id.startsWith('de-de/'));
  const enParts = all.filter(({ id }) => !id.startsWith('de-de/'));
  const deSlugs = new Set(deParts.map(({ id }) => id.replace('de-de/', '')));
  const merged = [
    ...deParts.map((a) => ({ slug: a.id.replace('de-de/', ''), title: a.data.title, part: a.data.series!.part })),
    ...enParts
      .filter(({ id }) => !deSlugs.has(id))
      .map((a) => ({ slug: a.id, title: a.data.title, part: a.data.series!.part })),
  ];
  seriesParts = merged.sort((a, b) => a.part - b.part);
}

const currentSlug = entry.id.replace('de-de/', '');
---

<Layout
  locale={locale}
  title={`${entry.data.title} — Sebastian Heitmann`}
  description={entry.data.abstract ?? s.meta.description}
  ogType="article"
  ogImage={heroImageUrl}
  canonical={canonicalUrl}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <meta slot="head" property="article:published_time" content={publishedISO} />
  {modifiedISO && <meta slot="head" property="article:modified_time" content={modifiedISO} />}
  {authorEntry && <meta slot="head" property="article:author" content={authorEntry.data.name} />}
  <meta slot="head" property="article:section" content={s.categories[entry.data.category]} />
  {entry.data.tags?.map((tag) => (
    <meta slot="head" property="article:tag" content={tag} />
  ))}
  <Navigation nav={s.nav} languagePicker={s.languagePicker} />

  <main class="article-page">
    {entry.data.headerImage && (
      <div class="article-page__hero">
        <Image
          src={entry.data.headerImage}
          alt={entry.data.title}
          width={1200}
          height={480}
          class="article-page__hero-image"
        />
      </div>
    )}

    <div class="article-page__layout">
      <article class="article-page__main">
        <header
          class:list={[
            'article-page__header',
            { 'article-page__header--no-hero': !entry.data.headerImage },
          ]}
        >
          {entry.data.headerDetailImage && (
            <Image
              src={entry.data.headerDetailImage}
              alt={entry.data.title}
              width={200}
              height={200}
              class:list={[
                'article-page__detail-image',
                { 'article-page__detail-image--no-hero': !entry.data.headerImage },
              ]}
            />
          )}
          <div class="article-page__title-block">
            {entry.data.series && seriesParts.length > 0 && (
              <p class="article-page__series-label">
                {entry.data.series.name} &middot; Teil {entry.data.series.part} von {seriesParts.length}
              </p>
            )}
            <p class="article-page__category">{s.categories[entry.data.category]}</p>
            <h1 class="article-page__title">{entry.data.title}</h1>
            {entry.data.subline && (
              <p class="article-page__subline">{entry.data.subline}</p>
            )}
            <p class="article-page__meta-line">
              <time class="article-page__date" datetime={publishedISO}>{publishedDate}</time>
              <span class="article-page__meta-sep" aria-hidden="true">&middot;</span>
              <span class="article-page__reading-time">{readingMinutes} Min. Lesezeit</span>
            </p>
          </div>
        </header>

        <div class="article-page__body">
          <Content />
        </div>

        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="article-page__tags">
            {entry.data.tags.map((tag) => (
              <span class="article-page__tag">{tag}</span>
            ))}
          </div>
        )}

        {entry.data.series && seriesParts.length > 0 && (
          <nav class="article-page__series" aria-label="Serien-Navigation">
            <div class="article-page__series-header">
              <span class="article-page__series-overline">Serie</span>
              <span class="article-page__series-name">{entry.data.series.name}</span>
            </div>
            <ol class="article-page__series-list">
              {seriesParts.map((part) => (
                <li class:list={['article-page__series-item', { 'article-page__series-item--current': part.slug === currentSlug }]}>
                  <span class="article-page__series-part">{String(part.part).padStart(2, '0')}</span>
                  {part.slug === currentSlug ? (
                    <span class="article-page__series-title">{part.title}</span>
                  ) : (
                    <a class="article-page__series-title" href={getRelativeLocaleUrl(locale, `articles/${part.slug}`)}>{part.title}</a>
                  )}
                </li>
              ))}
            </ol>
          </nav>
        )}

        <div class="article-page__footer-row">
          <a href={getRelativeLocaleUrl(locale, 'articles')} class="article-page__back">
            &larr; Alle Artikel
          </a>
        </div>
      </article>

      <aside class="article-page__sidebar">
        {authorEntry && (
          <AuthorCard
            name={authorEntry.data.name}
            role={authorEntry.data.role}
            description={authorEntry.data.description}
            avatar={authorEntry.data.avatar}
            email={authorEntry.data.email}
            socials={authorEntry.data.socials}
          />
        )}
        <div class="article-page__authorship">
          {entry.data.authorship === 'human' && 'Geschrieben von einem Menschen'}
          {entry.data.authorship === 'ai-assisted' && 'KI-unterst\u00FCtzt'}
          {entry.data.authorship === 'agent-written' && 'Geschrieben von einem KI-Agenten'}
          {entry.data.aiTranslated && (
            <>
              <span class="article-page__authorship-sep" aria-hidden="true">&middot;</span>
              <span>KI-übersetzt</span>
            </>
          )}
        </div>
      </aside>
    </div>
  </main>

  <Footer footer={s.footer} />
</Layout>

<style lang="scss">
  .article-page {
    max-width: 1440px;
    margin: 0 auto;

    &__hero {
      margin-top: 80px;
      margin-inline: calc(50% - 50vw);
      width: 100vw;
      overflow: hidden;
      max-height: clamp(280px, 32vw, 520px);
    }

    &__hero-image {
      width: 100%;
      height: clamp(280px, 32vw, 520px);
      max-height: clamp(280px, 32vw, 520px);
      object-fit: cover;
    }

    &__layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 64px;
      padding: 0 80px 120px;
    }

    &__main {
      min-width: 0;
      padding: 0 32px;
    }

    &__header {
      position: relative;
      margin-top: -180px;
      margin-left: -32px;
      margin-right: -32px;
      padding: 32px 32px 0;
      margin-bottom: 80px;
      background: var(--v8-bg);
      z-index: 2;

      &--no-hero {
        margin-top: 0;
        margin-left: 0;
        margin-right: 0;
        padding: 64px 0 0;
        background: transparent;
      }
    }

    &__detail-image {
      position: absolute;
      top: 40px;
      right: -32px;
      width: 200px;
      height: 200px;
      object-fit: cover;
      border: 6px solid var(--v8-bg);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
      z-index: 3;

      &--no-hero {
        position: static;
        float: inline-end;
        width: 200px;
        height: 200px;
        border-width: 4px;
        margin: 0 0 16px 24px;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
      }
    }

    &__title-block {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 0 168px 0 0;
    }

    &__category {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--v8-accent);
    }

    &__title {
      font-family: var(--v8-font-display);
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 400;
      line-height: 1.05;
      color: var(--v8-text);
    }

    &__subline {
      font-family: var(--v8-font-body);
      font-size: 18px;
      font-weight: 300;
      line-height: 1.5;
      color: var(--v8-text-secondary);
    }

    &__meta-line {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--v8-font-mono);
      font-size: 12px;
      color: var(--v8-text-muted);
    }

    &__date,
    &__reading-time {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      color: var(--v8-text-muted);
    }

    &__meta-sep {
      color: var(--v8-text-faint);
    }

    &__body {
      font-family: var(--v8-font-body);
      font-size: 24px;
      font-weight: 300;
      line-height: 1.7;
      color: var(--v8-text-secondary);
      max-width: 53ch;

      :global(h2) {
        font-family: var(--v8-font-display);
        font-size: 28px;
        font-weight: 400;
        color: var(--v8-text);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
      }

      :global(h3) {
        font-family: var(--v8-font-display);
        font-size: 22px;
        font-weight: 400;
        color: var(--v8-text);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      :global(p) {
        margin-bottom: 1.25rem;
      }

      :global(blockquote) {
        font-style: italic;
        border-left: 3px solid var(--v8-accent);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--v8-text-muted);
      }

      :global(code) {
        font-family: var(--v8-font-mono);
        font-size: 0.9em;
        background-color: var(--v8-bg-surface);
        padding: 0.1em 0.35em;
        border-radius: 2px;
      }

      :global(pre) {
        background-color: var(--v8-bg-surface);
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1.5rem 0;
        border-radius: 2px;

        :global(code) {
          background: none;
          padding: 0;
          font-size: 14px;
        }
      }

      :global(img) {
        max-width: 100%;
        height: auto;
      }

      :global(ul),
      :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
      }

      :global(li) {
        margin-bottom: 0.5rem;
      }

      :global(a) {
        color: var(--v8-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
    }

    &__series-label {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
      margin-bottom: 4px;
    }

    &__series {
      margin-top: 48px;
      padding: 24px;
      border: 1px solid var(--v8-border);
    }

    &__series-header {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-bottom: 16px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--v8-border);
    }

    &__series-overline {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--v8-text-muted);
    }

    &__series-name {
      font-family: var(--v8-font-display);
      font-size: 20px;
      line-height: 1.2;
      color: var(--v8-text);
    }

    &__series-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    &__series-item {
      display: flex;
      gap: 16px;
      align-items: baseline;
      padding: 10px 0;
      border-bottom: 1px solid var(--v8-border);

      &:last-child {
        border-bottom: none;
      }

      &--current .article-page__series-part {
        color: var(--v8-accent);
      }

      &--current .article-page__series-title {
        color: var(--v8-text);
      }
    }

    &__series-part {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      color: var(--v8-text-muted);
      flex-shrink: 0;
      letter-spacing: 0.04em;
    }

    &__series-title {
      font-family: var(--v8-font-body);
      font-size: 15px;
      color: var(--v8-text-tertiary);
      text-decoration: none;
      transition: color 0.2s ease;

      &:is(a):hover {
        color: var(--v8-text);
      }
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--v8-border);
      margin-top: 48px;
    }

    &__tag {
      font-family: var(--v8-font-mono);
      font-size: 11px;
      letter-spacing: 0.05em;
      color: var(--v8-text-muted);
      border: 1px solid var(--v8-border);
      padding: 4px 10px;
    }

    &__footer-row {
      margin-top: 32px;
    }

    &__back {
      font-family: var(--v8-font-mono);
      font-size: 12px;
      letter-spacing: 0.05em;
      color: var(--v8-accent);
      text-decoration: none;
      transition: opacity 0.2s ease;

      &:hover {
        opacity: 0.7;
      }
    }

    &__sidebar {
      padding-top: 80px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      position: sticky;
      top: 24px;
      align-self: start;
    }

    &__authorship {
      font-family: var(--v8-font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--v8-text-faint);
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    &__authorship-sep {
      color: var(--v8-text-faint);
      opacity: 0.6;
    }
  }

  @media (max-width: 1024px) {
    .article-page {
      &__layout {
        grid-template-columns: 1fr;
        gap: 0;
      }

      &__sidebar {
        order: -1;
        padding-top: 40px;
        padding-bottom: 0;
        position: static;
      }

      &__title-block {
        margin-top: 0;
      }

      &__body {
        font-size: 17px;
        max-width: none;
      }

      &__main {
        padding: 0 40px;
      }

      &__header {
        margin-top: -120px;
        margin-left: -40px;
        margin-right: -40px;
        padding: 40px 40px 0;

        &--no-hero {
          margin-top: 0;
          margin-left: 0;
          margin-right: 0;
          padding: 40px 0 0;
        }
      }

      &__detail-image {
        top: 40px;
        right: -32px;
      }
    }
  }

  @media (max-width: 768px) {
    .article-page {
      &__hero {
        margin-top: 40px;
      }

      &__layout {
        padding: 0 24px 60px;
      }

      &__main {
        padding: 0 32px;
      }

      &__header {
        margin-top: -64px;
        margin-left: -32px;
        margin-right: -32px;
        padding: 32px 32px 0;

        &--no-hero {
          margin-top: 0;
          margin-left: 0;
          margin-right: 0;
          padding: 32px 0 0;
        }
      }

      &__title-block {
        padding: 0 88px 0 0;
      }

      &__detail-image {
        width: 120px;
        height: 120px;
        top: 40px;
        right: -32px;
        border-width: 4px;

        &--no-hero {
          width: 120px;
          height: 120px;
          margin: 0 0 12px 16px;
        }
      }
    }
  }
</style>
