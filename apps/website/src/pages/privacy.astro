---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/navigation.astro';
import Footer from '../components/footer.astro';
import { getStrings, getHreflangAlternates } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale = Astro.currentLocale as Locale;
const s = getStrings(locale);
const alternates = getHreflangAlternates();
---
<Layout locale={locale} title="Privacy Policy — Sebastian Heitmann" description="Privacy policy and data protection information." alternates={alternates}>
    <Navigation nav={s.nav} languagePicker={s.languagePicker} />
    <main class="legal">
        <div class="legal-inner">
            <h1 class="legal-title">Privacy Policy</h1>
            <div class="legal-rule"></div>

            <section class="legal-section">
                <h2 class="legal-heading">Controller</h2>
                <p>Sebastian Heitmann<br/>Kastanienallee 24<br/>21255 Tostedt<br/>Email: <a href="mailto:me@sebastian-heitmann.dev">me@sebastian-heitmann.dev</a></p>
            </section>

            <section class="legal-section">
                <h2 class="legal-heading">General information</h2>
                <p>This website does not use cookies for analytics, tracking, or marketing purposes. No external fonts or third-party content that would automatically transmit data to external providers upon page load are embedded.</p>
                <p>However, when accessing this website, technically necessary connection data is processed by the hosting provider, in particular IP address, date and time of access, and other technical log data.</p>
            </section>

            <section class="legal-section">
                <h2 class="legal-heading">Hosting</h2>
                <p>This website is hosted by Scaleway SAS, 8 rue de la Ville l'&Eacute;v&ecirc;que, 75008 Paris, France.</p>
                <p>As part of hosting, technically necessary personal data is processed, in particular connection and server log data.</p>
                <p>Processing is carried out for the purpose of providing, maintaining stability, and securing the website on the basis of Art. 6(1)(f) GDPR. The legitimate interest lies in the secure and reliable operation of this online service.</p>
                <p>The recipient of the data is the hosting provider acting as a data processor. Data is only stored for as long as necessary for the secure and stable operation of the website or as required by the hosting provider's technical and organizational retention periods.</p>
            </section>

            <section class="legal-section">
                <h2 class="legal-heading">Contact form</h2>
                <p>When you use the contact form, the data you enter is processed. This includes your name, email address, an optional context field, and your message.</p>
                <p>Processing is carried out for the purpose of handling your inquiry. The legal basis is, depending on the content of the inquiry, Art. 6(1)(b) GDPR (pre-contractual measures) or Art. 6(1)(f) GDPR (legitimate interest in handling other inquiries).</p>
                <p>Scaleway Transactional Email is used as a data processor for technical transmission. No disclosure to unauthorized third parties takes place.</p>
                <p>Data is deleted once your inquiry has been conclusively handled and no statutory retention obligations apply.</p>
            </section>

            <section class="legal-section">
                <h2 class="legal-heading">Local storage</h2>
                <p>This website stores your language and display preferences (e.g. theme) in your browser's local storage. This information remains on your device and is not transmitted to the operator or third parties.</p>
            </section>

            <section class="legal-section">
                <h2 class="legal-heading">Your rights</h2>
                <p>Under GDPR, you have the right to access, rectification, erasure, restriction of processing, objection to processing, and data portability.</p>
                <p>If processing is based on your consent, you may withdraw it at any time with effect for the future.</p>
                <p>To exercise your rights, an informal message to <a href="mailto:me@sebastian-heitmann.dev">me@sebastian-heitmann.dev</a> is sufficient.</p>
            </section>

            <section class="legal-section">
                <h2 class="legal-heading">Right to lodge a complaint</h2>
                <p>You have the right to lodge a complaint with a data protection supervisory authority. The responsible authority is:</p>
                <p>Der Landesbeauftragte f&uuml;r den Datenschutz Niedersachsen<br/>Prinzenstra&szlig;e 5<br/>30159 Hannover</p>
            </section>
        </div>
    </main>
    <Footer footer={s.footer} />
</Layout>

<style lang="scss">
    .legal {
        padding: 160px 80px 120px;
        max-width: 1440px;
        margin: 0 auto;

        &-inner {
            max-width: 640px;
        }

        &-title {
            font-family: var(--v8-font-display);
            font-size: clamp(40px, 5vw, 64px);
            line-height: 1.05;
            color: var(--v8-text);
            margin-bottom: 24px;
        }

        &-rule {
            width: 48px;
            height: 2px;
            background: var(--v8-accent);
            margin-bottom: 64px;
        }

        &-section {
            margin-bottom: 48px;

            p {
                font-family: var(--v8-font-body);
                font-size: 16px;
                font-weight: 300;
                line-height: 1.8;
                color: var(--v8-text-tertiary);
            }

            a {
                color: var(--v8-accent);
                text-decoration: none;
                border-bottom: 1px solid transparent;
                transition: border-color 0.2s;

                &:hover {
                    border-bottom-color: var(--v8-accent);
                }
            }
        }

        &-heading {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            margin-bottom: 16px;
        }
    }

    @media (max-width: 768px) {
        .legal {
            padding: 120px 24px 80px;
        }
    }
</style>
