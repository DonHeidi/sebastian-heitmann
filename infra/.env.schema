# Infrastructure deploy credentials and inputs. Every sensitive value resolves
# from Proton Pass via the proton-pass plugin (needs an authenticated pass-cli
# session). Consumed by scripts/apply-infra.sh and scripts/deploy-website.sh,
# which run their Scaleway/Terraform commands under `varlock run`.
# @defaultRequired=infer @defaultSensitive=false
# @plugin(@varlock/proton-pass-plugin)
# @initProtonPass()
# ----------

# Scaleway API key. Read natively by the scw CLI and the Terraform Scaleway
# provider, and derived into AWS_* (ACCESS_KEY@PROJECT_ID) for the S3 state backend.
# @sensitive @required
SCW_ACCESS_KEY=protonPass(pass://sebastian-heitmann/scaleway/access-key)
# @sensitive @required
SCW_SECRET_KEY=protonPass(pass://sebastian-heitmann/scaleway/secret-key)

# Scaleway organization ID — lets the scw CLI authenticate purely from env
# (no ~/.config/scw/config.yaml needed), so deploys work on any machine with vault access.
# @required
SCW_DEFAULT_ORGANIZATION_ID=protonPass(pass://sebastian-heitmann/scaleway/org-id)

# Contact form recipient (PII), passed to Terraform as var.mail_recipient.
# @sensitive @type=email @required
TF_VAR_mail_recipient=protonPass(pass://sebastian-heitmann/mail/recipient)
