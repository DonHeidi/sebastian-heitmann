---
type Props = {
  gridArea: string;
  class?: string;
};

const { gridArea, class: className }: Props = Astro.props;
---
<div class:list={['bento-card', className]} style={`grid-area: ${gridArea};`}>
  <slot />
</div>

<style lang="scss">
  .bento-card {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: rgba(22, 24, 48, 0.7);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 1px 1px 1px 0 rgba(101, 108, 161, 0.15),
      -1px -1px 2px 0 rgba(101, 108, 161, 0.08),
      inset -1px -1px 0 0 rgba(0, 0, 0, 0.3),
      2px 2px 8px 0 rgba(0, 0, 0, 0.4);
    padding: 2rem;
  }
</style>
