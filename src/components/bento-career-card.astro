---
import BentoCard from './bento-card.astro';

const companies = [
  {
    id: 'i22',
    name: 'i22',
    role: 'Sr. Agile Project Manager',
    details: null,
  },
  {
    id: 'jung-von-matt',
    name: 'Jung von Matt',
    role: 'Technical Consultant',
    details: {
      positions: [
        'Technical Consultant (Feb 2020 to Mar 2021)',
        'Jr. Technical Project Manager (Sep 2019 to Jan 2020)',
      ],
      sections: [
        {
          heading: 'Projects, Tasks, and Tools',
          items: [
            'Technical support for the development and international rollout of a sales platform in the content management sector',
            'Conception and partial implementation of the migration of the intranet platform as a Product Owner',
            'Gap analysis for the implementation of IT projects',
            'Implementing measures to increase IT satisfaction',
            'General tasks such as documentation, training, and creating presentations',
            'Methods and tools: Scrum, Confluence, Jira, Next.js, Contentful, Keynote',
          ],
        },
      ],
    },
  },
  {
    id: 'datadrivers',
    name: 'Datadrivers',
    role: 'Sr. Consultant Project Operations',
    details: null,
  },
  {
    id: 'granny-smith',
    name: 'Granny & Smith',
    role: 'Technical Consultant',
    details: null,
  },
  {
    id: 'offis',
    name: 'Offis',
    role: 'Research Assistant',
    details: null,
  },
  {
    id: 'pool-position',
    name: 'Pool Position',
    role: 'Software Developer',
    details: null,
  },
  {
    id: 'syneriax',
    name: 'SyneriaX',
    role: 'Project Lead .Net',
    details: null,
  },
  {
    id: 'goldkalb',
    name: 'Goldkalb',
    role: 'Software Developer',
    details: null,
  },
];
---
<BentoCard gridArea="career">
  <div class="career">
    <h3 class="career__heading">Former Career</h3>
    <div class="career__layout">
      <div class="career__tabs">
        {companies.map((company, i) => (
          <button
            class:list={['career__tab', { 'career__tab--active': i === 0 }]}
            data-target={company.id}
          >
            <span class="career__tab-name">{company.name}</span>
            <span class="career__tab-role">{company.role}</span>
          </button>
        ))}
      </div>
      <div class="career__panels">
        {companies.map((company, i) => (
          <div
            class:list={['career__panel', { 'career__panel--active': i === 0 }]}
            data-panel={company.id}
          >
            <h4 class="career__panel-name">{company.name}</h4>
            <p class="career__panel-role">{company.role}</p>
            {company.details ? (
              <div class="career__detail">
                {company.details.positions.map((pos) => (
                  <p class="career__position">{pos}</p>
                ))}
                {company.details.sections.map((section) => (
                  <div class="career__section">
                    <h5 class="career__section-heading">{section.heading}</h5>
                    <ul class="career__section-list">
                      {section.items.map((item) => (
                        <li class="career__section-item">{item}</li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            ) : (
              <p class="career__placeholder">Details coming soon.</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</BentoCard>

<script>
  const tabs = document.querySelectorAll('.career__tab');
  const panels = document.querySelectorAll('.career__panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.target;
      tabs.forEach((t) => t.classList.remove('career__tab--active'));
      panels.forEach((p) => p.classList.remove('career__panel--active'));
      tab.classList.add('career__tab--active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('career__panel--active');
    });
  });
</script>

<style lang="scss">
  .career {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;

    &__heading {
      font-family: 'AntonSC', sans-serif;
      font-size: 2rem;
      font-weight: 500;
      line-height: 1;
      color: var(--clr-magenta);
    }

    &__layout {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 1.5rem;
      flex: 1;
      min-height: 0;
    }

    &__tabs {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      overflow-y: auto;
    }

    &__tab {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      padding: 0.5rem 0.75rem;
      background: none;
      border: none;
      border-left: 3px solid transparent;
      cursor: pointer;
      text-align: left;
      transition: border-color 0.2s ease, background-color 0.2s ease;
      border-radius: 0 4px 4px 0;

      &:hover {
        background-color: rgba(255, 255, 255, 0.04);
      }

      &--active {
        border-left-color: var(--clr-magenta);
        background-color: rgba(255, 255, 255, 0.06);
      }
    }

    &__tab-name {
      font-family: 'AntonSC', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1;
      color: var(--clr-green);
    }

    &__tab-role {
      font-family: 'SpaceGrotesk', sans-serif;
      font-size: 0.625rem;
      line-height: 1.3;
      color: rgba(255, 255, 255, 0.5);
    }

    &__panels {
      overflow-y: auto;
    }

    &__panel {
      display: none;
      flex-direction: column;
      gap: 0.75rem;

      &--active {
        display: flex;
      }
    }

    &__panel-name {
      font-family: 'AntonSC', sans-serif;
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1;
      color: var(--clr-green);
    }

    &__panel-role {
      font-family: 'SpaceGrotesk', sans-serif;
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.6);
    }

    &__position {
      font-family: 'SpaceGrotesk', sans-serif;
      font-size: 0.75rem;
      line-height: 1.4;
      color: var(--clr-font-primary);
      padding-left: 1rem;
      position: relative;

      &::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.35em;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--clr-magenta);
      }
    }

    &__detail {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 0.5rem;
    }

    &__section-heading {
      font-family: 'AntonSC', sans-serif;
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    &__section-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    &__section-item {
      font-family: 'SpaceGrotesk', sans-serif;
      font-size: 0.75rem;
      line-height: 1.4;
      color: var(--clr-font-primary);
    }

    &__placeholder {
      font-family: 'SpaceGrotesk', sans-serif;
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.4);
      font-style: italic;
    }
  }

  @media (max-width: 768px) {
    .career__layout {
      grid-template-columns: 1fr;
    }

    .career__tabs {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .career__tab {
      border-left: none;
      border-bottom: 2px solid transparent;
      border-radius: 4px;
      padding: 0.375rem 0.625rem;

      &--active {
        border-bottom-color: var(--clr-magenta);
      }
    }
  }
</style>
