---
import { Image } from 'astro:assets';
import BentoCard from './bento-card.astro';
import picture from '../assets/fb.jpg';
---
<BentoCard gridArea="photo" class="photo-card">
  <Image
    src={picture}
    alt="Sebastian Heitmann"
    width={400}
    height={400}
    fit="cover"
    class="photo-card__image"
  />
</BentoCard>

<style lang="scss">
  .photo-card {
    padding: 0;

    :global(.photo-card__image) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 12px;
    }
  }
</style>
