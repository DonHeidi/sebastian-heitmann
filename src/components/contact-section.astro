---
import type { Strings } from '../i18n/types';

type Props = {
    contact: Strings['contact'];
};

const { contact } = Astro.props;
---

<section class="contact" id="contact">
    <div class="contact-inner">
        <div class="contact-left">
            <h2 class="contact-headline" set:html={contact.headline.replace(/\n/g, '<br/>')} />
            <p class="contact-intro">{contact.intro}</p>
        </div>

        <div class="contact-right">
            <form class="contact-form" action="#" method="POST">
                <div class="form-row">
                    <div class="form-field">
                        <label class="form-label" for="name">{contact.nameLabel}</label>
                        <input class="form-input" type="text" id="name" name="name" required autocomplete="name" />
                    </div>
                    <div class="form-field">
                        <label class="form-label" for="email">{contact.emailLabel}</label>
                        <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
                    </div>
                </div>

                <div class="form-field">
                    <label class="form-label" for="context">{contact.contextLabel}</label>
                    <input class="form-input" type="text" id="context" name="context" placeholder={contact.contextPlaceholder} />
                </div>

                <div class="form-field">
                    <label class="form-label" for="message">{contact.messageLabel}</label>
                    <textarea class="form-input form-input--textarea" id="message" name="message" rows="4" required></textarea>
                </div>

                <button class="form-submit" type="submit">
                    <span class="form-submit__text">{contact.submitLabel}</span>
                    <span class="form-submit__arrow">&rarr;</span>
                </button>
            </form>
        </div>
    </div>
</section>

<style lang="scss">
    .contact {
        padding: 120px 80px;
        max-width: 1440px;
        margin: 0 auto;
        border-top: 1px solid var(--v8-border);

        &-inner {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: start;
        }

        &-left {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        &-headline {
            font-family: var(--v8-font-display);
            font-size: clamp(64px, 8vw, 120px);
            font-weight: 400;
            line-height: 0.9;
            color: var(--v8-text);
            letter-spacing: -0.02em;
        }

        &-intro {
            font-family: var(--v8-font-body);
            font-size: 15px;
            font-weight: 300;
            line-height: 1.7;
            color: var(--v8-text-muted);
            max-width: 400px;
        }

        &-form {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
    }

    .form {
        &-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        &-field {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
        }

        &-optional {
            color: var(--v8-text-faint);
        }

        &-input {
            background: transparent;
            border: none;
            border-bottom: 1px solid var(--v8-border);
            color: var(--v8-text);
            font-family: var(--v8-font-body);
            font-size: 15px;
            font-weight: 300;
            padding: 12px 0;
            outline: none;
            transition: border-color 0.2s ease;
            border-radius: 0;

            &::placeholder {
                color: var(--v8-text-faint);
                font-weight: 300;
            }

            &:focus {
                border-bottom-color: var(--v8-accent);
            }

            &--textarea {
                resize: vertical;
                min-height: 100px;
            }

        }

        &-submit {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 16px 0;
            border-bottom: 1px solid var(--v8-accent);
            align-self: flex-start;
            transition: gap 0.3s cubic-bezier(0.22, 1, 0.36, 1);

            &:hover {
                gap: 20px;
            }

            &__text {
                font-family: var(--v8-font-mono);
                font-size: 12px;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--v8-text);
            }

            &__arrow {
                font-size: 16px;
                color: var(--v8-accent);
                transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
            }

            &:hover &__arrow {
                transform: translateX(4px);
            }
        }
    }

    @media (max-width: 1024px) {
        .contact {
            padding: 80px 48px;
            border-top: none;

            &-inner {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            &-headline {
                font-size: clamp(48px, 8vw, 80px);
            }
        }
    }

    @media (max-width: 768px) {
        .contact {
            padding: 60px 24px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>
