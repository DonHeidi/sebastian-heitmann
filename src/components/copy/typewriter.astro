---
type Props = {
    text: string | string[];
    as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'p' | 'span';
}
const { as, text } = Astro.props;
---

{as === 'h1' && <div class="typewriter-container"><h1 class="typewriter-ghost">{text}</h1><h1 data-text={text} class="typewriter"></h1></div>}
{as === 'h2' && <div class="typewriter-container"><h2 class="typewriter-ghost">{text}</h2><h2 data-text={text} class="typewriter"></h2></div>}
{as === 'h3' && <div class="typewriter-container"><h3 class="typewriter-ghost">{text}</h3><h3 data-text={text} class="typewriter"></h3></div>}
{as === 'h4' && <div class="typewriter-container"><h4 class="typewriter-ghost">{text}</h4><h4 data-text={text} class="typewriter"></h4></div>}
{as === 'h5' && <div class="typewriter-container"><h5 class="typewriter-ghost">{text}</h5><h5 data-text={text} class="typewriter"></h5></div>}
{as === 'h6' && <div class="typewriter-container"><h6 class="typewriter-ghost">{text}</h6><h6 data-text={text} class="typewriter"></h6></div>}
{as === 'p' && <div class="typewriter-container"><p class="typewriter-ghost">{text}</p><p data-text={text} class="typewriter"></p></div>}
{as === 'span' && <div class="typewriter-container"><span class="typewriter-ghost">{text}</span><span data-text={text} class="typewriter"></span></div>}

<script>
    const typewriters = document.querySelectorAll('.typewriter');
    
    typewriters.forEach((typewriter) => {
        const textData = (typewriter as HTMLElement).dataset.text;
        if (!textData) return;
        
        const text = textData; // Create a const copy for type safety
        let index = 0;
        let isDeleting = false;
        let isPaused = false;
        
        function updateText() {
            if (isPaused) {
                setTimeout(updateText, isDeleting ? 1000 : 2000);
                isPaused = false;
                return;
            }
            
            if (isDeleting) {
                typewriter.textContent = text.slice(0, index);
                index--;
                
                if (index < 0) {
                    isDeleting = false;
                    isPaused = true;
                }
            } else {
                typewriter.textContent = text.slice(0, index + 1);
                index++;
                
                if (index >= text.length) {
                    isDeleting = true;
                    isPaused = true;
                }
            }
            
            const delay = isDeleting ? 50 : 100;
            setTimeout(updateText, delay);
        }
        
        // Start the animation
        setTimeout(updateText, 1000);
    });
</script>

<style lang="scss">
    .typewriter-container {
        display: grid;
    }

    .typewriter,
    .typewriter-ghost {
        grid-area: 1 / 1;
        font-size: 5rem;
        text-wrap: wrap;
        white-space: pre-wrap;
    }

    .typewriter-ghost {
        color: var(--background-color, #000000); /* Use CSS custom property or fallback to black */
        opacity: 0;
        z-index: 1;
    }

    .typewriter {
        color: inherit;
        z-index: 2;
        position: relative;
    }

    .typewriter::after {
        content: '|';
        font-weight: bold;
        animation: blink 1s infinite;
        margin-left: 2px;
    }

    @keyframes blink {
        0%, 50% {
            opacity: 1;
        }
        51%, 100% {
            opacity: 0;
        }
    }
</style>
