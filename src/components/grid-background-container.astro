---
<div class="grid-background-container">
    <slot />
</div>

<style>
    .grid-background-container {
        --weak-color: rgba(38, 40, 67, 0.4);
        --strong-color: rgba(63, 66, 118, 0.4);
        --cube-size: 12vw;
        width: 100%;
        background-image: 
            linear-gradient(to right, transparent calc(100% - 1px), var(--strong-color) calc(100% - 1px)),
            linear-gradient(to bottom, transparent calc(100% - 1px), var(--strong-color) calc(100% - 1px)),
            linear-gradient(to right, 
                transparent calc(20%),
                var(--weak-color) 20%, 
                var(--weak-color) calc(20% + 1px), 
                transparent calc(20% + 2px), transparent calc(40%),
                var(--weak-color) 40%, 
                var(--weak-color) calc(40% + 1px), 
                transparent calc(40% + 2px), transparent calc(60%),
                var(--weak-color) 60%, 
                var(--weak-color) calc(60% + 1px), 
                transparent calc(60% + 2px), transparent calc(80%),
                var(--weak-color) 80%, 
                var(--weak-color) calc(80% + 1px), 
                transparent calc(80% + 2px), transparent calc(100%)),
            linear-gradient(to bottom, 
                transparent calc(20%),
                var(--weak-color) calc(20%), 
                var(--weak-color) calc(20% + 1px), 
                transparent calc(20% + 2px), transparent calc(40%), 
                var(--weak-color) 40%,
                var(--weak-color) calc(40% + 1px), 
                transparent calc(40% + 2px), transparent calc(60%),
                var(--weak-color) 60%,
                var(--weak-color) calc(60% + 1px), 
                transparent calc(60% + 2px), transparent calc(80%),
                var(--weak-color) 80%,
                var(--weak-color) calc(80% + 1px), 
                transparent calc(80% + 2px), transparent calc(100%));
        background-repeat: repeat, repeat, repeat, repeat;
        background-position: center, center, center, center;
        background-size: var(--cube-size) 100vh, 100vh var(--cube-size), var(--cube-size) 100vh, 100vh var(--cube-size);
    }
</style>
