---
type Props = {
    link?: string;
    type?: 'primary' | 'secondary';
}

const { link, type }: Props = Astro.props;
const isPrimary = type === 'primary';
const isSecondary = type === 'secondary';
---

<a class:list={['cta', { primary: isPrimary, secondary: isSecondary }]} href={link}><slot /></a>

<script>
    const ctas = document.querySelectorAll('.cta');
    ctas.forEach(cta => {
        cta.addEventListener('mousedown', (event) => {
            (cta as HTMLElement).focus();
            console.log('mousedown');
        });
        cta.addEventListener('mouseleave', (event) => {
            (cta as HTMLElement).focus();
            (cta as HTMLElement).blur();
            console.log('mouseleave');
        });
    });

</script>

<style lang="scss">
    :root {
        --cta-color: var(--clr-font-primary);
        --cta-fnt-primary: 'AntonSC', sans-serif;
        --cta-fnt-secondary: 'Anton', sans-serif;
    }

    .cta {
        text-decoration: none;
        text-box-trim: trim-both cap alphabetic;
        -webkit-text-box-trim: trim-both cap alphabetic;
        display: inline-block;
        background-color: transparent;
        color: #fff;
        width: fit-content;
        cursor: pointer;
        font-size: 1.5rem;
        line-height: 1;

        &:focus-visible:not(:hover) {
            outline: 1px solid var(--clr-blue);
        }

        &.primary {
            will-change: transform, box-shadow;
            transition:
                transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 
                inset 1px 1px 2px 0 rgba(101, 108, 161, 0.5),
                -1px -1px 2px 0 rgba(101, 108, 161, 0.5),
                -1px -1px 0 0 rgba(101, 108, 161, 0.5),
                inset -1px -1px 0 0 rgba(0, 0, 0, 0.5),
                1px 1px 0 0 rgba(0, 0, 0, 0.5),
                1px 1px 3px 0 rgba(0, 0, 0, 0.5);
            font-family: var(--cta-fnt-primary);
            font-size: 1.5rem;
            padding: 1rem 3.75rem;
            border-radius: 100vh;
            backdrop-filter: blur(10px);

            &:hover {
                transform: translate(-5px, -5px);
                box-shadow: 
                    inset 1px 1px 2px 0 rgba(101, 108, 161, 0.5),
                    -1px -1px 2px 0 rgba(101, 108, 161, 0.5),
                    -1px -1px 0 0 rgba(101, 108, 161, 0.5),
                    inset -1px -1px 0 0 rgba(0, 0, 0, 0.5),
                    1px 1px 0 0 rgba(0, 0, 0, 0.5),
                    6px 6px 3px 0 rgba(0, 0, 0, 0.5);

            }
                &:focus:hover {
                    transform: translate(0, 0);
                    box-shadow: 
                        inset 1px 1px 2px 0 rgba(101, 108, 161, 0.5),
                        -1px -1px 2px 0 rgba(101, 108, 161, 0.5),
                        -1px -1px 0 0 rgba(101, 108, 161, 0.5),
                }



        }


        &.secondary {
            will-change: transform;
            border-radius: 0;
            text-decoration: underline;
            font-size: 0.875rem;
            font-family: var(--cta-fnt-secondary);
            border: none;
            padding-inline: 0.5rem;
            padding-block: 0.5rem;
            border-top: 1px solid transparent;
            border-bottom: 1px solid transparent;
            border-left: 1px solid transparent;
            border-right: 1px solid transparent;
            background-image: 
                linear-gradient(to right, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to bottom, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to left, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to bottom, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to right, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to top, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to left, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px),
                linear-gradient(to top, transparent 5px, var(--cta-color) 5px, var(--cta-color) 10px, transparent 10px);
            background-position: 
                top left,
                top left,
                top right,
                top right,
                bottom left,
                bottom left,
                bottom right,
                bottom right;
            background-repeat: no-repeat;
            background-size: 
                100% 1px,
                1px 100%,
                100% 1px,
                1px 100%,
                100% 1px,
                1px 100%,
                100% 1px,
                1px 100%;
            font-size: 0.875rem;
            padding: 0.75rem 0.6125rem;
            scale: 1;
            transition:
                scale 0.2s cubic-bezier(0.34, 1.78, 0.64, 1);
            &:after {
                content: ' -->';
            }
            
            &:hover {
                scale: 1.2;
                background-position: 
                    2px 2px,
                    2px 2px,
                    calc(100% - 2px) 2px,
                    calc(100% - 2px) 2px,
                    2px calc(100% - 2px),
                    2px calc(100% - 2px),
                    calc(100% - 2px) calc(100% - 2px),
                    calc(100% - 2px) calc(100% - 2px);
            }
        }
    }



</style>

