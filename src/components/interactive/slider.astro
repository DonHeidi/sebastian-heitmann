---
interface Props {
  backgrounds?: string[]; // Optional array of background styles
}

const { backgrounds = [] } = Astro.props;
---

<div class="slider-container">
  <div class="slider-viewport">
    <slot />
  </div>
</div>

<style>
  .slider-container {
    position: relative;
    height: 100vh;
    width: 100%;
    scroll-snap-align: start;
  }

  .slider-viewport {
    height: 100%;
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  :global(.slide) {
    height: 100%;
    width: 100%;
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.slide:nth-child(1)) { transform: translateY(0); }
  :global(.slide:nth-child(2)) { transform: translateY(100%); }
  :global(.slide:nth-child(3)) { transform: translateY(200%); }
  :global(.slide:nth-child(4)) { transform: translateY(300%); }

  :global(.slide-content) {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
</style>

<script>
  class SlideManager {
    private slides: HTMLElement[];
    private currentSlide: number = 0;
    private isTransitioning: boolean = false;
    private touchStartY: number = 0;
    private isInView: boolean = false;
    private container: HTMLElement;
    private observer: IntersectionObserver = null!;
    private lastMouseY: number = 0;
    private lastScrollY: number = 0;
    private isScrollingFromTop: boolean = false;
    private firstSlideTimeout: number | null = null;

    constructor() {
      this.container = document.querySelector('.slider-container')!;
      this.slides = Array.from(document.querySelectorAll('.slide'));
      this.initializeSlides();
      this.setupIntersectionObserver();
      this.setupEventListeners();
      
      // Add mouse move tracking
      window.addEventListener('mousemove', (e) => {
        this.lastMouseY = e.clientY;
      });

      // Track scroll direction
      window.addEventListener('scroll', () => {
        const currentScrollY = window.scrollY;
        this.isScrollingFromTop = currentScrollY < this.lastScrollY;
        this.lastScrollY = currentScrollY;
      }, { passive: true });
    }

    private setupIntersectionObserver() {
      this.observer = new IntersectionObserver(
        (entries) => {
          const [entry] = entries;
          const wasInView = this.isInView;
          this.isInView = entry.isIntersecting;

          // If entering view from top content, add delay for first slide
          if (!wasInView && this.isInView && !this.isScrollingFromTop) {
            this.firstSlideTimeout = window.setTimeout(() => {
              this.firstSlideTimeout = null;
            }, 1000); // 1 second delay before allowing next slide
          }
        },
        {
          threshold: 0.5
        }
      );

      this.observer.observe(this.container);
    }

    private setupEventListeners() {
      // Wheel event for mouse scroll
      window.addEventListener('wheel', (e) => {
        if (!this.isInView || this.isTransitioning) return;
        
        const rect = this.container.getBoundingClientRect();
        const isMouseOverSlider = 
          e.clientY >= rect.top && 
          e.clientY <= rect.bottom;

        if (!isMouseOverSlider) return;

        // Check if slider is fully in view (allow for 1px difference)
        const isFullyInView = Math.abs(rect.top) <= 1 && 
          Math.abs(rect.bottom - window.innerHeight) <= 1;
        const isFirstSlide = this.currentSlide === 0;
        
        // If first slide isn't fully in view yet, let normal scroll happen
        if (isFirstSlide && !isFullyInView) {
          return;
        }
        
        const isScrollingUp = e.deltaY < 0;
        const isScrollingDown = e.deltaY > 0;
        const isLastSlide = this.currentSlide === this.slides.length - 1;

        // Allow normal scroll behavior at the edges
        if ((isFirstSlide && isScrollingUp) || (isLastSlide && isScrollingDown)) {
          return;
        }

        // Don't trigger next slide if we just entered the first slide from top content
        if (isFirstSlide && isScrollingDown && this.firstSlideTimeout !== null) {
          e.preventDefault();
          return;
        }
        
        // Prevent default scroll for internal slider navigation
        e.preventDefault();
        
        if (isScrollingDown) {
          this.nextSlide();
        } else {
          this.previousSlide();
        }
      }, { passive: false });

      // Add scroll snap behavior when the first slide comes into view
      window.addEventListener('scroll', () => {
        if (this.isInView && this.currentSlide === 0) {
          const rect = this.container.getBoundingClientRect();
          if (rect.top <= 1 && rect.top >= -1) {
            window.scrollTo({
              top: this.container.offsetTop,
              behavior: 'smooth'
            });
          }
        }
      }, { passive: true });

      // Modify scroll event to only prevent scrolling when not at edges
      window.addEventListener('scroll', (e) => {
        if (this.isInView && this.isMouseOverSlider()) {
          const isFirstSlide = this.currentSlide === 0;
          const isLastSlide = this.currentSlide === this.slides.length - 1;
          
          if (!isFirstSlide && !isLastSlide) {
            window.scrollTo(0, this.container.offsetTop);
          }
        }
      });

      // Touch events for mobile swipe
      this.container.addEventListener('touchstart', (e) => {
        if (!this.isInView) return;
        this.touchStartY = e.touches[0].clientY;
      });

      this.container.addEventListener('touchend', (e) => {
        if (!this.isInView || this.isTransitioning) return;
        
        const touchEndY = e.changedTouches[0].clientY;
        const deltaY = this.touchStartY - touchEndY;

        if (Math.abs(deltaY) > 50) { // Minimum swipe distance
          if (deltaY > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
        }
      });
    }

    private isMouseOverSlider(): boolean {
      const rect = this.container.getBoundingClientRect();
      return (
        this.lastMouseY >= rect.top && 
        this.lastMouseY <= rect.bottom
      );
    }

    private initializeSlides() {
      this.slides.forEach((slide, index) => {
        slide.style.transform = `translateY(${index * 100}%)`;
      });
    }

    private nextSlide() {
      if (this.currentSlide >= this.slides.length - 1) return;
      
      this.isTransitioning = true;
      this.currentSlide++;
      // Clear first slide timeout when manually navigating
      if (this.firstSlideTimeout !== null) {
        clearTimeout(this.firstSlideTimeout);
        this.firstSlideTimeout = null;
      }
      this.updateSlides();
    }

    private previousSlide() {
      if (this.currentSlide <= 0) return;
      
      this.isTransitioning = true;
      this.currentSlide--;
      // Clear first slide timeout when manually navigating
      if (this.firstSlideTimeout !== null) {
        clearTimeout(this.firstSlideTimeout);
        this.firstSlideTimeout = null;
      }
      this.updateSlides();
    }

    private updateSlides() {
      // Lock scroll position while transitioning
      const scrollTop = window.scrollY;
      
      this.slides.forEach((slide, index) => {
        const offset = index - this.currentSlide;
        slide.style.transform = `translateY(${offset * 100}%)`;
      });

      // Ensure scroll position stays the same
      window.scrollTo(0, scrollTop);

      setTimeout(() => {
        this.isTransitioning = false;
      }, 500);
    }
  }

  // Initialize the slider when the DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new SlideManager();
  });
</script>
