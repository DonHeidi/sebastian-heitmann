---
import type { Strings } from '../i18n/types';

type Props = {
    logos: Strings['logos'];
};

const { logos } = Astro.props;
---

<section class="logos">
    <div class="logos-inner">
        <div class="logos-group">
            <span class="logos-label">{logos.workingWithLabel}</span>
            <div class="logos-names">
                {logos.workingWith.map(name => (
                    <span class="logos-name">{name}</span>
                ))}
            </div>
        </div>
        <div class="logos-divider"></div>
        <div class="logos-group">
            <span class="logos-label">{logos.previouslyAtLabel}</span>
            <div class="logos-names">
                {logos.previouslyAt.map(name => (
                    <span class="logos-name">{name}</span>
                ))}
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .logos {
        padding: 0 80px;
        max-width: 1440px;
        margin: 0 auto;

        &-inner {
            display: flex;
            align-items: center;
            gap: 48px;
            padding: 28px 0;
            border-top: 1px solid var(--v8-border);
            border-bottom: 1px solid var(--v8-border);
        }

        &-group {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        &-label {
            font-family: var(--v8-font-mono);
            font-size: 10px;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--v8-text-muted);
            flex-shrink: 0;
            white-space: nowrap;
        }

        &-names {
            display: flex;
            align-items: center;
            gap: 32px;
        }

        &-name {
            font-family: var(--v8-font-display);
            font-size: 18px;
            color: var(--v8-text);
            opacity: 0.35;
            white-space: nowrap;
            transition: opacity 0.2s ease;

            &:hover {
                opacity: 0.6;
            }
        }

        &-divider {
            width: 1px;
            height: 24px;
            background: var(--v8-border);
            flex-shrink: 0;
        }
    }

    @media (max-width: 1024px) {
        .logos {
            padding: 0 48px;

            &-inner {
                gap: 32px;
            }

            &-names {
                gap: 24px;
            }
        }
    }

    @media (max-width: 768px) {
        .logos {
            padding: 0 24px;

            &-inner {
                flex-direction: column;
                align-items: flex-start;
                gap: 20px;
                padding: 24px 0;
            }

            &-group {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            &-names {
                flex-wrap: wrap;
                gap: 16px 24px;
            }

            &-divider {
                width: 100%;
                height: 1px;
            }
        }
    }
</style>
