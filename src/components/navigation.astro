---
import type { Strings } from '../i18n/types';
import { locales, localeConfig, type Locale } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

type Props = {
    nav?: Strings['nav'];
    languagePicker?: Strings['languagePicker'];
};

const { nav: navProp, languagePicker } = Astro.props;
const nav = navProp ?? { logo: 'sebastian-heitmann', logoDot: '.dev', cta: 'Book a Call' };
const currentLocale = (Astro.currentLocale ?? 'en-us') as Locale;
const currentConfig = localeConfig[currentLocale];
const shortLabel = currentLocale.toUpperCase();
---

<nav class="nav">
    <a class="nav-logo" href="/">{nav.logo}<span class="nav-logo__dot">.</span>dev</a>
    <div class="nav-actions">
        <div class="nav-lang" aria-label={languagePicker?.label ?? 'Language'}>
            <button class="nav-lang__trigger" type="button" aria-expanded="false" aria-haspopup="true">
                <span class="nav-lang__flag">{currentConfig.flag}</span>
                <span class="nav-lang__label">{shortLabel}</span>
                <svg class="nav-lang__chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </button>
            <div class="nav-lang__dropdown">
                {locales.map((loc) => (
                    <a
                        class="nav-lang__option"
                        href={getRelativeLocaleUrl(loc, '/')}
                        data-locale={loc}
                        data-current={loc === currentLocale ? 'true' : undefined}
                        aria-current={loc === currentLocale ? 'true' : undefined}
                    >
                        <span class="nav-lang__option-flag">{localeConfig[loc].flag}</span>
                        <span class="nav-lang__option-label">{localeConfig[loc].label}</span>
                    </a>
                ))}
            </div>
        </div>
        <div class="nav-theme-toggle" role="radiogroup" aria-label="Theme">
            <button class="nav-theme-toggle__btn" type="button" data-theme="system" aria-label="System theme">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                    <line x1="8" y1="21" x2="16" y2="21"></line>
                    <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
            </button>
            <button class="nav-theme-toggle__btn" type="button" data-theme="light" aria-label="Light theme">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"></circle>
                    <line x1="12" y1="1" x2="12" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="23"></line>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                    <line x1="1" y1="12" x2="3" y2="12"></line>
                    <line x1="21" y1="12" x2="23" y2="12"></line>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
            </button>
            <button class="nav-theme-toggle__btn" type="button" data-theme="dark" aria-label="Dark theme">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
            </button>
        </div>
        <a class="nav-cta" href="#contact">{nav.cta}</a>
    </div>
</nav>

<script>
    function applyTheme(preference: string) {
        const html = document.documentElement;
        html.classList.remove('dark', 'light');
        if (preference === 'dark' || preference === 'light') {
            html.classList.add(preference);
        } else {
            // system
            const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            html.classList.add(systemDark ? 'dark' : 'light');
        }
    }

    function updateActiveBtn(preference: string) {
        document.querySelectorAll('.nav-theme-toggle__btn').forEach(btn => {
            const isActive = (btn as HTMLElement).dataset.theme === preference;
            btn.classList.toggle('nav-theme-toggle__btn--active', isActive);
        });
    }

    // Set initial active state
    const stored = localStorage.getItem('theme') || 'system';
    updateActiveBtn(stored);

    // Handle clicks
    document.querySelectorAll('.nav-theme-toggle__btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const preference = (btn as HTMLElement).dataset.theme!;
            localStorage.setItem('theme', preference);
            applyTheme(preference);
            updateActiveBtn(preference);
        });
    });

    // Listen for OS theme changes when in system mode
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        const current = localStorage.getItem('theme') || 'system';
        if (current === 'system') {
            applyTheme('system');
        }
    });
</script>

<script>
    const trigger = document.querySelector('.nav-lang__trigger') as HTMLButtonElement;
    const dropdown = document.querySelector('.nav-lang__dropdown') as HTMLElement;

    function toggleDropdown(open?: boolean) {
        const isOpen = open ?? !dropdown.classList.contains('nav-lang__dropdown--open');
        dropdown.classList.toggle('nav-lang__dropdown--open', isOpen);
        trigger.setAttribute('aria-expanded', String(isOpen));
    }

    trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleDropdown();
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
        if (!(e.target as Element).closest('.nav-lang')) {
            toggleDropdown(false);
        }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            toggleDropdown(false);
        }
    });

    // Store locale on option click
    document.querySelectorAll('.nav-lang__option').forEach(option => {
        option.addEventListener('click', () => {
            const locale = (option as HTMLElement).dataset.locale;
            if (locale) {
                localStorage.setItem('locale', locale);
            }
        });
    });
</script>

<style lang="scss">
    .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 80px;
        max-width: 1440px;
        margin: 0 auto;

        &-logo {
            font-family: var(--v8-font-mono);
            font-size: 13px;
            letter-spacing: 0.02em;
            color: var(--v8-text-muted);
            text-decoration: none;
            transition: color 0.2s ease;

            &:hover {
                color: var(--v8-text);
            }

            &__dot {
                color: var(--v8-accent);
            }
        }

        &-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        &-lang {
            position: relative;

            &__trigger {
                display: flex;
                align-items: center;
                gap: 6px;
                background: none;
                border: 1px solid var(--v8-border);
                color: var(--v8-text-muted);
                cursor: pointer;
                padding: 6px 10px;
                font-family: var(--v8-font-mono);
                font-size: 11px;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                transition: color 0.2s ease, border-color 0.2s ease;

                &:hover {
                    color: var(--v8-accent);
                    border-color: var(--v8-accent);
                }
            }

            &__flag {
                font-size: 14px;
                line-height: 1;
            }

            &__label {
                line-height: 1;
            }

            &__chevron {
                transition: transform 0.2s ease;
            }

            &__dropdown {
                position: absolute;
                top: calc(100% + 6px);
                right: 0;
                min-width: 160px;
                background: var(--v8-bg-surface);
                border: 1px solid var(--v8-border);
                display: none;
                flex-direction: column;
                z-index: 100;

                &--open {
                    display: flex;
                }
            }

            &__option {
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 8px 12px;
                font-family: var(--v8-font-mono);
                font-size: 11px;
                letter-spacing: 0.04em;
                color: var(--v8-text-muted);
                text-decoration: none;
                transition: color 0.2s ease, background-color 0.2s ease;

                &:not(:last-child) {
                    border-bottom: 1px solid var(--v8-border);
                }

                &:hover {
                    color: var(--v8-accent);
                    background: rgba(255, 255, 255, 0.03);
                }

                &[data-current] {
                    color: var(--v8-accent);
                }

                &-flag {
                    font-size: 14px;
                    line-height: 1;
                }

                &-label {
                    line-height: 1;
                }
            }

            // Rotate chevron when open
            &:has(&__dropdown--open) &__chevron {
                transform: rotate(180deg);
            }
        }

        &-theme-toggle {
            display: flex;
            border: 1px solid var(--v8-border);

            &__btn {
                background: none;
                border: none;
                color: var(--v8-text-muted);
                cursor: pointer;
                padding: 6px 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: color 0.2s ease, background-color 0.2s ease;

                &:not(:last-child) {
                    border-right: 1px solid var(--v8-border);
                }

                &:hover {
                    color: var(--v8-accent);
                }

                &--active {
                    color: var(--v8-accent);
                    background: var(--v8-bg-surface);
                }
            }
        }

        &-cta {
            font-family: var(--v8-font-mono);
            font-size: 12px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--v8-text);
            text-decoration: none;
            padding: 10px 24px;
            border: 1px solid var(--v8-border);
            transition: border-color 0.2s ease, color 0.2s ease;

            &:hover {
                border-color: var(--v8-accent);
                color: var(--v8-accent);
            }
        }
    }

    @media (max-width: 768px) {
        .nav {
            padding: 20px 24px;
        }
    }
</style>
