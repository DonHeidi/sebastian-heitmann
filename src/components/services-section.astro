---
import Typewriter from './copy/typewriter.astro';
---

<section class="services reveal" id="services">
    <div class="services__header">
        <p class="services__overline">
            <span class="services__overline-plain">What I </span><span class="services__overline-accent">offer</span>
        </p>
        <h2 class="services__headline">How I Help</h2>
        <p class="services__description">From early-stage product discovery to scaling engineering organisations — I provide hands-on technical leadership tailored to where your business is today and where it needs to go.</p>
    </div>

    <!-- Single pane, three sections divided by lines -->
    <div class="services__pane stagger stagger-1">
        <div class="services__section">
            <div class="services__section-header">
                <span class="services__section-number services__section-number--terracotta">01</span>
                <h3 class="services__section-title">Strategy & Advisory</h3>
            </div>
            <p class="services__section-description">For founders and leadership teams who need technical clarity before committing to a direction.</p>
            <ul class="services__section-bullets">
                <li style="--accent: var(--clr-terracotta);">Technical due diligence</li>
                <li style="--accent: var(--clr-terracotta);">Architecture assessment</li>
                <li style="--accent: var(--clr-terracotta);">Build vs. buy analysis</li>
                <li style="--accent: var(--clr-terracotta);">Product roadmap review</li>
            </ul>
            <p class="services__section-ideal">Ideal for: Pre-investment, pivot decisions, scaling planning</p>
        </div>

        <hr class="services__divider" />

        <div class="services__section">
            <div class="services__section-header">
                <span class="services__section-number services__section-number--teal">02</span>
                <h3 class="services__section-title">Product & Engineering</h3>
            </div>
            <p class="services__section-description">For teams that need hands-on product leadership and engineering execution.</p>
            <ul class="services__section-bullets">
                <li style="--accent: var(--clr-teal);">Full-stack development</li>
                <li style="--accent: var(--clr-teal);">Team setup & mentoring</li>
                <li style="--accent: var(--clr-teal);">Sprint planning & delivery</li>
                <li style="--accent: var(--clr-teal);">CI/CD & DevOps</li>
            </ul>
            <p class="services__section-ideal">Ideal for: MVPs, rebuilds, team augmentation</p>
        </div>

        <hr class="services__divider" />

        <div class="services__section">
            <div class="services__section-header">
                <span class="services__section-number services__section-number--sage">03</span>
                <h3 class="services__section-title">Operations & Scale</h3>
            </div>
            <p class="services__section-description">For growing companies that need structure, process, and technical operations at scale.</p>
            <ul class="services__section-bullets">
                <li style="--accent: var(--clr-sage);">Engineering process design</li>
                <li style="--accent: var(--clr-sage);">Hiring & onboarding</li>
                <li style="--accent: var(--clr-sage);">Performance monitoring</li>
                <li style="--accent: var(--clr-sage);">Incident management</li>
            </ul>
            <p class="services__section-ideal">Ideal for: Series A+, scaling teams, post-launch</p>
        </div>
    </div>

    <!-- Engagement Models — 3 tiers, horizontal strips instead of equal cards -->
    <div class="services__plans-header stagger stagger-1">
        <h3 class="services__plans-headline">Engagement Models</h3>
    </div>

    <div class="services__plans">
        <div class="services__plan stagger stagger-1">
            <div class="services__plan-left">
                <h4 class="services__plan-title">Hourly Based Consulting</h4>
                <p class="services__plan-desc">Strategy sessions, architecture reviews, team mentoring, and code review oversight.</p>
            </div>
            <div class="services__plan-price-row">
                <span class="services__plan-price">$130</span>
                <span class="services__plan-price-unit">/hour</span>
            </div>
        </div>

        <div class="services__plan services__plan--highlighted stagger stagger-2">
            <div class="services__plan-left">
                <h4 class="services__plan-title">Fixed Prototype Iterations</h4>
                <p class="services__plan-desc">Hands-on product development, sprint planning & delivery, async support, and performance tracking.</p>
            </div>
            <div class="services__plan-price-row">
                <span class="services__plan-price">$4,999</span>
                <span class="services__plan-price-unit">/iteration</span>
            </div>
        </div>

        <div class="services__plan stagger stagger-3">
            <div class="services__plan-left">
                <h4 class="services__plan-title">Monthly CTO Retainer</h4>
                <p class="services__plan-desc">Dedicated CTO, board & stakeholder reporting, security & compliance oversight, custom integrations.</p>
            </div>
            <div class="services__plan-price-row">
                <span class="services__plan-price">$2,499</span>
                <span class="services__plan-price-unit">/month</span>
            </div>
        </div>
    </div>

    <div class="services__deco">
        <p class="services__deco-line services__deco-line--1">
            <span class="services__deco-plain">THE&nbsp;</span><span class="services__deco-accent">RIGHT PLAN</span><span class="services__deco-plain">&nbsp;FOR</span>
        </p>
        <p class="services__deco-line services__deco-line--2">
            <span class="services__deco-plain">YOUR BUSINESS</span>
        </p>
    </div>

    <div class="services__cta">
        <p class="services__cta-text">Not sure which fits? Let's talk.</p>
        <a class="services__cta-button" href="#contact">Book a Discovery Call</a>
    </div>
</section>

<style lang="scss">
    .services {
        display: flex;
        flex-direction: column;
        padding: 80px 144px 64px;

        &__header {
            max-width: 560px;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 3rem;
        }

        &__overline {
            font-family: 'Outfit', sans-serif;
            font-size: 24px;
            font-weight: 500;
            color: var(--clr-text-primary);
        }

        &__overline-plain {
            color: var(--clr-text-primary);
        }

        &__overline-accent {
            font-weight: 700;
            color: var(--clr-teal);
        }

        &__headline {
            font-family: 'Anton', sans-serif;
            font-size: 6rem;
            color: var(--clr-text-primary);
            letter-spacing: -2px;
            line-height: 0.95;
        }

        &__description {
            font-family: 'Outfit', sans-serif;
            font-size: 1.4375rem;
            color: rgba(232, 226, 214, 0.7);
            line-height: 1.6;
            max-width: 500px;
        }

        /* Single pane with three sections */
        &__pane {
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-dark);
            border-radius: 12px;
            padding: 0;
        }

        &__section {
            padding: 36px 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-template-rows: auto auto auto;
            column-gap: 2.5rem;
            row-gap: 0.5rem;
        }

        &__section-header {
            grid-column: 1 / -1;
            display: flex;
            flex-direction: row;
            align-items: baseline;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }

        &__section-number {
            font-family: 'Anton', sans-serif;
            font-size: 1.25rem;
            line-height: 1;

            &--terracotta { color: var(--clr-terracotta); }
            &--teal { color: var(--clr-teal); }
            &--sage { color: var(--clr-sage); }
        }

        &__section-title {
            font-family: 'Anton', sans-serif;
            font-size: 2rem;
            color: var(--clr-white);
            letter-spacing: -0.5px;
            line-height: 1.1;
        }

        &__section-description {
            font-family: 'Outfit', sans-serif;
            font-size: 1.3125rem;
            color: rgba(232, 226, 214, 0.7);
            line-height: 1.6;
            grid-column: 1;
        }

        &__section-bullets {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            grid-column: 2;
            grid-row: 2 / 4;
            align-self: center;

            li {
                font-family: 'Outfit', sans-serif;
                font-size: 1.25rem;
                color: rgba(232, 226, 214, 0.65);
                padding-left: 1rem;
                position: relative;

                &::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 5px;
                    height: 5px;
                    border-radius: 50%;
                    background: var(--accent);
                }
            }
        }

        &__section-ideal {
            font-family: 'Outfit', sans-serif;
            font-size: 1.0625rem;
            font-style: italic;
            color: rgba(232, 226, 214, 0.45);
            grid-column: 1;
        }

        &__divider {
            border: none;
            border-top: 1px solid var(--clr-border-dark);
            margin: 0 40px;
        }

        /* Engagement Models — horizontal strips */
        &__plans-header {
            margin-top: 80px;
            text-align: center;
        }

        &__plans-headline {
            font-family: 'Anton', sans-serif;
            font-size: 4rem;
            color: var(--clr-white);
            letter-spacing: -1.5px;
            line-height: 1;
        }

        &__plans {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
            margin-top: 40px;
        }

        &__plan {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-dark);
            border-radius: 12px;
            padding: 28px 36px;
            transition: border-color 0.3s ease;

            &:hover {
                border-color: rgba(232, 226, 214, 0.12);
            }

            &--highlighted {
                border-left: 3px solid var(--clr-terracotta);
                padding-left: 33px;
            }
        }

        &__plan-left {
            display: flex;
            flex-direction: column;
            gap: 6px;
            flex: 1;
        }

        &__plan-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.5rem;
            color: var(--clr-white);
            line-height: 1.1;
        }

        &__plan-desc {
            font-family: 'Outfit', sans-serif;
            font-size: 1.1875rem;
            color: rgba(232, 226, 214, 0.55);
            line-height: 1.5;
        }

        &__plan-price-row {
            display: flex;
            flex-direction: row;
            align-items: baseline;
            gap: 4px;
            flex-shrink: 0;
        }

        &__plan-price {
            font-family: 'Anton', sans-serif;
            font-size: 2.75rem;
            color: var(--clr-white);
            line-height: 1;
        }

        &__plan-price-unit {
            font-family: 'Outfit', sans-serif;
            font-size: 1.25rem;
            color: rgba(232, 226, 214, 0.45);
        }

        &__deco {
            margin-top: 32px;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 0;
            user-select: none;
        }

        &__deco-line {
            font-family: 'AntonSC', sans-serif;
            line-height: 1;
            letter-spacing: 3px;
        }

        &__deco-line--1 {
            font-size: clamp(3rem, 6vw, 5.5rem);
        }

        &__deco-line--2 {
            font-size: clamp(2.5rem, 5vw, 4.5rem);
        }

        &__deco-plain {
            color: rgba(232, 226, 214, 0.15);
        }

        &__deco-accent {
            color: rgba(196, 93, 62, 0.35);
        }

        &__cta {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            margin-top: 16px;
        }

        &__cta-text {
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            color: var(--clr-text-muted);
        }

        &__cta-button {
            text-decoration: none;
            font-family: 'Anton', sans-serif;
            font-size: 1.125rem;
            line-height: 1;
            color: var(--clr-white);
            background-color: var(--clr-bg-surface);
            border: 1.5px solid var(--clr-text-primary);
            border-radius: 100vh;
            padding: 1rem 2.5rem;
            transition:
                background-color 0.2s ease,
                border-color 0.2s ease;

            &:hover {
                background-color: var(--clr-text-primary);
                color: #151310;
            }
        }
    }

    @media (max-width: 1440px) {
        .services {
            padding: 80px 80px 64px;
        }
    }

    @media (max-width: 768px) {
        .services {
            padding: 64px 2rem 48px;

            &__header {
                max-width: 100%;
            }

            &__headline {
                font-size: 4rem;
            }

            &__section {
                grid-template-columns: 1fr;
            }

            &__section-bullets {
                grid-column: 1;
                grid-row: auto;
            }

            &__plans-headline {
                font-size: 3rem;
            }

            &__plan {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
        }
    }

    @media (max-width: 375px) {
        .services {
            padding: 64px 1.25rem 48px;
        }
    }
</style>
