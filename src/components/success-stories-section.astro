---
---

<section class="success-stories reveal" id="work">
    <p class="success-stories__vertical-text">SUCCESS STORY</p>

    <div class="success-stories__content">
        <div class="success-stories__cards">
            <div class="success-stories__card stagger stagger-1" style="flex: 0 0 400px;">
                <div class="success-stories__card-image success-stories__card-image--magenta"></div>
                <span class="success-stories__card-metric success-stories__card-metric--magenta">40% cost reduction</span>
                <h3 class="success-stories__card-title">SAAS PLATFORM REBUILD</h3>
                <p class="success-stories__card-desc">Architecture overhaul of a multi-tenant SaaS platform serving 200+ enterprise clients. Migrated from monolithic PHP to distributed Node.js, tripling throughput.</p>
                <div class="success-stories__card-footer">
                    <span class="success-stories__card-tag success-stories__card-tag--magenta">Architecture</span>
                </div>
            </div>

            <div class="success-stories__card stagger stagger-2" style="flex: 0 0 340px;">
                <span class="success-stories__card-metric success-stories__card-metric--blue">12-person team</span>
                <h3 class="success-stories__card-title">SCALE-UP TEAM BUILDING</h3>
                <p class="success-stories__card-desc">Built an engineering team from scratch. Established hiring pipelines, onboarding, and code review culture that cut deploy time from weeks to hours.</p>
                <div class="success-stories__card-footer">
                    <span class="success-stories__card-tag success-stories__card-tag--blue">Leadership</span>
                </div>
            </div>

            <div class="success-stories__card stagger stagger-3" style="flex: 0 0 380px;">
                <div class="success-stories__card-image success-stories__card-image--green"></div>
                <span class="success-stories__card-metric success-stories__card-metric--green">99.99% uptime</span>
                <h3 class="success-stories__card-title">CLOUD MIGRATION</h3>
                <p class="success-stories__card-desc">Migrated a legacy monolith to cloud-native microservices on AWS — zero downtime, 5M records preserved, 60% infrastructure cost reduction.</p>
                <div class="success-stories__card-footer">
                    <span class="success-stories__card-tag success-stories__card-tag--green">Infrastructure</span>
                </div>
            </div>

            <div class="success-stories__card stagger stagger-4" style="flex: 0 0 320px;">
                <span class="success-stories__card-metric success-stories__card-metric--gold">3x conversions</span>
                <h3 class="success-stories__card-title">E-COMMERCE RELAUNCH</h3>
                <p class="success-stories__card-desc">Rebuilt a failing e-commerce platform end-to-end, delivering 3x conversion rate improvement and 60% faster page loads.</p>
                <div class="success-stories__card-footer">
                    <span class="success-stories__card-tag success-stories__card-tag--gold">Product Dev</span>
                </div>
            </div>
        </div>

        <div class="success-stories__cta-row">
            <a class="success-stories__cta" href="#contact">BOOK A CALL</a>
        </div>
    </div>
</section>

<style lang="scss">
    .success-stories {
        position: relative;
        padding: 80px 0 48px 144px;
        display: flex;
        flex-direction: row;
        align-items: stretch;
        gap: 0;
        overflow: visible;

        &__vertical-text {
            position: absolute;
            left: 10px;
            top: 48px;
            font-family: 'Anton', sans-serif;
            font-size: 8rem;
            color: #F5F0E8;
            opacity: 0.12;
            letter-spacing: 6px;
            writing-mode: vertical-lr;
            transform: rotate(180deg);
            line-height: 1;
            white-space: nowrap;
            pointer-events: none;
            user-select: none;
            max-height: calc(100% - 96px);
        }

        &__content {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 48px;
            min-width: 0;
        }

        &__cards {
            display: flex;
            flex-direction: row;
            gap: 20px;
            align-items: flex-end;
            overflow-x: auto;
            padding-bottom: 16px;
            padding-right: 48px;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;

            /* Subtle scrollbar */
            &::-webkit-scrollbar {
                height: 4px;
            }
            &::-webkit-scrollbar-track {
                background: rgba(255, 255, 255, 0.04);
                border-radius: 2px;
            }
            &::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.12);
                border-radius: 2px;
            }
        }

        &__card {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 16px;
            border-radius: 12px;
            background: rgba(30, 27, 22, 0.95);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 28px 24px;
        }

        &__card-image {
            width: 100%;
            height: 140px;
            border-radius: 8px;
            flex-shrink: 0;

            &--magenta {
                background: linear-gradient(135deg, rgba(255, 0, 123, 0.15), rgba(22, 20, 16, 1) 70%);
            }

            &--blue {
                background: linear-gradient(135deg, rgba(0, 183, 255, 0.15), rgba(22, 20, 16, 1) 70%);
            }

            &--green {
                background: linear-gradient(135deg, rgba(0, 224, 142, 0.15), rgba(22, 20, 16, 1) 70%);
            }
        }

        &__card-metric {
            font-family: 'Anton', sans-serif;
            font-size: 2rem;
            line-height: 1;
            letter-spacing: -0.5px;

            &--magenta { color: var(--clr-magenta); }
            &--blue { color: var(--clr-blue); }
            &--green { color: var(--clr-green); }
            &--gold { color: var(--clr-gold); }
        }

        &__card-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--clr-white);
            text-transform: uppercase;
            line-height: 1.1;
            letter-spacing: 0.5px;
        }

        &__card-desc {
            font-family: 'Outfit', sans-serif;
            font-size: 1.0625rem;
            color: rgba(255, 255, 255, 0.65);
            line-height: 1.6;
        }

        &__card-footer {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-top: auto;
        }

        &__card-tag {
            font-family: 'Outfit', sans-serif;
            font-size: 12px;
            font-weight: 500;
            padding: 4px 12px;
            border-radius: 100vh;

            &--magenta {
                background: rgba(255, 0, 123, 0.12);
                color: var(--clr-magenta);
            }

            &--blue {
                background: rgba(0, 183, 255, 0.12);
                color: var(--clr-blue);
            }

            &--green {
                background: rgba(0, 224, 142, 0.12);
                color: var(--clr-green);
            }

            &--gold {
                background: rgba(255, 184, 0, 0.12);
                color: var(--clr-gold);
            }
        }

        &__card-link {
            font-family: 'Outfit', sans-serif;
            font-size: 12px;
            color: var(--clr-blue);
            text-decoration: none;
            transition: opacity 0.2s ease;
            flex-shrink: 0;

            &:hover {
                opacity: 0.7;
            }
        }

        &__cta-row {
            display: flex;
            justify-content: center;
            padding-right: 144px;
        }

        &__cta {
            display: inline-block;
            text-decoration: none;
            font-family: 'Anton', sans-serif;
            font-size: 1.125rem;
            color: var(--clr-white);
            background: #1c1814;
            border: 1px solid rgba(255, 255, 255, 0.19);
            border-radius: 100vh;
            padding: 16px 48px;
            transition:
                background-color 0.2s ease,
                border-color 0.2s ease;

            &:hover {
                background: rgba(255, 255, 255, 0.1);
                border-color: rgba(255, 255, 255, 0.3);
            }
        }
    }

    @media (max-width: 1440px) {
        .success-stories {
            padding: 64px 0 40px 80px;

            &__cta-row {
                padding-right: 80px;
            }
        }
    }

    @media (max-width: 768px) {
        .success-stories {
            padding: 64px 2rem;

            &__vertical-text {
                display: none;
            }

            &__cards {
                flex-direction: column;
                align-items: stretch;
                overflow-x: visible;
                padding-right: 0;
            }

            &__card {
                flex: none !important;
                width: 100%;
            }

            &__cta-row {
                padding-right: 0;
            }
        }
    }

    @media (max-width: 375px) {
        .success-stories {
            padding: 64px 1.25rem;

            &__cta-row {
                padding-right: 0;
            }
        }
    }
</style>
