---
---

<section class="bento" id="more-about-me">
    <h2 class="bento__title">More About Me</h2>

    <div class="bento__grid">
        <!-- Row 1: Current Occupation (full width) -->
        <div class="bento__card bento__card--occupation">
            <div class="bento__occupation-left">
                <div class="bento__occupation-top">
                    <h3 class="bento__occupation-heading">CURRENT OCCUPATION</h3>
                    <span class="bento__badge bento__badge--magenta">Freelancer</span>
                </div>
                <p class="bento__occupation-desc">
                    Product-obsessed full-stack engineering and team leadership.
                </p>
                <div class="bento__tags">
                    <span class="bento__tag bento__tag--magenta">Software +</span>
                    <span class="bento__tag bento__tag--magenta">Career</span>
                </div>
            </div>
            <div class="bento__occupation-image" aria-hidden="true"></div>
        </div>

        <!-- Row 2: Two columns -->
        <div class="bento__row2">
            <!-- Left column -->
            <div class="bento__col-left">
                <!-- Former Career Card -->
                <div class="bento__card bento__card--career">
                    <h3 class="bento__card-title">FORMER CAREER</h3>
                    <div class="bento__career-entry">
                        <p class="bento__career-meta">10 years with Accenture</p>
                        <p class="bento__career-role">TECHNICAL CONSULTANT</p>
                        <p class="bento__career-desc">
                            Delivered large-scale enterprise transformations, system integrations, and digital strategy across global clients in finance, telco, and manufacturing.
                        </p>
                    </div>
                    <p class="bento__subheading">Projects, Tasks, and Tools</p>
                    <div class="bento__tags">
                        <span class="bento__tag bento__tag--magenta">Enterprise</span>
                        <span class="bento__tag bento__tag--blue">Integration</span>
                        <span class="bento__tag bento__tag--green">Java</span>
                        <span class="bento__tag bento__tag--magenta">SAP</span>
                        <span class="bento__tag bento__tag--blue">Architecture</span>
                        <span class="bento__tag bento__tag--green">Strategy</span>
                    </div>
                </div>

                <!-- Skills Card -->
                <div class="bento__card bento__card--skills">
                    <h3 class="bento__card-title">Skills</h3>
                    <div class="bento__skills-grid">
                        <div class="bento__tags">
                            <span class="bento__tag bento__tag--magenta">TypeScript</span>
                            <span class="bento__tag bento__tag--blue">React/Next.js</span>
                            <span class="bento__tag bento__tag--green">Frontend/Design</span>
                            <span class="bento__tag bento__tag--magenta">Python</span>
                        </div>
                        <div class="bento__tags">
                            <span class="bento__tag bento__tag--blue">Tailwind</span>
                            <span class="bento__tag bento__tag--green">Node.js</span>
                            <span class="bento__tag bento__tag--magenta">AWS</span>
                            <span class="bento__tag bento__tag--blue">AI/LLMs</span>
                        </div>
                        <div class="bento__tags">
                            <span class="bento__tag bento__tag--green">Google Cloud</span>
                            <span class="bento__tag bento__tag--magenta">Docker/K8s</span>
                            <span class="bento__tag bento__tag--blue">Terraform</span>
                        </div>
                        <div class="bento__tags">
                            <span class="bento__tag bento__tag--filled-magenta">UI/UX</span>
                            <span class="bento__tag bento__tag--filled-blue">Product</span>
                            <span class="bento__tag bento__tag--filled-green">Agile</span>
                            <span class="bento__tag bento__tag--filled-magenta">DevOps</span>
                            <span class="bento__tag bento__tag--filled-blue">CI/CD</span>
                        </div>
                        <div class="bento__tags">
                            <span class="bento__tag bento__tag--green">REST</span>
                            <span class="bento__tag bento__tag--magenta">GraphQL</span>
                            <span class="bento__tag bento__tag--blue">SQL</span>
                            <span class="bento__tag bento__tag--green">NoSQL</span>
                            <span class="bento__tag bento__tag--magenta">Redis</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right column: Voluntary Card -->
            <div class="bento__card bento__card--voluntary">
                <h3 class="bento__voluntary-title">Voluntary</h3>
                <div class="bento__voluntary-entries">
                    <div class="bento__voluntary-entry">
                        <p class="bento__voluntary-meta">2021 - present</p>
                        <p class="bento__voluntary-role">MEMBER OF THE ADVISORY BOARD</p>
                        <p class="bento__voluntary-desc">Advising on strategic product and technology decisions for an early-stage startup in the climate-tech space.</p>
                    </div>
                    <div class="bento__voluntary-entry">
                        <p class="bento__voluntary-meta">2020 - present</p>
                        <p class="bento__voluntary-role">FELLOW SOFTWARE DEVELOPMENT</p>
                        <p class="bento__voluntary-desc">Mentoring and teaching aspiring software developers through structured program curriculum.</p>
                    </div>
                    <div class="bento__voluntary-entry">
                        <p class="bento__voluntary-meta">2018 - 2021</p>
                        <p class="bento__voluntary-role">HEAD OF QUALITY &amp; INNOVATION MANAGEMENT</p>
                        <p class="bento__voluntary-desc">Led quality processes and innovation initiatives across the organization.</p>
                    </div>
                    <div class="bento__voluntary-entry">
                        <p class="bento__voluntary-meta">2016 - 2018</p>
                        <p class="bento__voluntary-role">CHAIRMAN OF THE BOARD</p>
                        <p class="bento__voluntary-desc">Chaired the board, driving governance and long-term strategic direction.</p>
                    </div>
                    <hr class="bento__voluntary-separator" />
                    <div class="bento__voluntary-entry">
                        <p class="bento__voluntary-meta">2014 - 2016</p>
                        <p class="bento__voluntary-role">HEAD OF ACQUISITION &amp; PROJECT MANAGEMENT</p>
                        <p class="bento__voluntary-desc">Led business development efforts and managed incoming project pipeline.</p>
                    </div>
                    <div class="bento__voluntary-entry">
                        <p class="bento__voluntary-meta">2012 - 2013</p>
                        <p class="bento__voluntary-role">VOLUNTARY SOCIAL YEAR</p>
                        <p class="bento__voluntary-desc">Completed a voluntary social year contributing to community development programs.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style lang="scss">
    .bento {
        padding: 96px 144px;
        display: flex;
        flex-direction: column;
        gap: 48px;

        &__title {
            font-family: 'Anton', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            color: var(--clr-text-primary);
            letter-spacing: -1px;
        }

        &__grid {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        // Base card styles
        &__card {
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-dark);
            border-radius: 12px;
            overflow: hidden;
            backdrop-filter: blur(24px);
        }

        // Row 1: Current Occupation
        &__card--occupation {
            display: flex;
            flex-direction: row;
            height: 300px;
        }

        &__occupation-left {
            flex: 1;
            padding: 28px 32px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        &__occupation-top {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        &__occupation-heading {
            font-family: 'Anton', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--clr-white);
            line-height: 1.1;
        }

        &__occupation-desc {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.5;
        }

        &__occupation-image {
            width: 461px;
            height: 100%;
            background: linear-gradient(135deg, #2a1040 0%, #1a0828 30%, #0a1028 70%, #041020 100%);
            flex-shrink: 0;
        }

        // Row 2 layout
        &__row2 {
            display: flex;
            flex-direction: row;
            gap: 20px;
        }

        &__col-left {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        // Former Career
        &__card--career {
            padding: 32px 28px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        &__card-title {
            font-family: 'Anton', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--clr-white);
            line-height: 1.1;
        }

        &__career-entry {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        &__career-meta {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
        }

        &__career-role {
            font-family: 'Anton', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--clr-white);
            line-height: 1.2;
        }

        &__career-desc {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.5;
        }

        &__subheading {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--clr-white);
        }

        // Skills
        &__card--skills {
            padding: 32px 28px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        &__skills-grid {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        // Right column: Voluntary
        &__card--voluntary {
            width: 470px;
            flex-shrink: 0;
            padding: 28px 24px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-self: stretch;
        }

        &__voluntary-title {
            font-family: 'Anton', sans-serif;
            font-size: 32px;
            font-weight: 700;
            color: #F5C518;
            line-height: 1.1;
        }

        &__voluntary-entries {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        &__voluntary-entry {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        &__voluntary-meta {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.3);
        }

        &__voluntary-role {
            font-family: 'Anton', sans-serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--clr-white);
            line-height: 1.2;
            text-transform: uppercase;
        }

        &__voluntary-desc {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 12px;
            color: rgba(255, 255, 255, 0.4);
            line-height: 1.4;
        }

        &__voluntary-separator {
            border: none;
            border-top: 2px solid rgba(255, 255, 255, 0.08);
            width: 60px;
            margin: 0;
        }

        // Tags
        &__tags {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 8px;
        }

        &__tag {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 12px;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 100vh;
            line-height: 1;
        }

        &__tag--magenta {
            background: rgba(255, 0, 123, 0.12);
            color: var(--clr-magenta);
        }

        &__tag--blue {
            background: rgba(0, 183, 255, 0.12);
            color: var(--clr-blue);
        }

        &__tag--green {
            background: rgba(0, 224, 142, 0.12);
            color: var(--clr-green);
        }

        &__tag--filled-magenta {
            background: rgba(255, 0, 123, 0.22);
            color: var(--clr-magenta);
        }

        &__tag--filled-blue {
            background: rgba(0, 183, 255, 0.22);
            color: var(--clr-blue);
        }

        &__tag--filled-green {
            background: rgba(0, 224, 142, 0.22);
            color: var(--clr-green);
        }

        // Badges
        &__badge {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 100vh;
        }

        &__badge--magenta {
            background: rgba(255, 0, 123, 0.15);
            color: var(--clr-magenta);
        }
    }

    @media (max-width: 1440px) {
        .bento {
            padding: 96px 80px;
        }
    }

    @media (max-width: 768px) {
        .bento {
            padding: 96px 2rem;

            &__card--occupation {
                flex-direction: column;
                height: auto;
            }

            &__occupation-left {
                gap: 20px;
            }

            &__occupation-image {
                width: 100%;
                height: 200px;
            }

            &__row2 {
                flex-direction: column;
            }

            &__card--voluntary {
                width: 100%;
            }
        }
    }

    @media (max-width: 375px) {
        .bento {
            padding: 64px 1.25rem;
            gap: 32px;

            &__title {
                font-size: 2rem;
            }

            &__occupation-heading,
            &__card-title {
                font-size: 22px;
            }

            &__voluntary-title {
                font-size: 24px;
            }
        }
    }
</style>
