---
import { Icon } from 'astro-icon/components';
---

<section class="contact reveal" id="contact">
    <div class="contact__section-label">05 // COMMUNICATION</div>

    <div class="contact__header">
        <h2 class="contact__title">Let's Talk</h2>
        <p class="contact__subtitle">Tell me about your project and I'll get back to you within 24 hours with an honest assessment of how I can help.</p>
    </div>

    <form class="contact__form" action="#" method="POST">
        <div class="contact__row">
            <div class="contact__field">
                <label class="contact__label" for="v2-contact-name">NAME *</label>
                <input
                    class="contact__input"
                    type="text"
                    id="v2-contact-name"
                    name="name"
                    placeholder="Your full name"
                    required
                />
            </div>
            <div class="contact__field">
                <label class="contact__label" for="v2-contact-email">EMAIL *</label>
                <input
                    class="contact__input"
                    type="email"
                    id="v2-contact-email"
                    name="email"
                    placeholder="your@email.com"
                    required
                />
            </div>
        </div>

        <div class="contact__row">
            <div class="contact__field">
                <label class="contact__label" for="v2-contact-company">COMPANY</label>
                <input
                    class="contact__input"
                    type="text"
                    id="v2-contact-company"
                    name="company"
                    placeholder="Your company"
                />
            </div>
            <div class="contact__field">
                <label class="contact__label" for="v2-contact-plan">PLAN</label>
                <div class="contact__select-wrapper">
                    <select
                        class="contact__select"
                        id="v2-contact-plan"
                        name="plan"
                    >
                        <option value="" disabled selected>Select a plan</option>
                        <option value="hourly">Hourly Based Consulting</option>
                        <option value="prototype">Fixed Prototype Iterations</option>
                        <option value="retainer">Monthly CTO Retainer</option>
                        <option value="unsure">Not sure yet</option>
                    </select>
                    <Icon name="mdi:chevron-down" class="contact__select-icon" width={20} height={20} />
                </div>
            </div>
        </div>

        <div class="contact__field">
            <label class="contact__label" for="v2-contact-message">MESSAGE *</label>
            <textarea
                class="contact__textarea"
                id="v2-contact-message"
                name="message"
                placeholder="Tell me about your project..."
                required
            ></textarea>
        </div>

        <button type="submit" class="contact__submit">
            TRANSMIT MESSAGE
        </button>
    </form>
</section>

<style lang="scss">
    .contact {
        padding: 80px 280px 80px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 32px;

        &__section-label {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.6875rem;
            font-weight: 700;
            color: var(--clr-accent);
            letter-spacing: 0.15em;
            text-transform: uppercase;
        }

        &__header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            text-align: center;
        }

        &__title {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 3.5rem;
            font-weight: 700;
            color: var(--clr-text-primary);
            letter-spacing: -0.02em;
            line-height: 1.1;
            text-transform: uppercase;
        }

        &__subtitle {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            color: var(--clr-text-muted);
            text-align: center;
            max-width: 480px;
            line-height: 1.7;
        }

        &__form {
            display: flex;
            flex-direction: column;
            gap: 16px;
            width: 100%;
            max-width: 820px;
        }

        &__row {
            display: flex;
            flex-direction: row;
            gap: 16px;
        }

        &__field {
            display: flex;
            flex-direction: column;
            gap: 6px;
            flex: 1;
        }

        &__label {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.625rem;
            font-weight: 700;
            color: var(--clr-accent);
            letter-spacing: 0.12em;
        }

        &__input {
            height: 44px;
            padding: 0 16px;
            background: var(--clr-bg-surface);
            border: 1px solid rgba(59, 130, 246, 0.12);
            color: var(--clr-text-primary);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            outline: none;
            transition: border-color 0.2s;

            &::placeholder {
                color: rgba(200, 214, 229, 0.3);
            }

            &:focus {
                border-color: var(--clr-accent);
            }
        }

        &__select-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        &__select {
            height: 44px;
            padding: 0 16px;
            background: var(--clr-bg-surface);
            border: 1px solid rgba(59, 130, 246, 0.12);
            color: rgba(200, 214, 229, 0.3);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            outline: none;
            appearance: none;
            -webkit-appearance: none;
            width: 100%;
            cursor: pointer;
            transition: border-color 0.2s;

            option {
                background: #111827;
                color: var(--clr-text-primary);
            }

            option:not([value=""]) {
                color: var(--clr-text-primary);
            }

            &:focus {
                border-color: var(--clr-accent);
            }
        }

        &__select-icon {
            position: absolute;
            right: 12px;
            pointer-events: none;
            color: rgba(200, 214, 229, 0.3);
            flex-shrink: 0;
        }

        &__textarea {
            height: 120px;
            padding: 12px 16px;
            background: var(--clr-bg-surface);
            border: 1px solid rgba(59, 130, 246, 0.12);
            color: var(--clr-text-primary);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            outline: none;
            resize: vertical;
            line-height: 1.6;
            transition: border-color 0.2s;

            &::placeholder {
                color: rgba(200, 214, 229, 0.3);
            }

            &:focus {
                border-color: var(--clr-accent);
            }
        }

        &__submit {
            width: fit-content;
            align-self: center;
            padding: 14px 40px;
            background: var(--clr-accent);
            border: 1px solid var(--clr-accent);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.8125rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: var(--clr-bg-primary);
            cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;

            &:hover {
                opacity: 0.9;
                transform: translateY(-1px);
            }

            &:active {
                opacity: 1;
                transform: translateY(0);
            }
        }
    }

    @media (max-width: 1440px) {
        .contact {
            padding: 80px 80px 80px;
        }
    }

    @media (max-width: 768px) {
        .contact {
            padding: 96px 2rem;

            &__row {
                flex-direction: column;
            }

            &__title {
                font-size: 2.5rem;
            }
        }
    }

    @media (max-width: 375px) {
        .contact {
            padding: 64px 1.25rem;

            &__title {
                font-size: 2rem;
            }

            &__subtitle {
                font-size: 0.8125rem;
            }
        }
    }
</style>
