---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import picture from '../../assets/fb.jpg';
---

<section class="hero reveal">
    <div class="hero-section-label">01 // IDENTIFICATION</div>

    <p class="hero-overline">
        <span class="overline-plain">Fractional CTO who turns </span><span class="overline-accent">outgrown processes</span><span class="overline-plain"> into </span><span class="overline-accent2">systems that scale</span><span class="overline-plain">.</span>
    </p>

    <div class="hero-main">
        <div class="hero-left">
            <div class="hero-headline-group">
                <h1 class="hero-headline">Sebastian Heitmann</h1>
            </div>

            <div class="hero-body">
                <p class="hero-body-text">I help growing companies align product, technology, and operations — bringing structure to complexity, clarity to decisions, and momentum to execution.</p>
            </div>

            <div class="hero-stats">
                <div class="hero-stats__item">
                    <span class="hero-stats__number hero-stats__number--accent">10+</span>
                    <span class="hero-stats__label">YRS_IN_TECH</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number hero-stats__number--accent2">50+</span>
                    <span class="hero-stats__label">PROJECTS_DELIVERED</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number hero-stats__number--amber">8</span>
                    <span class="hero-stats__label">INDUSTRIES</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number hero-stats__number--red">3</span>
                    <span class="hero-stats__label">COUNTRIES</span>
                </div>
            </div>

            <div class="hero-cta-row">
                <a class="hero-cta-primary" href="#contact">Book a Discovery Call</a>
                <a class="hero-cta-secondary" href="#services">See how I work &rarr;</a>
            </div>
        </div>

        <aside class="hero-aside">
            <div class="hero-aside__card">
                <Image
                    loading="eager"
                    class="hero-aside__photo"
                    src={picture}
                    alt="Sebastian Heitmann"
                    width={260}
                    height={320}
                />
                <div class="hero-aside__icons">
                    <a id="linkedin" href="https://www.linkedin.com/in/don-heidmann/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <Icon name="simple-icons:linkedin" width={28} height={28} />
                    </a>
                    <a id="github" href="https://github.com/DonHeidi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                        <Icon name="simple-icons:github" width={28} height={28} />
                    </a>
                    <a id="bluesky" href="https://www.bluesky.com/e2e_developer" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                        <Icon name="simple-icons:bluesky" width={24} height={24} />
                    </a>
                </div>
            </div>
        </aside>
    </div>

    <div class="hero-stamp">[AUTHORIZED PERSONNEL]</div>
</section>

<style lang="scss">
    .hero {
        padding: 3rem 144px 4rem 144px;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        position: relative;

        &-section-label {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.6875rem;
            font-weight: 700;
            color: var(--clr-accent);
            letter-spacing: 0.15em;
            text-transform: uppercase;
        }

        &-overline {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: baseline;
            gap: 0 4px;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 1.25rem;
            line-height: 1.6;

            .overline-plain {
                color: var(--clr-text-primary);
            }

            .overline-accent {
                color: var(--clr-accent);
                font-weight: 700;
            }

            .overline-accent2 {
                color: var(--clr-amber);
                font-weight: 700;
            }
        }

        &-main {
            flex: 1;
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            gap: 5rem;
        }

        &-headline-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        &-headline {
            font-family: 'IBM Plex Mono', monospace;
            font-size: clamp(2.5rem, 4.5vw, 4rem);
            font-weight: 700;
            color: var(--clr-text-primary);
            letter-spacing: -0.02em;
            line-height: 1.1;
            text-transform: uppercase;
        }

        &-positioning {
            font-family: 'IBM Plex Mono', monospace;
            font-size: clamp(1rem, 1.5vw, 1.375rem);
            font-weight: 400;
            color: var(--clr-text-muted);
            line-height: 1.4;
        }

        &-left {
            flex: 0 1 auto;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        &-body-text {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 1.0625rem;
            color: rgba(200, 214, 229, 0.75);
            line-height: 1.7;
            max-width: 520px;
        }

        &-cta-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.5rem;
        }

        &-cta-primary {
            text-decoration: none;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            font-weight: 700;
            line-height: 1;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--clr-bg-primary);
            background-color: var(--clr-accent);
            border: 1px solid var(--clr-accent);
            padding: 1rem 2rem;
            transition:
                background-color 0.2s ease,
                color 0.2s ease;

            &:hover {
                background-color: transparent;
                color: var(--clr-accent);
            }
        }

        &-cta-secondary {
            text-decoration: none;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.8125rem;
            font-weight: 400;
            color: var(--clr-text-muted);
            transition: color 0.2s ease;

            &:hover {
                color: var(--clr-accent);
            }
        }

        &-stats {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 1.5rem;
            margin-top: 0.5rem;
            padding: 1rem 0;
            border-top: 1px solid rgba(59, 130, 246, 0.1);
            border-bottom: 1px solid rgba(59, 130, 246, 0.1);

            &__item {
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }

            &__number {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 2rem;
                font-weight: 700;
                line-height: 1;
                font-variant-numeric: tabular-nums;

                &--accent { color: var(--clr-accent); }
                &--accent2 { color: var(--clr-amber); }
                &--amber { color: var(--clr-amber); }
                &--red { color: var(--clr-danger); }
            }

            &__label {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 0.625rem;
                font-weight: 400;
                color: var(--clr-text-muted);
                letter-spacing: 0.08em;
            }

            &__divider {
                width: 1px;
                height: 32px;
                background: rgba(59, 130, 246, 0.15);
                flex-shrink: 0;
            }
        }

        &-aside {
            flex-shrink: 0;

            &__card {
                display: flex;
                flex-direction: row;
                align-items: center;
                gap: 1.5rem;
                border: 1px solid rgba(59, 130, 246, 0.15);
                padding: 16px;
                position: relative;

                /* Corner markers */
                &::before, &::after {
                    content: '';
                    position: absolute;
                    width: 12px;
                    height: 12px;
                    border-color: var(--clr-accent);
                    border-style: solid;
                }
                &::before {
                    top: -1px;
                    left: -1px;
                    border-width: 2px 0 0 2px;
                }
                &::after {
                    bottom: -1px;
                    right: -1px;
                    border-width: 0 2px 2px 0;
                }
            }

            &__photo {
                display: block;
                flex: 0 0 auto;
                width: 200px;
                height: 250px;
                object-fit: cover;
                filter: grayscale(0.6) contrast(1.1);
            }

            &__icons {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 1.25rem;

                a {
                    color: var(--clr-text-muted);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                    transition: color 0.2s ease;

                    &:hover {
                        color: var(--clr-accent);
                    }

                    :global(svg) {
                        color: inherit;
                        fill: currentColor;
                    }
                }
            }
        }

        &-stamp {
            position: absolute;
            top: 80px;
            right: 180px;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--clr-danger);
            opacity: 0.12;
            letter-spacing: 0.15em;
            transform: rotate(-12deg);
            pointer-events: none;
            user-select: none;
        }
    }

    @media (max-width: 1440px) {
        .hero {
            padding: 3rem 80px 4rem 80px;
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 2rem;

            &-headline {
                font-size: 2.5rem;
            }

            &-main {
                flex-direction: column;
            }

            &-left {
                width: 100%;
            }

            &-stats {
                gap: 1.25rem;

                &__number {
                    font-size: 1.75rem;
                }
            }

            &-aside {
                margin-top: 2rem;

                &__photo {
                    width: 160px;
                    height: 200px;
                }
            }

            &-stamp {
                display: none;
            }
        }
    }

    @media (max-width: 375px) {
        .hero {
            padding: 1.25rem;

            &-headline {
                font-size: 2rem;
            }

            &-overline {
                font-size: 0.875rem;
            }

            &-cta-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            &-stats {
                display: grid;
                grid-template-columns: 1fr auto 1fr;
                gap: 1rem;

                &__item:nth-child(n+5) {
                    grid-column: 1;
                }

                &__divider:nth-of-type(2) {
                    display: none;
                }
            }
        }
    }
</style>
