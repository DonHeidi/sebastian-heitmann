---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import picture from '../../assets/fb.jpg';
---

<section class="hero">
    <p class="hero-overline">
        <span class="overline-plain">I build </span><span class="overline-magenta">products</span><span class="overline-plain">. I lead </span><span class="overline-blue">teams</span><span class="overline-plain">. I solve </span><span class="overline-green">problems</span><span class="overline-plain">.</span>
    </p>

    <div class="hero-main">
        <h1 class="hero-headline">Sebastian Heitmann</h1>

        <div class="hero-left">
            <div class="hero-body">
                <p class="hero-body-text">From scale-ups to B2B SaaS founders, I help teams grow through smart software and strong operations.</p>
                <p class="hero-body-text">With 10+ years of experience across industries and company sizes, I bring structure, speed, and clarity to complex challenges.</p>
            </div>
            <div class="hero-cta-row">
                <a class="hero-cta-primary" href="#contact">BOOK A CALL</a>
                <a class="hero-cta-secondary" href="#why-me">more about me →</a>
            </div>
        </div>

        <aside class="hero-aside">
            <div class="hero-aside__social">
                <Image
                    loading="eager"
                    class="hero-aside__photo"
                    src={picture}
                    alt="Sebastian Heitmann"
                    width={300}
                    height={360}
                />
                <div class="hero-aside__icons">
                    <a id="linkedin" href="https://www.linkedin.com/in/don-heidmann/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <Icon name="simple-icons:linkedin" width={32} height={32} />
                    </a>
                    <a id="github" href="https://github.com/DonHeidi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                        <Icon name="simple-icons:github" width={32} height={32} />
                    </a>
                    <a id="bluesky" href="https://www.bluesky.com/e2e_developer" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                        <Icon name="simple-icons:bluesky" width={28} height={28} />
                    </a>
                </div>
            </div>

            <div class="hero-badge">
                <p class="hero-badge__title">Fractional CTO and AI & Product Engineer</p>
            </div>
        </aside>
    </div>
</section>

<style lang="scss">
    .hero {
        min-height: 56.25rem;
        padding: 3.75rem 144px 5rem 144px;
        display: flex;
        flex-direction: column;
        gap: 2rem;

        &-overline {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: baseline;
            gap: 0 4px;
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 1.25rem;
            line-height: 1.5;

            .overline-plain {
                color: var(--clr-text-primary);
            }

            .overline-magenta {
                color: var(--clr-magenta);
                font-weight: 700;
            }

            .overline-blue {
                color: var(--clr-blue);
                font-weight: 700;
            }

            .overline-green {
                color: var(--clr-green);
                font-weight: 700;
            }
        }

        &-main {
            position: relative;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        &-headline {
            font-family: 'Anton', sans-serif;
            font-size: clamp(4rem, 7.5vw, 7.5rem);
            font-weight: 700;
            color: var(--clr-text-primary);
            letter-spacing: -3px;
            line-height: 1;
            white-space: nowrap;
            position: relative;
            z-index: 2;
        }

        &-left {
            width: 480px;
            margin-top: 2.5rem;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        &-body {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        &-body-text {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 1rem;
            color: var(--clr-text-primary);
            line-height: 1.5;
        }

        &-cta-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.75rem;
        }

        &-cta-primary {
            text-decoration: none;
            font-family: 'Anton', sans-serif;
            font-size: 1.375rem;
            line-height: 1;
            color: var(--clr-white);
            background-color: var(--clr-bg-surface);
            border: 1.5px solid var(--clr-text-primary);
            border-radius: 100vh;
            padding: 0.875rem 3rem;
            backdrop-filter: blur(10px);
            transition:
                background-color 0.2s ease,
                border-color 0.2s ease;

            &:hover {
                background-color: var(--clr-text-primary);
            }
        }

        &-cta-secondary {
            text-decoration: none;
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--clr-text-primary);
            transition: opacity 0.2s ease;

            &:hover {
                opacity: 0.7;
            }
        }

        &-aside {
            position: absolute;
            left: 480px;
            top: 140px;
            display: flex;
            flex-direction: column;
            gap: 0;
            transform: rotate(-10deg);

            &__social {
                display: flex;
                flex-direction: row;
                align-items: center;
                gap: 2rem;
            }

            &__photo {
                display: block;
                flex: 0 0 auto;
                width: 300px;
                height: 360px;
                border-radius: 24px;
                object-fit: cover;
                box-shadow:
                    0 8px 32px rgba(0, 0, 0, 0.3),
                    0 0 0 1px rgba(255, 255, 255, 0.06);
            }

            &__icons {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 1rem;

                a {
                    color: var(--clr-text-primary);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                    transition: opacity 0.2s ease;

                    &:hover {
                        opacity: 0.7;
                    }

                    :global(svg) {
                        color: var(--clr-text-primary);
                        fill: var(--clr-text-primary);
                    }
                }

                #linkedin {
                    rotate: -7deg;
                }

                #github {
                    rotate: 10deg;
                }

                #bluesky {
                    rotate: -4deg;
                }
            }
        }

        &-badge {
            position: absolute;
            left: 16px;
            right: unset;
            top: 320px;
            background-color: rgba(255, 0, 123, 0.59);
            backdrop-filter: blur(8.5px);
            border-radius: 6px;
            padding: 0.375rem 0.75rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: var(--clr-white);

            &__title {
                font-family: 'Anton', sans-serif;
                font-size: 1rem;
                font-weight: 700;
                line-height: 1.2;
                margin-bottom: 0.5rem;
            }

            &__skills {
                display: flex;
                flex-direction: row;
                flex-wrap: wrap;
                align-items: center;
                gap: 4px;
                font-family: 'SpaceGrotesk', sans-serif;
                font-size: 0.6875rem;
                font-weight: 700;
            }

            &__dot {
                opacity: 0.7;
            }
        }
    }

    @media (max-width: 1440px) {
        .hero {
            padding: 3.75rem 80px 5rem 80px;

            &-headline {
                font-size: 8rem;
            }

            &-aside {
                left: 380px;
                top: 120px;
            }

        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 2rem;
            min-height: auto;

            &-headline {
                font-size: 4rem;
                letter-spacing: -1px;
            }

            &-main {
                position: static;
            }

            &-left {
                width: 100%;
                margin-top: 1.5rem;
                position: static;
            }

            &-aside {
                position: static;
                margin-top: 2rem;
                flex-direction: column;

                &__social {
                    justify-content: flex-start;
                }

                &__photo {
                    width: 180px;
                    height: 220px;
                    border-radius: 16px;
                }
            }

            &-badge {
                position: static;
                margin-top: 1rem;
                width: auto;
            }
        }
    }

    @media (max-width: 375px) {
        .hero {
            padding: 1.25rem;

            &-headline {
                font-size: 2.5rem;
                letter-spacing: -0.5px;
            }

            &-overline {
                font-size: 1rem;
            }

            &-cta-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            &-aside {
                &__photo {
                    width: 140px;
                    height: 170px;
                    border-radius: 12px;
                }
            }
        }
    }
</style>
