---
import Typewriter from './typewriter.astro';

const steps = [
    {
        number: '01',
        title: 'Discovery',
        description: 'We start with your business context — goals, constraints, team, and timeline. No templates. I need to understand the real problem before proposing a solution.',
    },
    {
        number: '02',
        title: 'Strategy',
        description: 'I map out the technical approach, identify risks early, and align the plan with your business objectives. You get a clear roadmap, not a vague proposal.',
    },
    {
        number: '03',
        title: 'Delivery',
        description: 'Hands-on execution — building, shipping, and iterating. I work with your team or independently, in sprints, with full transparency and regular check-ins.',
    },
    {
        number: '04',
        title: 'Handoff',
        description: 'Every engagement ends with documentation, knowledge transfer, and systems your team can own. I build to leave, not to create dependency.',
    },
];
---

<section class="how-i-work reveal" id="process">
    <div class="how-i-work__header">
        <div class="how-i-work__section-label">03 // PROCESS</div>
        <p class="how-i-work__overline">
            <span class="how-i-work__overline-plain">How I </span><span class="how-i-work__overline-accent">work</span>
        </p>
        <Typewriter
            as="h3"
            text={[
                'Built to leave, not to stay ',
                'Clarity before momentum ',
                'Embedded, then handed over ',
            ]}
        />
        <p class="how-i-work__description">I work from the inside, create clarity early, and leave behind systems, knowledge, and structure your team can own without me.</p>
    </div>

    <div class="how-i-work__cards">
        {steps.map((step, i) => (
            <div class={`how-i-work__card stagger stagger-${i + 1}`}>
                <span class="how-i-work__card-number">{step.number}</span>
                <h3 class="how-i-work__card-title">{step.title}</h3>
                <p class="how-i-work__card-desc">{step.description}</p>
            </div>
        ))}
    </div>
</section>

<style lang="scss">
    .how-i-work {
        padding: 64px 144px 80px;
        display: flex;
        flex-direction: column;
        gap: 48px;

        &__section-label {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.6875rem;
            font-weight: 700;
            color: var(--clr-accent);
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-bottom: 0.25rem;
        }

        &__header {
            max-width: 800px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        &__overline {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 1rem;
            font-weight: 400;
            color: var(--clr-text-primary);
        }

        &__overline-plain {
            color: var(--clr-text-primary);
        }

        &__overline-accent {
            font-weight: 700;
            color: var(--clr-accent);
        }

        &__description {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.9375rem;
            color: rgba(200, 214, 229, 0.6);
            line-height: 1.7;
            max-width: 500px;
        }

        &__cards {
            display: flex;
            flex-direction: row;
            gap: 16px;
        }

        &__card {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: var(--clr-bg-surface);
            border: 1px solid rgba(59, 130, 246, 0.1);
            padding: 28px 24px;
            position: relative;
            transition: border-color 0.3s ease;

            /* Corner markers */
            &::before, &::after {
                content: '';
                position: absolute;
                width: 10px;
                height: 10px;
                border-color: var(--clr-accent);
                border-style: solid;
            }
            &::before {
                top: -1px;
                left: -1px;
                border-width: 2px 0 0 2px;
            }
            &::after {
                bottom: -1px;
                right: -1px;
                border-width: 0 2px 2px 0;
            }

            &:hover {
                border-color: rgba(59, 130, 246, 0.25);
            }
        }

        &__card-number {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 3rem;
            font-weight: 700;
            line-height: 1;
            color: rgba(59, 130, 246, 0.1);
        }

        &__card-title {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--clr-text-primary);
            line-height: 1.2;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        &__card-desc {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            color: rgba(200, 214, 229, 0.55);
            line-height: 1.7;
        }
    }

    @media (max-width: 1440px) {
        .how-i-work {
            padding: 64px 80px 80px;
        }
    }

    @media (max-width: 768px) {
        .how-i-work {
            padding: 48px 2rem 64px;

            &__cards {
                flex-direction: column;
            }
        }
    }

    @media (max-width: 375px) {
        .how-i-work {
            padding: 48px 1.25rem 64px;
        }
    }
</style>
