<section class="logobar">
    <div class="logobar__group">
        <p class="logobar__label">// PREVIOUSLY_AT</p>
        <div class="logobar__names">
            <span class="logobar__name">Jung von Matt</span>
            <span class="logobar__name">Synergy</span>
            <span class="logobar__name">Granny & Smith</span>
            <span class="logobar__name">OFFIS</span>
        </div>
    </div>

    <span class="logobar__divider"></span>

    <div class="logobar__group">
        <p class="logobar__label">// CURRENTLY_ASSIGNED</p>
        <div class="logobar__names">
            <span class="logobar__name">Pool Position GmbH</span>
            <span class="logobar__name">mobilespace GmbH</span>
        </div>
    </div>
</section>

<style lang="scss">
    .logobar {
        border-top: 1px solid rgba(59, 130, 246, 0.12);
        border-bottom: 1px solid rgba(59, 130, 246, 0.12);
        background: rgba(17, 24, 39, 0.5);
        padding: 24px 144px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 4rem;

        &__group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
        }

        &__label {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.625rem;
            font-weight: 700;
            color: var(--clr-accent);
            letter-spacing: 0.12em;
        }

        &__names {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.5rem;
        }

        &__name {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.875rem;
            font-weight: 400;
            color: var(--clr-text-primary);
            opacity: 0.45;
            letter-spacing: 0.02em;
            white-space: nowrap;
            transition: opacity 0.3s ease;

            &:hover {
                opacity: 0.7;
            }
        }

        &__divider {
            width: 1px;
            height: 48px;
            background: rgba(59, 130, 246, 0.15);
            flex-shrink: 0;
        }
    }

    @media (max-width: 1440px) {
        .logobar {
            padding: 24px 80px;
        }
    }

    @media (max-width: 768px) {
        .logobar {
            padding: 24px 2rem;
            flex-direction: column;
            gap: 1.5rem;

            &__divider {
                width: 60px;
                height: 1px;
            }

            &__names {
                flex-wrap: wrap;
                justify-content: center;
                gap: 1.25rem 2rem;
            }
        }
    }

    @media (max-width: 375px) {
        .logobar {
            padding: 20px 1.25rem;

            &__names {
                gap: 1rem 1.5rem;
            }

            &__name {
                font-size: 0.8125rem;
            }
        }
    }
</style>
