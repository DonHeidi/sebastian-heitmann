---

<section class="plans">
    <div class="plans__cards">
        <!-- Card 1: Hourly Based Consulting -->
        <div class="plans__card plans__card--hourly">
            <h3 class="plans__card-title">Hourly Based Consulting</h3>
            <div class="plans__price-row">
                <span class="plans__price">$130</span>
                <span class="plans__price-unit">/per hour</span>
            </div>
            <ul class="plans__features">
                <li class="plans__feature">Weekly strategy sessions</li>
                <li class="plans__feature">Technical architecture reviews</li>
                <li class="plans__feature">Team mentoring</li>
                <li class="plans__feature">Code review oversight</li>
            </ul>
        </div>

        <!-- Card 2: Fixed Prototype Iterations (FEATURED) -->
        <div class="plans__card plans__card--featured">
            <div class="plans__badge">POPULAR</div>
            <h3 class="plans__card-title">Fixed Prototype Iterations</h3>
            <div class="plans__price-row">
                <span class="plans__price">$4,999</span>
                <span class="plans__price-unit">/per iteration</span>
            </div>
            <hr class="plans__divider" />
            <ul class="plans__features">
                <li class="plans__feature">Everything in Practice</li>
                <li class="plans__feature">Hands-on product development</li>
                <li class="plans__feature">Sprint planning &amp; delivery</li>
                <li class="plans__feature">Remote &amp; Async support</li>
                <li class="plans__feature">Performance tracking support</li>
            </ul>
        </div>

        <!-- Card 3: Monthly CTO Retainer -->
        <div class="plans__card plans__card--retainer">
            <h3 class="plans__card-title">Monthly CTO Retainer</h3>
            <div class="plans__price-row">
                <span class="plans__price">$2,499</span>
                <span class="plans__price-unit">/month</span>
            </div>
            <ul class="plans__features">
                <li class="plans__feature">Everything in Growth</li>
                <li class="plans__feature">Dedicated CTO</li>
                <li class="plans__feature">Board &amp; stakeholder reporting</li>
                <li class="plans__feature">Security &amp; compliance oversight</li>
                <li class="plans__feature">Custom integrations</li>
            </ul>
        </div>
    </div>

    <div class="plans__decorative">
        <p class="plans__decorative-line plans__decorative-line--1">
            <span class="plans__deco-plain">THE&nbsp;</span><span class="plans__deco-accent">RIGHT PLAN</span><span class="plans__deco-plain">&nbsp;FOR</span>
        </p>
        <p class="plans__decorative-line plans__decorative-line--2">
            <span class="plans__deco-plain">YOUR BUSINESS</span>
        </p>
    </div>
</section>

<style lang="scss">
    .plans {
        padding: 96px 144px 64px 144px;
        display: flex;
        flex-direction: column;
        align-items: center;

        &__cards {
            display: flex;
            flex-direction: row;
            gap: 24px;
            align-items: flex-end;
            width: 100%;
        }

        &__card {
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-dark);
            backdrop-filter: blur(24px);
            flex: 1;
        }

        &__card--hourly {
            border-radius: 20px;
            padding: 40px;
        }

        &__card--featured {
            border-radius: 16px;
            padding: 32px 28px;
            border: 1.5px solid var(--clr-blue);
            backdrop-filter: blur(40px);
        }

        &__card--retainer {
            border-radius: 16px;
            padding: 32px;
        }

        &__badge {
            display: inline-block;
            align-self: flex-start;
            padding: 4px 12px;
            border-radius: 100vh;
            background: rgba(255, 0, 123, 0.2);
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 10px;
            font-weight: 700;
            color: var(--clr-magenta);
            letter-spacing: 1.5px;
        }

        &__card-title {
            font-family: 'Anton', sans-serif;
            font-size: 28px;
            color: var(--clr-white);
            line-height: 1.1;
        }

        &__price-row {
            display: flex;
            flex-direction: row;
            align-items: baseline;
            gap: 6px;
        }

        &__price {
            font-family: 'Anton', sans-serif;
            font-size: 4rem;
            font-weight: 700;
            color: var(--clr-white);
            line-height: 1;
        }

        &__price-unit {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.5);
        }

        &__divider {
            border: none;
            border-top: 1px solid var(--clr-border-dark);
            margin: 0;
        }

        &__features {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        &__card--featured &__features {
            gap: 14px;
        }

        &__card--retainer &__features {
            gap: 14px;
        }

        &__feature {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.4;
        }

        &__decorative {
            padding-top: 32px;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        &__decorative-line {
            font-family: 'Anton', sans-serif;
            font-size: 5.25rem;
            letter-spacing: 6px;
            line-height: 1;
            text-align: center;
            display: flex;
            flex-direction: row;
            justify-content: center;
            align-items: baseline;
        }

        &__deco-plain {
            color: rgba(231, 229, 219, 0.3);
        }

        &__deco-accent {
            color: var(--clr-magenta);
        }
    }

    @media (max-width: 1440px) {
        .plans {
            padding: 96px 80px 64px 80px;

            &__decorative-line {
                font-size: 3.75rem;
            }
        }
    }

    @media (max-width: 768px) {
        .plans {
            padding: 96px 2rem 64px 2rem;

            &__cards {
                flex-direction: column;
                align-items: stretch;
            }

            &__decorative-line {
                font-size: 3rem;
            }
        }
    }

    @media (max-width: 375px) {
        .plans {
            padding: 96px 1.25rem 64px 1.25rem;

            &__decorative-line {
                font-size: 2rem;
                letter-spacing: 3px;
            }
        }
    }
</style>
