<!-- Space objects that fly across the viewport at random intervals -->
<div id="space-layer" aria-hidden="true"></div>

<!-- Templates (hidden, cloned by script) -->
<template id="tpl-rocket">
    <div class="space-object" data-type="rocket">
        <div class="exhaust">
            <div class="flame flame-outer"></div>
            <div class="flame flame-mid"></div>
            <div class="flame flame-core"></div>
        </div>
        <div class="object-body">
            <svg viewBox="0 0 80 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="rocket-svg">
                <path d="M20 2 L28 8 L20 8 Z" fill="#3B82F6" opacity="0.9"/>
                <path d="M20 30 L28 24 L20 24 Z" fill="#3B82F6" opacity="0.9"/>
                <ellipse cx="44" cy="16" rx="28" ry="9" fill="#C8D6E5"/>
                <path d="M72 16 L80 16 Q76 10 72 7 Z" fill="#E2E8F0"/>
                <path d="M72 16 L80 16 Q76 22 72 25 Z" fill="#B0BEC5"/>
                <rect x="34" y="9" width="20" height="14" rx="2" fill="#1E3A5F" opacity="0.3"/>
                <circle cx="56" cy="16" r="4" fill="#0A0E17" stroke="#3B82F6" stroke-width="1.2"/>
                <circle cx="56" cy="14.5" r="1.8" fill="#3B82F6" opacity="0.3"/>
            </svg>
        </div>
    </div>
</template>

<template id="tpl-asteroid">
    <div class="space-object" data-type="asteroid">
        <div class="object-body asteroid-body">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="asteroid-svg">
                <path d="M20 2 L30 6 L36 14 L38 24 L32 34 L22 38 L10 36 L4 28 L2 18 L6 8 L14 3 Z" fill="#4A4458"/>
                <path d="M20 2 L30 6 L36 14 L38 24 L32 34 L22 38" fill="#3D3852"/>
                <circle cx="15" cy="14" r="3.5" fill="#3A3450" stroke="#52496A" stroke-width="0.5"/>
                <circle cx="26" cy="22" r="2.5" fill="#3A3450" stroke="#52496A" stroke-width="0.5"/>
                <circle cx="18" cy="28" r="2" fill="#3A3450" stroke="#52496A" stroke-width="0.4"/>
                <circle cx="28" cy="12" r="1.5" fill="#433D58"/>
                <path d="M8 20 Q10 18 12 20" stroke="#52496A" stroke-width="0.5" fill="none"/>
            </svg>
        </div>
    </div>
</template>

<template id="tpl-ufo">
    <div class="space-object" data-type="ufo">
        <div class="object-body ufo-body">
            <svg viewBox="0 0 72 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="ufo-svg">
                <ellipse cx="36" cy="38" rx="14" ry="2" fill="#00E08E" opacity="0.15"/>
                <ellipse cx="36" cy="24" rx="32" ry="7" fill="#2D3748"/>
                <ellipse cx="36" cy="23" rx="32" ry="7" fill="#4A5568"/>
                <path d="M22 23 Q22 10 36 8 Q50 10 50 23" fill="#718096"/>
                <path d="M24 23 Q24 12 36 10 Q48 12 48 23" fill="rgba(59, 130, 246, 0.15)"/>
                <path d="M28 18 Q30 13 36 12" stroke="rgba(200, 214, 229, 0.3)" stroke-width="1.2" fill="none" stroke-linecap="round"/>
                <circle cx="16" cy="24" r="1.8" fill="#00E08E" class="ufo-light ufo-light-1"/>
                <circle cx="26" cy="26" r="1.8" fill="#00E08E" class="ufo-light ufo-light-2"/>
                <circle cx="36" cy="27" r="1.8" fill="#00E08E" class="ufo-light ufo-light-3"/>
                <circle cx="46" cy="26" r="1.8" fill="#00E08E" class="ufo-light ufo-light-2"/>
                <circle cx="56" cy="24" r="1.8" fill="#00E08E" class="ufo-light ufo-light-1"/>
            </svg>
        </div>
    </div>
</template>

<style lang="scss">
    #space-layer {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
        perspective: 600px;
    }

    .space-object {
        position: absolute;
        display: flex;
        align-items: center;
        opacity: 0;
        will-change: transform, opacity;
        transform-style: preserve-3d;
    }

    /* Rocket */
    .rocket-svg {
        width: 48px;
        height: 20px;
        display: block;
    }

    [data-type="rocket"] .object-body {
        filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.3));
    }

    .exhaust {
        display: flex;
        align-items: center;
        margin-right: -6px;
        position: relative;
    }

    .flame {
        border-radius: 50%;
        filter: blur(2px);
        animation: flicker 0.1s ease-in-out infinite alternate;
    }

    .flame-outer {
        width: 28px;
        height: 14px;
        background: rgba(239, 68, 68, 0.7);
        margin-right: -14px;
        z-index: 1;
        filter: blur(4px);
        animation-delay: 0.06s;
    }

    .flame-mid {
        width: 18px;
        height: 10px;
        background: #F59E0B;
        margin-right: -8px;
        z-index: 2;
        animation-delay: 0.03s;
    }

    .flame-core {
        width: 10px;
        height: 6px;
        background: #FFF;
        z-index: 3;
    }

    @keyframes flicker {
        0% { transform: scaleX(0.9) scaleY(0.85); }
        100% { transform: scaleX(1.1) scaleY(1.15); }
    }

    /* Asteroid */
    .asteroid-svg {
        width: 32px;
        height: 32px;
        display: block;
    }

    .asteroid-body {
        filter: drop-shadow(0 0 4px rgba(82, 73, 106, 0.4));
    }

    /* UFO */
    .ufo-svg {
        width: 52px;
        height: 30px;
        display: block;
    }

    .ufo-body {
        filter: drop-shadow(0 0 12px rgba(0, 224, 142, 0.2));
    }

    .ufo-light {
        animation: ufo-blink 1.2s ease-in-out infinite;
    }
    .ufo-light-1 { animation-delay: 0s; }
    .ufo-light-2 { animation-delay: 0.4s; }
    .ufo-light-3 { animation-delay: 0.8s; }

    @keyframes ufo-blink {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
    }

    @media (prefers-reduced-motion: reduce) {
        .space-object { display: none; }
    }
</style>

<script>
    type ObjectType = 'rocket' | 'asteroid' | 'ufo';

    const layer = document.getElementById('space-layer')!;
    const templates: Record<ObjectType, HTMLTemplateElement> = {
        rocket: document.getElementById('tpl-rocket') as HTMLTemplateElement,
        asteroid: document.getElementById('tpl-asteroid') as HTMLTemplateElement,
        ufo: document.getElementById('tpl-ufo') as HTMLTemplateElement,
    };

    interface Trajectory {
        startX: number;
        startY: number;
        endX: number;
        endY: number;
        duration: number;
        flightAngle: number;
        rotateY: number;
        scale: number;
        spin: number;
        wobble: number;
    }

    function randomTrajectory(type: ObjectType): Trajectory {
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const margin = 120;

        const edges = [0, 1, 2, 3];
        const startEdge = edges[Math.floor(Math.random() * edges.length)];
        const exitOptions = edges.filter(e => e !== startEdge);
        const endEdge = exitOptions[Math.floor(Math.random() * exitOptions.length)];

        function pointOnEdge(edge: number): [number, number] {
            switch (edge) {
                case 0: return [-margin, vh * (0.1 + Math.random() * 0.8)];
                case 1: return [vw + margin, vh * (0.1 + Math.random() * 0.8)];
                case 2: return [vw * (0.1 + Math.random() * 0.8), -margin];
                case 3: return [vw * (0.1 + Math.random() * 0.8), vh + margin];
                default: return [-margin, vh * 0.5];
            }
        }

        const [startX, startY] = pointOnEdge(startEdge);
        const [endX, endY] = pointOnEdge(endEdge);
        const headingRight = endX > startX;
        const flightAngle = Math.atan2(endY - startY, endX - startX) * (180 / Math.PI);

        const speeds: Record<ObjectType, [number, number]> = {
            rocket:   [9000, 5000],
            asteroid: [12000, 6000],
            ufo:      [10000, 5000],
        };
        const scales: Record<ObjectType, [number, number]> = {
            rocket:   [0.7, 0.8],
            asteroid: [0.5, 1.0],
            ufo:      [0.7, 0.6],
        };

        const [baseDur, varDur] = speeds[type];
        const [baseScale, varScale] = scales[type];

        return {
            startX, startY, endX, endY,
            duration: baseDur + Math.random() * varDur,
            flightAngle,
            rotateY: headingRight ? 0 : 180,
            scale: baseScale + Math.random() * varScale,
            spin: type === 'asteroid' ? (60 + Math.random() * 120) * (Math.random() > 0.5 ? 1 : -1) : 0,
            wobble: type === 'ufo' ? 6 + Math.random() * 8 : 0,
        };
    }

    function launch(type: ObjectType) {
        const clone = templates[type].content.cloneNode(true) as DocumentFragment;
        const el = clone.firstElementChild as HTMLElement;
        layer.appendChild(el);

        const traj = randomTrajectory(type);
        let start: number | null = null;

        function animate(timestamp: number) {
            if (!start) start = timestamp;
            const elapsed = timestamp - start;
            const progress = Math.min(elapsed / traj.duration, 1);

            const x = traj.startX + (traj.endX - traj.startX) * progress;
            let y = traj.startY + (traj.endY - traj.startY) * progress;

            if (traj.wobble) {
                y += Math.sin(elapsed * 0.003) * traj.wobble;
            }

            const spinAngle = traj.spin ? (elapsed / 1000) * traj.spin : 0;

            el.style.opacity = '1';

            if (type === 'asteroid') {
                // Tumble freely + follow flight angle
                el.style.transform = `
                    translate3d(${x}px, ${y}px, 0)
                    rotate(${traj.flightAngle + spinAngle}deg)
                    scale(${traj.scale})
                `;
            } else if (type === 'ufo') {
                // Stays mostly level, gentle rocking
                el.style.transform = `
                    translate3d(${x}px, ${y}px, 0)
                    rotateZ(${Math.sin(elapsed * 0.002) * 5}deg)
                    scale(${traj.scale})
                `;
            } else {
                // Rocket nose aims along flight path
                const flipCorrection = traj.rotateY === 180 ? 180 : 0;
                el.style.transform = `
                    translate3d(${x}px, ${y}px, 0)
                    rotateY(${traj.rotateY}deg)
                    rotateZ(${traj.flightAngle + flipCorrection}deg)
                    scale(${traj.scale})
                `;
            }

            if (progress < 1) {
                requestAnimationFrame(animate);
            } else {
                el.remove();
            }
        }

        requestAnimationFrame(animate);
    }

    const types: ObjectType[] = ['rocket', 'asteroid', 'ufo'];
    // Weighted — more asteroids for a busy feel
    const weighted: ObjectType[] = ['rocket', 'asteroid', 'asteroid', 'asteroid', 'ufo', 'ufo'];

    function scheduleNext() {
        const delay = 1500 + Math.random() * 3000; // 1.5–4.5 seconds
        setTimeout(() => {
            const type = weighted[Math.floor(Math.random() * weighted.length)];
            launch(type);
            scheduleNext();
        }, delay);
    }

    // Stagger initial burst
    setTimeout(() => launch('rocket'), 1000);
    setTimeout(() => launch('asteroid'), 2000);
    setTimeout(() => launch('ufo'), 3000);
    scheduleNext();
</script>
