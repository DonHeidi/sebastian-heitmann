---
import { Icon } from 'astro-icon/components';

const services = [
    { name: 'UX & UI', bg: '#0C0E1E' },
    { name: 'Solution Design', bg: '#141630' },
    { name: 'Product Development', bg: '#1C1F42' },
    { name: 'Operations & Evolution', bg: '#252854' },
];
---

<section class="services">
    <div class="services__header">
        <p class="services__overline">
            <span class="services__overline-plain">What I </span><span class="services__overline-accent">offer</span>
        </p>
        <h2 class="services__headline">My Services</h2>
        <p class="services__description">From early-stage product discovery to scaling engineering organisations — I provide hands-on technical leadership tailored to where your business is today and where it needs to go.</p>
    </div>

    <div class="services__rows">
        {services.map((service) => (
            <div class="services__row" style={`background: ${service.bg};`}>
                <span class="services__row-name">{service.name}</span>
                <Icon name="mdi:chevron-up" width={16} height={16} class="services__row-icon" />
            </div>
        ))}
    </div>
</section>

<style lang="scss">
    .services {
        display: flex;
        flex-direction: column;

        &__header {
            padding: 96px 144px 48px 144px;
            max-width: calc(560px + 144px);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        &__overline {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 20px;
            color: var(--clr-text-primary);
        }

        &__overline-plain {
            color: var(--clr-text-primary);
        }

        &__overline-accent {
            font-weight: 700;
            color: var(--clr-blue);
        }

        &__headline {
            font-family: 'Anton', sans-serif;
            font-size: 4.5rem;
            color: var(--clr-text-primary);
            letter-spacing: -1.5px;
            line-height: 0.95;
        }

        &__description {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 16px;
            color: var(--clr-text-muted);
            line-height: 1.6;
            max-width: 500px;
        }

        &__rows {
            width: 100%;
        }

        &__row {
            width: 100vw;
            margin-left: calc(-1 * (100vw - 100%) / 2);
            display: flex;
            flex-direction: row;
            justify-content: flex-end;
            align-items: center;
            gap: 12px;
            padding: 28px 144px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        }

        &__row-name {
            font-family: 'Anton', sans-serif;
            font-size: 24px;
            color: var(--clr-white);
            letter-spacing: -0.5px;
        }

        &__row-icon {
            color: var(--clr-text-muted);
            flex-shrink: 0;
        }
    }

    @media (max-width: 1440px) {
        .services {
            &__header {
                padding: 96px 80px 48px 80px;
            }

            &__row {
                padding: 28px 80px;
            }
        }
    }

    @media (max-width: 768px) {
        .services {
            &__header {
                padding: 96px 2rem 48px 2rem;
                max-width: 100%;
            }

            &__headline {
                font-size: 3rem;
            }

            &__row {
                padding: 28px 2rem;
            }

            &__row-name {
                font-size: 1.125rem;
            }
        }
    }

    @media (max-width: 375px) {
        .services {
            &__header {
                padding: 96px 1.25rem 48px 1.25rem;
            }

            &__row {
                padding: 28px 1.25rem;
            }
        }
    }
</style>
