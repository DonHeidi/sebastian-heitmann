---
type Props = {
    text: string | string[];
    as?: 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6' | 'p' | 'span';
}

const { as = 'h1', text } = Astro.props;
const longestText = Array.isArray(text) ? text.reduce((a, b) => a.length > b.length ? a : b) : text;
---

{as === 'h1' && <div class="typewriter-container"><h1 data-text={JSON.stringify(text)} class="typewriter headline"></h1><h1 class="typewriter-ghost headline" aria-hidden="true">{longestText}</h1></div>}
{as === 'h2' && <div class="typewriter-container"><h2 data-text={JSON.stringify(text)} class="typewriter headline"></h2><h2 class="typewriter-ghost headline" aria-hidden="true">{longestText}</h2></div>}
{as === 'h3' && <div class="typewriter-container"><h3 data-text={JSON.stringify(text)} class="typewriter headline"></h3><h3 class="typewriter-ghost headline" aria-hidden="true">{longestText}</h3></div>}
{as === 'h4' && <div class="typewriter-container"><h4 data-text={JSON.stringify(text)} class="typewriter headline"></h4><h4 class="typewriter-ghost headline" aria-hidden="true">{longestText}</h4></div>}
{as === 'h5' && <div class="typewriter-container"><h5 data-text={JSON.stringify(text)} class="typewriter headline"></h5><h5 class="typewriter-ghost headline" aria-hidden="true">{longestText}</h5></div>}
{as === 'h6' && <div class="typewriter-container"><h6 data-text={JSON.stringify(text)} class="typewriter headline"></h6><h6 class="typewriter-ghost headline" aria-hidden="true">{longestText}</h6></div>}
{as === 'p' && <div class="typewriter-container"><p data-text={JSON.stringify(text)} class="typewriter headline"></p><p class="typewriter-ghost headline" aria-hidden="true">{longestText}</p></div>}
{as === 'span' && <div class="typewriter-container"><span data-text={JSON.stringify(text)} class="typewriter headline"></span><span class="typewriter-ghost headline" aria-hidden="true">{longestText}</span></div>}

<script>
    function calculateTextHeight(text: string, element: HTMLElement) {
        const computedStyle = window.getComputedStyle(element);
        const container = element.parentElement;
        if (!container) return 0;

        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        if (!ctx) return 0;

        ctx.font = `${computedStyle.fontWeight} ${computedStyle.fontSize} ${computedStyle.fontFamily}`;

        const containerWidth = container.getBoundingClientRect().width;

        const words = text.split(' ');
        let lines: string[] = [];
        let currentLine = '';

        for (const word of words) {
            const testLine = currentLine ? `${currentLine} ${word}` : word;
            const metrics = ctx.measureText(testLine);

            if (metrics.width > containerWidth && currentLine) {
                lines.push(currentLine);
                currentLine = word;
            } else {
                currentLine = testLine;
            }
        }
        if (currentLine) lines.push(currentLine);

        const lineHeight = computedStyle.lineHeight === 'normal'
            ? parseFloat(computedStyle.fontSize) * 1.2
            : parseFloat(computedStyle.lineHeight);

        return lines.length * lineHeight;
    }

    const typewriters = document.querySelectorAll('.typewriter');
    typewriters.forEach((typewriter) => {
        const rawText = (typewriter as HTMLElement).dataset.text;
        const container = typewriter.parentElement;

        let texts: string[] = [];
        if (rawText) {
            try {
                const parsed = JSON.parse(rawText);
                texts = Array.isArray(parsed) ? parsed : [parsed];
            } catch {
                texts = [rawText];
            }
        }

        const longestText = texts.reduce((a, b) => a.length > b.length ? a : b, '');

        if (container && longestText) {
            const height = calculateTextHeight(longestText, typewriter as HTMLElement);
            container.style.height = `${height}px`;
        }

        const cursor = document.createElement('span');
        cursor.classList.add('cursor');
        cursor.classList.add('headline');

        const textContent = document.createElement('span');
        textContent.classList.add('typewriter-text');
        textContent.classList.add('headline');

        typewriter.appendChild(cursor);
        typewriter.appendChild(textContent);

        const measure = typewriter.cloneNode(false) as HTMLElement;
        measure.classList.add('typewriter-measure');
        measure.classList.add('headline');
        measure.removeAttribute('data-text');
        document.body.appendChild(measure);

        type State = 'start' | 'typing' | 'deleting' | 'end';
        let state: State = 'start';
        let index = 0;
        let textIndex = 0;

        function getCurrentText() {
            return texts[textIndex] ?? '';
        }

        function updateTypewriter() {
            const currentText = getCurrentText();
            const visibleText = currentText.slice(0, index + 1);
            measure.textContent = visibleText;
            textContent.textContent = visibleText;

            switch (state) {
                case 'start':
                    textContent.textContent = ' ';
                    measure.textContent = ' ';

                    const range = document.createRange();
                    if (textContent.firstChild) {
                        range.setStart(textContent.firstChild, 0);
                        range.setEnd(textContent.firstChild, 0);
                    }

                    cursor.classList.add('blinking');
                    state = 'typing';
                    setTimeout(updateTypewriter, 1000);
                    break;

                case 'typing':
                    if (textContent.firstChild?.textContent && index <= textContent.firstChild.textContent.length) {
                        const range = document.createRange();
                        const safeIndex = Math.min(index + 1, textContent.firstChild.textContent.length);
                        range.setStart(textContent.firstChild, safeIndex);
                        range.setEnd(textContent.firstChild, safeIndex);

                        const rect = range.getBoundingClientRect();
                        const containerRect = typewriter.getBoundingClientRect();

                        cursor.style.left = `${rect.right - containerRect.left}px`;
                        cursor.style.top = `${rect.top - containerRect.top + (rect.height - cursor.offsetHeight) / 2}px`;
                        cursor.classList.remove('blinking');
                        cursor.classList.add('typing');

                        index++;
                        if (index < currentText.length) {
                            setTimeout(updateTypewriter, 80);
                        } else {
                            state = 'end';
                            setTimeout(updateTypewriter, 1000);
                        }
                    }
                    break;

                case 'deleting':
                    if (textContent.firstChild?.textContent && index >= 0) {
                        const range = document.createRange();
                        const safeIndex = Math.min(index + 1, textContent.firstChild.textContent.length);
                        range.setStart(textContent.firstChild, safeIndex);
                        range.setEnd(textContent.firstChild, safeIndex);

                        const rect = range.getBoundingClientRect();
                        const containerRect = typewriter.getBoundingClientRect();

                        cursor.style.left = `${rect.right - containerRect.left}px`;
                        cursor.style.top = `${rect.top - containerRect.top + (rect.height - cursor.offsetHeight) / 2}px`;
                        cursor.classList.remove('blinking');

                        index--;
                        setTimeout(updateTypewriter, 40);
                    } else {
                        textContent.textContent = ' ';
                        measure.textContent = ' ';
                        if (textContent.firstChild) {
                            const range = document.createRange();
                            range.setStart(textContent.firstChild, 0);
                            range.setEnd(textContent.firstChild, 0);
                            const rect = range.getBoundingClientRect();
                            const containerRect = typewriter.getBoundingClientRect();
                            cursor.style.left = `${rect.left - containerRect.left}px`;
                            cursor.style.top = `${rect.top - containerRect.top + (rect.height - cursor.offsetHeight) / 2}px`;
                        }

                        textIndex = (textIndex + 1) % texts.length;
                        state = 'start';
                        index = 0;
                        cursor.classList.add('blinking');
                        setTimeout(updateTypewriter, 1000);
                    }
                    break;

                case 'end':
                    cursor.classList.add('blinking');
                    state = 'deleting';
                    setTimeout(updateTypewriter, 1000);
                    break;
            }
        }

        updateTypewriter();

    });

</script>

<style lang="scss">
    @keyframes blink {
        0%, 100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }

    :root {
        --v2-fnt-size-h1-xl: 4rem;
        --v2-fnt-size-h1-lg: 3.5rem;
        --v2-fnt-size-h1-md: 2.5rem;
        --v2-fnt-size-h1-sm: 1.75rem;
        --v2-fnt-size-h1: var(--v2-fnt-size-h1-xl);

        @media (max-width: 1440px) { --v2-fnt-size-h1: var(--v2-fnt-size-h1-lg); }
        @media (max-width: 768px) { --v2-fnt-size-h1: var(--v2-fnt-size-h1-md); }
        @media (max-width: 375px) { --v2-fnt-size-h1: var(--v2-fnt-size-h1-sm); }

        --v2-fnt-size-h2-xl: 3.5rem;
        --v2-fnt-size-h2-lg: 3rem;
        --v2-fnt-size-h2-md: 2rem;
        --v2-fnt-size-h2-sm: 1.5rem;
        --v2-fnt-size-h2: var(--v2-fnt-size-h2-xl);

        @media (max-width: 1440px) { --v2-fnt-size-h2: var(--v2-fnt-size-h2-lg); }
        @media (max-width: 768px) { --v2-fnt-size-h2: var(--v2-fnt-size-h2-md); }
        @media (max-width: 375px) { --v2-fnt-size-h2: var(--v2-fnt-size-h2-sm); }

        --v2-fnt-size-h3-xl: 3rem;
        --v2-fnt-size-h3-lg: 2.5rem;
        --v2-fnt-size-h3-md: 2rem;
        --v2-fnt-size-h3-sm: 1.5rem;
        --v2-fnt-size-h3: var(--v2-fnt-size-h3-xl);

        @media (max-width: 1440px) { --v2-fnt-size-h3: var(--v2-fnt-size-h3-lg); }
        @media (max-width: 768px) { --v2-fnt-size-h3: var(--v2-fnt-size-h3-md); }
        @media (max-width: 375px) { --v2-fnt-size-h3: var(--v2-fnt-size-h3-sm); }

        --v2-fnt-size-h4-xl: 2.5rem;
        --v2-fnt-size-h4-lg: 2rem;
        --v2-fnt-size-h4-md: 1.5rem;
        --v2-fnt-size-h4-sm: 1.125rem;
        --v2-fnt-size-h4: var(--v2-fnt-size-h4-xl);

        @media (max-width: 1440px) { --v2-fnt-size-h4: var(--v2-fnt-size-h4-lg); }
        @media (max-width: 768px) { --v2-fnt-size-h4: var(--v2-fnt-size-h4-md); }
        @media (max-width: 375px) { --v2-fnt-size-h4: var(--v2-fnt-size-h4-sm); }
    }

    .headline {
        font-family: 'IBM Plex Mono', monospace;
        font-weight: 700;
        line-height: 1.1;
        color: var(--clr-text-primary);
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    h1.headline { font-size: var(--v2-fnt-size-h1); }
    h2.headline { font-size: var(--v2-fnt-size-h2); }
    h3.headline { font-size: var(--v2-fnt-size-h3); }
    h4.headline { font-size: var(--v2-fnt-size-h4); }
    h5.headline { font-size: 2rem; }
    h6.headline { font-size: 1.5rem; }
    p.headline, span.headline { font-size: 1.5rem; }

    .typewriter {
        text-wrap: wrap;
        white-space: pre-wrap;
        position: relative;
    }

    .typewriter-container {
        position: relative;
        display: grid;
    }

    .typewriter,
    .typewriter-ghost {
        grid-area: 1 / 1;
    }

    .typewriter-ghost {
        visibility: hidden;
        pointer-events: none;
        user-select: none;
    }

    :global(.typewriter-hidden) {
        visibility: hidden;
        pointer-events: none;
        user-select: none;
    }

    :global(.cursor) {
        display: inline-block;
        position: absolute;
        top: 0;
        left: 0;
        width: 2px;
        height: 1em;
        font-size: inherit;
        background-color: var(--clr-accent);
        opacity: 1;
    }

    :global(.cursor.blinking) {
        animation: blink 1s step-end infinite;
    }

    :global(.typewriter-measure) {
        text-wrap: wrap;
        position: absolute;
        visibility: hidden;
        white-space: pre-wrap;
        pointer-events: none;
        z-index: -1;
        display: inline-block;
    }
</style>
