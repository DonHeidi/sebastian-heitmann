<section class="why-me">
    <div class="why-me__title-row">
        <span class="why-me__title-plain">Why </span><span class="why-me__title-accent">Me</span>
    </div>
    <div class="why-me__accent-line"></div>
    <p class="why-me__body">
        I'm not just a consultant who drops in with recommendations and leaves. I embed with your team, understand your challenges from the inside, and build systems that last long after my engagement ends. My approach combines hands-on technical leadership with strategic thinking — giving you a CTO-level partner without the full-time commitment.
    </p>
</section>

<style lang="scss">
    .why-me {
        padding: 96px 144px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;

        &__title-row {
            display: flex;
            flex-direction: row;
            align-items: baseline;
            gap: 8px;
        }

        &__title-plain {
            font-family: 'Anton', sans-serif;
            font-size: 4.5rem;
            color: rgba(42, 42, 60, 0.18);
            line-height: 0.95;
        }

        &__title-accent {
            font-family: 'Anton', sans-serif;
            font-size: 4.5rem;
            font-weight: 700;
            color: var(--clr-magenta);
            line-height: 0.95;
        }

        &__accent-line {
            width: 200px;
            height: 4px;
            border-radius: 2px;
            background: var(--clr-blue);
        }

        &__body {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 16px;
            color: var(--clr-text-primary);
            text-align: center;
            max-width: 620px;
            line-height: 1.7;
        }
    }

    @media (max-width: 1440px) {
        .why-me {
            padding: 96px 80px;
        }
    }

    @media (max-width: 768px) {
        .why-me {
            padding: 96px 2rem;

            &__title-plain,
            &__title-accent {
                font-size: 3rem;
            }

            &__body {
                max-width: 100%;
            }
        }
    }

    @media (max-width: 375px) {
        .why-me {
            padding: 96px 1.25rem;

            &__title-plain,
            &__title-accent {
                font-size: 2rem;
            }
        }
    }
</style>
