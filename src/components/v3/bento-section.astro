---
const companies = [
  { id: 'i22', name: 'i22', role: 'Sr. Agile Project Manager', details: null },
  { id: 'jung-von-matt', name: 'Jung von Matt', role: 'Technical Consultant', details: {
      positions: ['Technical Consultant (Feb 2020 to Mar 2021)', 'Jr. Technical Project Manager (Sep 2019 to Jan 2020)'],
      sections: [{ heading: 'Projects, Tasks, and Tools', items: [
        'Technical support for the development and international rollout of a sales platform in the content management sector',
        'Conception and partial implementation of the migration of the intranet platform as a Product Owner',
        'Gap analysis for the implementation of IT projects',
        'Implementing measures to increase IT satisfaction',
        'General tasks such as documentation, training, and creating presentations',
        'Methods and tools: Scrum, Confluence, Jira, Next.js, Contentful, Keynote',
      ]}],
    }},
  { id: 'datadrivers', name: 'Datadrivers', role: 'Sr. Consultant Project Operations', details: null },
  { id: 'granny-smith', name: 'Granny & Smith', role: 'Technical Consultant', details: null },
  { id: 'offis', name: 'Offis', role: 'Research Assistant', details: null },
  { id: 'pool-position', name: 'Pool Position', role: 'Software Developer', details: null },
  { id: 'syneriax', name: 'SyneriaX', role: 'Project Lead .Net', details: null },
  { id: 'goldkalb', name: 'Goldkalb', role: 'Software Developer', details: null },
];

const voluntaryPositions = [
  { org: 'GMLS Consulting e.V.', role: 'Member of the Advisory Board', period: 'since May 2020', points: ['Sparring partner for development of the club', 'Mediation in internal conflicts within the association'] },
  { org: 'JDNetwork e.V.', role: 'Fellow Software Development', period: 'Oct 2018 to Mar 2020', points: ['Development of a decentralized membership management system'] },
  { org: 'GMLS Consulting e.V.', role: 'Head of Quality & Innovation Management', period: 'Dec 2018 to Apr 2019', points: ['IT Operations (e.g. MS 365 Administration)', 'Developing a strategy for the department'] },
  { org: 'GMLS Consulting e.V.', role: 'Chairman of the Board', period: 'Sep 2017 to Nov 2018', points: ['Maintain partner network', 'Acquisition of projects, work shops, and trainings', 'Development of a vision and strategy for the club', 'Heading internal projects'] },
  { org: 'GMLS Consulting e.V.', role: 'Head of Acquisition & Project Management', period: 'Dec 2016 to Sep 2018', points: ['Acquisition of consulting projects', 'Project Controlling'] },
  { org: 'Municipality of Ritterhude', role: 'Voluntary Social Year', period: 'Aug 2013 to Jul 2014', points: ['Day care in the Werschenrege kindergarten', 'Afternoon care in the Ritterbude primary school'] },
];

const skillCategories = [
  { name: 'Technical Project Management', tags: ['Requirements Engineering', 'Workshop Facilitating', 'Scrum', 'Kanban', 'Design Sprint', 'Jira', 'Confluence', 'MS 365', 'Google Workspace', 'iWork'] },
  { name: 'Software Development', tags: ['Kotlin', 'Java', 'TypeScript', 'JavaScript', 'Next.js', 'React', 'Vert.x', 'WSL 2', 'HTML/CSS', 'Gradle', 'esbuild', 'Design Patterns', 'Maven', 'Contentful', 'Unit Testing', 'AWS'] },
  { name: 'Solution Design', tags: ['Plant UML', 'MVP/MVC', 'API Design', 'openAPI', 'UML', 'SOA', 'Headless', 'Feasibility Analysis', 'graphQL', 'serverless', 'Adobe XD', 'Figma'] },
];

const tagColors = ['magenta', 'blue', 'green'];
---

<section class="bento" id="career">
    <h2 class="bento__title">More About Me</h2>

    <div class="bento__grid">
        <!-- Row 1: Current Occupation (full width) -->
        <div class="bento__card bento__card--occupation">
            <div class="bento__occupation-left">
                <div class="bento__occupation-top">
                    <h3 class="bento__occupation-heading">CURRENT OCCUPATION</h3>
                    <span class="bento__badge bento__badge--magenta">Freelancer</span>
                </div>
                <p class="bento__occupation-desc">
                    Product-obsessed full-stack engineering and team leadership.
                </p>
                <div class="bento__tags">
                    <span class="bento__tag bento__tag--magenta">Software +</span>
                    <span class="bento__tag bento__tag--magenta">Career</span>
                </div>
            </div>
            <div class="bento__occupation-image" aria-hidden="true"></div>
        </div>

        <!-- Row 2: Two columns -->
        <div class="bento__row2">
            <!-- Left column -->
            <div class="bento__col-left">
                <!-- Former Career Card with interactive tabs -->
                <div class="bento__card bento__card--career">
                    <h3 class="bento__card-title">Former Career</h3>
                    <div class="bento__career-layout">
                        <div class="bento__career-tabs">
                            {companies.map((company, i) => (
                                <button class:list={['bento__career-tab', { 'bento__career-tab--active': i === 0 }]} data-target={company.id}>
                                    <span class="bento__career-tab-name">{company.name}</span>
                                    <span class="bento__career-tab-role">{company.role}</span>
                                </button>
                            ))}
                        </div>
                        <div class="bento__career-panels">
                            {companies.map((company, i) => (
                                <div class:list={['bento__career-panel', { 'bento__career-panel--active': i === 0 }]} data-panel={company.id}>
                                    <h4 class="bento__career-panel-name">{company.name}</h4>
                                    <p class="bento__career-panel-role">{company.role}</p>
                                    {company.details ? (
                                        <div class="bento__career-detail">
                                            {company.details.positions.map((pos) => (
                                                <p class="bento__career-position">{pos}</p>
                                            ))}
                                            {company.details.sections.map((section) => (
                                                <div class="bento__career-section">
                                                    <h5 class="bento__career-section-heading">{section.heading}</h5>
                                                    <ul class="bento__career-section-list">
                                                        {section.items.map((item) => (
                                                            <li class="bento__career-section-item">{item}</li>
                                                        ))}
                                                    </ul>
                                                </div>
                                            ))}
                                        </div>
                                    ) : (
                                        <p class="bento__career-placeholder">Details coming soon.</p>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                </div>

                <!-- Skills Card with categories -->
                <div class="bento__card bento__card--skills">
                    <h3 class="bento__card-title">Skills</h3>
                    <div class="bento__skills-categories">
                        {skillCategories.map((cat, ci) => (
                            <div class="bento__skills-category">
                                <h4 class={`bento__skills-cat-name bento__skills-cat-name--${tagColors[ci % 3]}`}>{cat.name}</h4>
                                <div class="bento__tags">
                                    {cat.tags.map((tag, ti) => (
                                        <span class={`bento__tag bento__tag--${tagColors[(ci + ti) % 3]}`}>{tag}</span>
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Right column: Voluntary Card -->
            <div class="bento__card bento__card--voluntary">
                <h3 class="bento__voluntary-title">Voluntary</h3>
                <div class="bento__voluntary-entries">
                    {voluntaryPositions.map((pos, i) => (
                        <>
                            {i === 4 && <hr class="bento__voluntary-separator" />}
                            <div class="bento__voluntary-entry">
                                <span class="bento__voluntary-org">{pos.org}</span>
                                <p class="bento__voluntary-role">{pos.role}</p>
                                <span class="bento__voluntary-period">{pos.period}</span>
                                <ul class="bento__voluntary-points">
                                    {pos.points.map((point) => (
                                        <li class="bento__voluntary-point">{point}</li>
                                    ))}
                                </ul>
                            </div>
                        </>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<script>
  const tabs = document.querySelectorAll('.bento__career-tab');
  const panels = document.querySelectorAll('.bento__career-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.target;
      tabs.forEach((t) => t.classList.remove('bento__career-tab--active'));
      panels.forEach((p) => p.classList.remove('bento__career-panel--active'));
      tab.classList.add('bento__career-tab--active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('bento__career-panel--active');
    });
  });
</script>

<style lang="scss">
    .bento {
        padding: 96px 144px;
        display: flex;
        flex-direction: column;
        gap: 48px;

        &__title {
            font-family: 'Anton', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            color: var(--clr-text-primary);
            letter-spacing: -1px;
        }

        &__grid {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        // Base card styles
        &__card {
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-dark);
            border-radius: 12px;
            overflow: hidden;
            backdrop-filter: blur(24px);
        }

        // Row 1: Current Occupation
        &__card--occupation {
            display: flex;
            flex-direction: row;
            height: 300px;
        }

        &__occupation-left {
            flex: 1;
            padding: 28px 32px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        &__occupation-top {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        &__occupation-heading {
            font-family: 'Anton', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--clr-white);
            line-height: 1.1;
        }

        &__occupation-desc {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.5;
        }

        &__occupation-image {
            width: 461px;
            height: 100%;
            background: linear-gradient(135deg, #2a1040 0%, #1a0828 30%, #0a1028 70%, #041020 100%);
            flex-shrink: 0;
        }

        // Row 2 layout
        &__row2 {
            display: flex;
            flex-direction: row;
            gap: 20px;
        }

        &__col-left {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        // Former Career
        &__card--career {
            padding: 32px 28px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        &__card-title {
            font-family: 'Anton', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--clr-magenta);
            line-height: 1.1;
        }

        &__career-layout {
            display: grid;
            grid-template-columns: 180px 1fr;
            gap: 1.5rem;
            flex: 1;
            min-height: 0;
        }

        &__career-tabs {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            overflow-y: auto;
        }

        &__career-tab {
            display: flex;
            flex-direction: column;
            gap: 2px;
            padding: 0.5rem 0.75rem;
            background: none;
            border: none;
            border-left: 3px solid transparent;
            cursor: pointer;
            text-align: left;
            transition: border-color 0.2s ease, background-color 0.2s ease;
            border-radius: 0 4px 4px 0;

            &:hover { background-color: rgba(255, 255, 255, 0.04); }
            &--active {
                border-left-color: var(--clr-magenta);
                background-color: rgba(255, 255, 255, 0.06);
            }
        }

        &__career-tab-name {
            font-family: 'AntonSC', sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            line-height: 1;
            color: var(--clr-green);
        }

        &__career-tab-role {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.625rem;
            line-height: 1.3;
            color: rgba(255, 255, 255, 0.5);
        }

        &__career-panels { overflow-y: auto; }

        &__career-panel {
            display: none;
            flex-direction: column;
            gap: 0.75rem;
            &--active { display: flex; }
        }

        &__career-panel-name {
            font-family: 'AntonSC', sans-serif;
            font-size: 1.25rem;
            font-weight: 500;
            line-height: 1;
            color: var(--clr-green);
        }

        &__career-panel-role {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.6);
        }

        &__career-position {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.75rem;
            line-height: 1.4;
            color: var(--clr-text-primary);
            padding-left: 1rem;
            position: relative;
            &::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0.35em;
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background-color: var(--clr-magenta);
            }
        }

        &__career-detail {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 0.5rem;
        }

        &__career-section-heading {
            font-family: 'AntonSC', sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            line-height: 1;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        &__career-section-list {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0.375rem;
        }

        &__career-section-item {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.75rem;
            line-height: 1.4;
            color: var(--clr-text-primary);
        }

        &__career-placeholder {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.4);
            font-style: italic;
        }

        // Skills
        &__card--skills {
            padding: 32px 28px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        &__skills-categories {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        &__skills-cat-name {
            font-family: 'AntonSC', sans-serif;
            font-size: 0.875rem;
            font-weight: 400;
            line-height: 1;
            margin-bottom: 0.5rem;
            &--magenta { color: var(--clr-magenta); }
            &--blue { color: var(--clr-blue); }
            &--green { color: var(--clr-green); }
        }

        // Right column: Voluntary
        &__card--voluntary {
            width: 470px;
            flex-shrink: 0;
            padding: 28px 24px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-self: stretch;
        }

        &__voluntary-title {
            font-family: 'Anton', sans-serif;
            font-size: 32px;
            font-weight: 700;
            color: #F5C518;
            line-height: 1.1;
        }

        &__voluntary-entries {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        &__voluntary-entry {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        &__voluntary-org {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.625rem;
            color: rgba(255, 255, 255, 0.5);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        &__voluntary-role {
            font-family: 'AntonSC', sans-serif;
            font-size: 1rem;
            font-weight: 500;
            color: var(--clr-green);
            line-height: 1.2;
        }

        &__voluntary-period {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.625rem;
            color: rgba(255, 255, 255, 0.4);
        }

        &__voluntary-points {
            list-style: none;
            padding: 0;
            margin-top: 0.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        &__voluntary-point {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.75rem;
            line-height: 1.4;
            color: var(--clr-text-primary);
            padding-left: 1rem;
            position: relative;
            &::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0.35em;
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background-color: var(--clr-magenta);
            }
        }

        &__voluntary-separator {
            border: none;
            border-top: 2px solid rgba(255, 255, 255, 0.08);
            width: 60px;
            margin: 0;
        }

        // Tags
        &__tags {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 8px;
        }

        &__tag {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 12px;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 100vh;
            line-height: 1;
        }

        &__tag--magenta {
            background: rgba(255, 0, 123, 0.12);
            color: var(--clr-magenta);
        }

        &__tag--blue {
            background: rgba(0, 183, 255, 0.12);
            color: var(--clr-blue);
        }

        &__tag--green {
            background: rgba(0, 224, 142, 0.12);
            color: var(--clr-green);
        }

        &__tag--filled-magenta {
            background: rgba(255, 0, 123, 0.22);
            color: var(--clr-magenta);
        }

        &__tag--filled-blue {
            background: rgba(0, 183, 255, 0.22);
            color: var(--clr-blue);
        }

        &__tag--filled-green {
            background: rgba(0, 224, 142, 0.22);
            color: var(--clr-green);
        }

        // Badges
        &__badge {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 100vh;
        }

        &__badge--magenta {
            background: rgba(255, 0, 123, 0.15);
            color: var(--clr-magenta);
        }
    }

    @media (max-width: 1440px) {
        .bento {
            padding: 96px 80px;
        }
    }

    @media (max-width: 768px) {
        .bento {
            padding: 96px 2rem;

            &__card--occupation {
                flex-direction: column;
                height: auto;
            }

            &__occupation-left {
                gap: 20px;
            }

            &__occupation-image {
                width: 100%;
                height: 200px;
            }

            &__row2 {
                flex-direction: column;
            }

            &__card--voluntary {
                width: 100%;
            }

            &__career-layout {
                grid-template-columns: 1fr;
            }

            &__career-tabs {
                flex-direction: row;
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            &__career-tab {
                border-left: none;
                border-bottom: 2px solid transparent;
                border-radius: 4px;
                padding: 0.375rem 0.625rem;
                &--active { border-bottom-color: var(--clr-magenta); }
            }
        }
    }

    @media (max-width: 375px) {
        .bento {
            padding: 64px 1.25rem;
            gap: 32px;

            &__title {
                font-size: 2rem;
            }

            &__occupation-heading,
            &__card-title {
                font-size: 22px;
            }

            &__voluntary-title {
                font-size: 24px;
            }
        }
    }
</style>
