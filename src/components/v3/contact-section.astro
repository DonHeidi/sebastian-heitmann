---
import { Icon } from 'astro-icon/components';
---

<section class="contact reveal" id="contact">
    <div class="contact__header">
        <h2 class="contact__title">Let's Talk</h2>
        <p class="contact__subtitle">Tell me about your project and I'll get back to you within 24 hours with an honest assessment of how I can help.</p>
    </div>

    <form class="contact__form" action="#" method="POST">
        <div class="contact__row">
            <div class="contact__field">
                <label class="contact__label" for="v3-contact-name">NAME *</label>
                <input class="contact__input" type="text" id="v3-contact-name" name="name" placeholder="Your full name" required />
            </div>
            <div class="contact__field">
                <label class="contact__label" for="v3-contact-email">EMAIL *</label>
                <input class="contact__input" type="email" id="v3-contact-email" name="email" placeholder="your@email.com" required />
            </div>
        </div>

        <div class="contact__row">
            <div class="contact__field">
                <label class="contact__label" for="v3-contact-company">COMPANY</label>
                <input class="contact__input" type="text" id="v3-contact-company" name="company" placeholder="Your company" />
            </div>
            <div class="contact__field">
                <label class="contact__label" for="v3-contact-plan">PLAN</label>
                <div class="contact__select-wrapper">
                    <select class="contact__select" id="v3-contact-plan" name="plan">
                        <option value="" disabled selected>Select a plan</option>
                        <option value="hourly">Hourly Based Consulting</option>
                        <option value="prototype">Fixed Prototype Iterations</option>
                        <option value="retainer">Monthly CTO Retainer</option>
                        <option value="unsure">Not sure yet</option>
                    </select>
                    <Icon name="mdi:chevron-down" class="contact__select-icon" width={20} height={20} />
                </div>
            </div>
        </div>

        <div class="contact__field">
            <label class="contact__label" for="v3-contact-message">MESSAGE *</label>
            <textarea class="contact__textarea" id="v3-contact-message" name="message" placeholder="Tell me about your project..." required></textarea>
        </div>

        <button type="submit" class="contact__submit">SEND_MSG</button>
    </form>
</section>

<style lang="scss">
    .contact {
        padding: 80px 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 32px;

        &__header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            text-align: center;
        }

        &__title {
            font-family: 'Rajdhani', sans-serif;
            font-size: 4rem;
            font-weight: 700;
            color: var(--clr-yellow);
            text-transform: uppercase;
            letter-spacing: 0.02em;
            line-height: 1;
        }

        &__subtitle {
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.4);
            max-width: 480px;
            line-height: 1.7;
        }

        &__form {
            display: flex;
            flex-direction: column;
            gap: 16px;
            width: 100%;
            max-width: 820px;
        }

        &__row { display: flex; gap: 16px; }

        &__field { display: flex; flex-direction: column; gap: 6px; flex: 1; }

        &__label {
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.6875rem;
            font-weight: 700;
            color: var(--clr-yellow);
            letter-spacing: 0.15em;
        }

        &__input {
            height: 44px;
            padding: 0 16px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(252, 227, 0, 0.12);
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;

            &::placeholder { color: rgba(255, 255, 255, 0.25); }
            &:focus { border-color: var(--clr-yellow); }
        }

        &__select-wrapper { position: relative; display: flex; align-items: center; }

        &__select {
            height: 44px;
            padding: 0 16px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(252, 227, 0, 0.12);
            color: rgba(255, 255, 255, 0.25);
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            outline: none;
            appearance: none;
            -webkit-appearance: none;
            width: 100%;
            cursor: pointer;
            transition: border-color 0.2s;

            option { background: #0a0a0a; color: #fff; }
            &:focus { border-color: var(--clr-yellow); }
        }

        &__select-icon {
            position: absolute;
            right: 12px;
            pointer-events: none;
            color: rgba(255, 255, 255, 0.25);
        }

        &__textarea {
            height: 120px;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(252, 227, 0, 0.12);
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            outline: none;
            resize: vertical;
            line-height: 1.6;
            transition: border-color 0.2s;

            &::placeholder { color: rgba(255, 255, 255, 0.25); }
            &:focus { border-color: var(--clr-yellow); }
        }

        &__submit {
            width: fit-content;
            align-self: center;
            padding: 14px 48px;
            background: var(--clr-yellow);
            border: none;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            color: var(--clr-bg-primary);
            cursor: pointer;
            clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
            transition: background-color 0.15s ease;

            &:hover { background: var(--clr-cyan); }
        }
    }

    @media (max-width: 1440px) { .contact { padding: 80px 80px; } }

    @media (max-width: 768px) {
        .contact {
            padding: 96px 2rem;
            &__row { flex-direction: column; }
            &__title { font-size: 3rem; }
        }
    }

    @media (max-width: 375px) {
        .contact { padding: 64px 1.25rem; &__title { font-size: 2.25rem; } }
    }
</style>
