---
import { Icon } from 'astro-icon/components';
---

<footer class="footer">
    <div class="footer__top">
        <div class="footer__brand">
            <p class="footer__logo">sebastian-heitmann.dev</p>
            <p class="footer__tagline">// FRACTIONAL CTO & PRODUCT ENGINEER</p>
        </div>

        <div class="footer__links">
            <a class="footer__link" href="#services">Services</a>
            <a class="footer__link" href="#process">Process</a>
            <a class="footer__link" href="#work">Results</a>
            <a class="footer__link" href="#contact">Contact</a>
        </div>

        <div class="footer__socials">
            <a class="footer__social-link" href="https://linkedin.com/in/sebastian-heitmann" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <Icon name="simple-icons:linkedin" width={20} height={20} />
            </a>
            <a class="footer__social-link" href="https://github.com/sebastian-heitmann" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <Icon name="simple-icons:github" width={20} height={20} />
            </a>
            <a class="footer__social-link" href="https://bsky.app/profile/sebastian-heitmann.dev" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                <Icon name="simple-icons:bluesky" width={18} height={18} />
            </a>
        </div>
    </div>

    <hr class="footer__divider" />

    <div class="footer__bottom">
        <p class="footer__copyright">&copy; 2026 Sebastian Heitmann. All rights reserved.</p>
        <div class="footer__legal">
            <a class="footer__legal-link" href="/privacy">Privacy Policy</a>
            <a class="footer__legal-link" href="/imprint">Imprint</a>
        </div>
        <p class="footer__access">ACCESS_GRANTED</p>
    </div>
</footer>

<style lang="scss">
    .footer {
        padding: 48px 144px 32px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        border-top: 2px solid var(--clr-yellow);

        &__top {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            justify-content: space-between;
            gap: 2rem;
        }

        &__brand { display: flex; flex-direction: column; gap: 4px; }

        &__logo {
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--clr-yellow);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        &__tagline {
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.6875rem;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.3);
            letter-spacing: 0.1em;
        }

        &__links { display: flex; gap: 2rem; }

        &__link {
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.8125rem;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.4);
            text-decoration: none;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            transition: color 0.15s ease;
            &:hover { color: var(--clr-cyan); }
        }

        &__socials { display: flex; align-items: center; gap: 16px; }

        &__social-link {
            color: rgba(255, 255, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: color 0.15s ease;
            &:hover { color: var(--clr-cyan); }
        }

        &__divider { border: none; border-top: 1px solid rgba(252, 227, 0, 0.08); margin: 0; }

        &__bottom {
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
        }

        &__copyright {
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.25);
        }

        &__legal { display: flex; gap: 1.5rem; }

        &__legal-link {
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.25);
            text-decoration: none;
            transition: color 0.15s ease;
            &:hover { color: rgba(255, 255, 255, 0.5); }
        }

        &__access {
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.625rem;
            font-weight: 700;
            color: var(--clr-cyan);
            letter-spacing: 0.15em;
            opacity: 0.4;
        }
    }

    @media (max-width: 1440px) { .footer { padding: 48px 80px 32px; } }

    @media (max-width: 768px) {
        .footer {
            padding: 40px 2rem 28px;
            &__top { flex-direction: column; gap: 1.5rem; }
            &__bottom { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        }
    }

    @media (max-width: 375px) {
        .footer { padding: 32px 1.25rem 24px; &__links { flex-wrap: wrap; gap: 1rem 1.5rem; } }
    }
</style>
