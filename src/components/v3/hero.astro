---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import picture from '../../assets/fb.jpg';
---

<section class="hero reveal">
    <div class="hero-scanline"></div>

    <p class="hero-overline">
        <span class="overline-plain">I turn </span><span class="overline-yellow">outgrown processes</span><span class="overline-plain"> into </span><span class="overline-cyan">systems that scale</span><span class="overline-plain">.</span>
    </p>

    <div class="hero-main">
        <div class="hero-left">
            <div class="hero-headline-group">
                <h1 class="hero-headline">Sebastian<br/>Heitmann</h1>
                <p class="hero-positioning">Fractional CTO & Product Engineer</p>
            </div>

            <div class="hero-body">
                <p class="hero-body-text">I help founders and product teams turn ambiguity into working software and scalable operations — without the overhead of a full-time CTO.</p>
            </div>

            <div class="hero-stats">
                <div class="hero-stats__item">
                    <span class="hero-stats__number">10+</span>
                    <span class="hero-stats__label">YRS_EXP</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number">50+</span>
                    <span class="hero-stats__label">PROJECTS</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number">8</span>
                    <span class="hero-stats__label">SECTORS</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number">3</span>
                    <span class="hero-stats__label">REGIONS</span>
                </div>
            </div>

            <div class="hero-cta-row">
                <a class="hero-cta-primary" href="#contact">Book a Discovery Call</a>
                <a class="hero-cta-secondary" href="#services">See how I work &rarr;</a>
            </div>
        </div>

        <aside class="hero-aside">
            <div class="hero-aside__frame">
                <Image
                    loading="eager"
                    class="hero-aside__photo"
                    src={picture}
                    alt="Sebastian Heitmann"
                    width={260}
                    height={320}
                />
                <div class="hero-aside__tag">NETRUNNER // ONLINE</div>
            </div>
            <div class="hero-aside__icons">
                <a href="https://www.linkedin.com/in/don-heidmann/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <Icon name="simple-icons:linkedin" width={28} height={28} />
                </a>
                <a href="https://github.com/DonHeidi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    <Icon name="simple-icons:github" width={28} height={28} />
                </a>
                <a href="https://www.bluesky.com/e2e_developer" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                    <Icon name="simple-icons:bluesky" width={24} height={24} />
                </a>
            </div>
        </aside>
    </div>
</section>

<style lang="scss">
    @keyframes scanline {
        0% { top: -5%; }
        100% { top: 105%; }
    }

    .hero {
        padding: 3rem 144px 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        position: relative;
        overflow: hidden;

        &-scanline {
            position: absolute;
            top: -5%;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--clr-cyan), transparent);
            opacity: 0.15;
            animation: scanline 8s linear infinite;
            pointer-events: none;
            z-index: 1;
        }

        &-overline {
            display: flex;
            flex-wrap: wrap;
            gap: 0 4px;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.375rem;
            font-weight: 400;
            line-height: 1.6;

            .overline-plain { color: rgba(255, 255, 255, 0.7); }
            .overline-yellow { color: var(--clr-yellow); font-weight: 700; }
            .overline-cyan { color: var(--clr-cyan); font-weight: 700; }
        }

        &-main {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            gap: 5rem;
        }

        &-left {
            flex: 0 1 auto;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        &-headline-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        &-headline {
            font-family: 'Rajdhani', sans-serif;
            font-size: clamp(3.5rem, 6vw, 5.5rem);
            font-weight: 700;
            color: var(--clr-yellow);
            letter-spacing: 0.02em;
            line-height: 0.95;
            text-transform: uppercase;
        }

        &-positioning {
            font-family: 'Rajdhani', sans-serif;
            font-size: clamp(1.25rem, 2vw, 1.75rem);
            font-weight: 400;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.3;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        &-body-text {
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.1875rem;
            color: rgba(255, 255, 255, 0.65);
            line-height: 1.7;
            max-width: 520px;
        }

        &-stats {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 1.5rem;
            margin-top: 0.5rem;
            padding: 1rem 1.25rem;
            background: rgba(252, 227, 0, 0.03);
            border-left: 3px solid var(--clr-yellow);

            &__item {
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }

            &__number {
                font-family: 'Rajdhani', sans-serif;
                font-size: 2.25rem;
                font-weight: 700;
                line-height: 1;
                color: var(--clr-yellow);
            }

            &__label {
                font-family: 'Rajdhani', sans-serif;
                font-size: 0.6875rem;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.35);
                letter-spacing: 0.12em;
            }

            &__divider {
                width: 1px;
                height: 32px;
                background: rgba(252, 227, 0, 0.15);
                flex-shrink: 0;
            }
        }

        &-cta-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.5rem;
        }

        &-cta-primary {
            text-decoration: none;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--clr-bg-primary);
            background: var(--clr-yellow);
            padding: 0.875rem 2rem;
            clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
            transition: background-color 0.15s ease;

            &:hover {
                background: var(--clr-cyan);
            }
        }

        &-cta-secondary {
            text-decoration: none;
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.9375rem;
            font-weight: 400;
            color: rgba(255, 255, 255, 0.45);
            transition: color 0.15s ease;

            &:hover {
                color: var(--clr-cyan);
            }
        }

        &-aside {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.25rem;

            &__frame {
                position: relative;
                border: 2px solid var(--clr-yellow);
                clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
                overflow: hidden;
            }

            &__photo {
                display: block;
                width: 220px;
                height: 280px;
                object-fit: cover;
                filter: saturate(0.3) contrast(1.2) brightness(0.9);
                mix-blend-mode: normal;
            }

            &__tag {
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                background: rgba(252, 227, 0, 0.9);
                color: var(--clr-bg-primary);
                font-family: 'Rajdhani', sans-serif;
                font-size: 0.625rem;
                font-weight: 700;
                letter-spacing: 0.15em;
                text-align: center;
                padding: 4px 0;
            }

            &__icons {
                display: flex;
                flex-direction: row;
                gap: 1rem;

                a {
                    color: rgba(255, 255, 255, 0.35);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                    transition: color 0.15s ease;

                    &:hover { color: var(--clr-cyan); }

                    :global(svg) {
                        color: inherit;
                        fill: currentColor;
                    }
                }
            }
        }
    }

    @media (max-width: 1440px) {
        .hero { padding: 3rem 80px 4rem; }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 2rem;

            &-headline { font-size: 3rem; }

            &-main { flex-direction: column; }

            &-left { width: 100%; }

            &-stats { gap: 1.25rem; &__number { font-size: 1.75rem; } }

            &-aside { margin-top: 2rem; &__photo { width: 160px; height: 200px; } }
        }
    }

    @media (max-width: 375px) {
        .hero {
            padding: 1.25rem;
            &-headline { font-size: 2.5rem; }
            &-overline { font-size: 1rem; }
            &-cta-row { flex-direction: column; align-items: flex-start; gap: 1rem; }
            &-stats {
                display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem;
                &__item:nth-child(n+5) { grid-column: 1; }
                &__divider:nth-of-type(2) { display: none; }
            }
        }
    }
</style>
