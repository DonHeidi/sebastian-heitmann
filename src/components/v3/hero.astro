---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import picture from '../../assets/fb.jpg';
---

<section class="hero">
    <p class="hero-overline">
        <span class="overline-plain">I build </span><span class="overline-magenta">products</span><span class="overline-plain">. I lead </span><span class="overline-blue">teams</span><span class="overline-plain">. I solve </span><span class="overline-green">problems</span><span class="overline-plain">.</span>
    </p>

    <div class="hero-main">
        <div class="hero-left">
            <div class="hero-headline-group">
                <h1 class="hero-headline">Sebastian Heitmann</h1>
                <p class="hero-positioning">Fractional CTO & Product Engineer</p>
            </div>

            <div class="hero-body">
                <p class="hero-body-text">From scale-ups to B2B SaaS founders, I help teams grow through smart software and strong operations.</p>
                <p class="hero-body-text">With 10+ years of experience across industries and company sizes, I bring structure, speed, and clarity to complex challenges.</p>
            </div>
            <div class="hero-cta-row">
                <a class="hero-cta-primary" href="#contact">Book a Discovery Call</a>
                <a class="hero-cta-secondary" href="#services">See how I work →</a>
            </div>
        </div>

        <aside class="hero-aside">
            <div class="hero-aside__social">
                <Image
                    loading="eager"
                    class="hero-aside__photo"
                    src={picture}
                    alt="Sebastian Heitmann"
                    width={260}
                    height={320}
                />
                <div class="hero-aside__icons">
                    <a id="linkedin" href="https://www.linkedin.com/in/don-heidmann/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <Icon name="simple-icons:linkedin" width={32} height={32} />
                    </a>
                    <a id="github" href="https://github.com/DonHeidi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                        <Icon name="simple-icons:github" width={32} height={32} />
                    </a>
                    <a id="bluesky" href="https://www.bluesky.com/e2e_developer" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                        <Icon name="simple-icons:bluesky" width={28} height={28} />
                    </a>
                </div>
            </div>
        </aside>
    </div>
</section>

<style lang="scss">
    .hero {
        min-height: 56.25rem;
        padding: 3.75rem 144px 5rem 144px;
        display: flex;
        flex-direction: column;
        gap: 2.5rem;

        &-overline {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: baseline;
            gap: 0 4px;
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 1.5rem;
            line-height: 1.5;

            .overline-plain {
                color: var(--clr-text-primary);
            }

            .overline-magenta {
                color: var(--clr-magenta);
                font-weight: 700;
            }

            .overline-blue {
                color: var(--clr-blue);
                font-weight: 700;
            }

            .overline-green {
                color: var(--clr-green);
                font-weight: 700;
            }
        }

        &-main {
            flex: 1;
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            gap: 4rem;
        }

        &-headline-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        &-headline {
            font-family: 'Anton', sans-serif;
            font-size: clamp(3rem, 5vw, 5rem);
            font-weight: 700;
            color: var(--clr-text-primary);
            letter-spacing: -2px;
            line-height: 1;
            white-space: nowrap;
        }

        &-positioning {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: clamp(1.5rem, 2.5vw, 3rem);
            font-weight: 300;
            color: var(--clr-text-primary);
            line-height: 1.2;
        }

        &-left {
            flex: 0 1 520px;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        &-body {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        &-body-text {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 1.125rem;
            color: rgba(231, 229, 219, 0.75);
            line-height: 1.65;
        }

        &-cta-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.75rem;
        }

        &-cta-primary {
            text-decoration: none;
            font-family: 'Anton', sans-serif;
            font-size: 1.125rem;
            line-height: 1;
            color: var(--clr-white);
            background-color: var(--clr-bg-surface);
            border: 1.5px solid var(--clr-text-primary);
            border-radius: 100vh;
            padding: 1rem 2.5rem;
            backdrop-filter: blur(10px);
            transition:
                background-color 0.2s ease,
                border-color 0.2s ease;

            &:hover {
                background-color: var(--clr-text-primary);
                color: #111222;
            }
        }

        &-cta-secondary {
            text-decoration: none;
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--clr-text-primary);
            transition: opacity 0.2s ease;

            &:hover {
                opacity: 0.7;
            }
        }

        &-aside {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            gap: 0;
            position: relative;
            top: -32px;

            &__social {
                display: flex;
                flex-direction: row;
                align-items: center;
                gap: 2rem;
            }

            &__photo {
                display: block;
                flex: 0 0 auto;
                width: 260px;
                height: 320px;
                border-radius: 24px;
                object-fit: cover;
                transform: rotate(-7deg);
                box-shadow:
                    0 8px 32px rgba(0, 0, 0, 0.3),
                    0 0 0 1px rgba(255, 255, 255, 0.06);
            }

            &__icons {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 1rem;

                a {
                    color: var(--clr-text-primary);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                    transition: opacity 0.2s ease;

                    &:hover {
                        opacity: 0.7;
                    }

                    :global(svg) {
                        color: var(--clr-text-primary);
                        fill: var(--clr-text-primary);
                    }
                }

                #linkedin {
                    rotate: -7deg;
                }

                #github {
                    rotate: 10deg;
                }

                #bluesky {
                    rotate: -4deg;
                }
            }
        }
    }

    @media (max-width: 1440px) {
        .hero {
            padding: 3.75rem 80px 5rem 80px;
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 2rem;
            min-height: auto;

            &-headline {
                font-size: 3rem;
                letter-spacing: -1px;
                white-space: normal;
            }

            &-positioning {
                font-size: 1.5rem;
            }

            &-main {
                flex-direction: column;
            }

            &-left {
                width: 100%;
            }

            &-aside {
                margin-top: 2rem;

                &__social {
                    justify-content: flex-start;
                }

                &__photo {
                    width: 180px;
                    height: 220px;
                    border-radius: 16px;
                }
            }
        }
    }

    @media (max-width: 375px) {
        .hero {
            padding: 1.25rem;

            &-headline {
                font-size: 2.5rem;
                letter-spacing: -0.5px;
            }

            &-positioning {
                font-size: 1.25rem;
            }

            &-overline {
                font-size: 1rem;
            }

            &-cta-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            &-aside {
                &__photo {
                    width: 140px;
                    height: 170px;
                    border-radius: 12px;
                }
            }
        }
    }
</style>
