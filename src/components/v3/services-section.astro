---
const services = [
    {
        title: 'Strategy & Advisory',
        accent: 'var(--clr-magenta)',
        description: 'For founders and leadership teams who need technical clarity before committing to a direction.',
        bullets: [
            'Technical due diligence',
            'Architecture assessment',
            'Build vs. buy analysis',
            'Product roadmap review',
        ],
        idealFor: 'Ideal for: Pre-investment, pivot decisions, scaling planning',
    },
    {
        title: 'Product & Engineering',
        accent: 'var(--clr-blue)',
        description: 'For teams that need hands-on product leadership and engineering execution.',
        bullets: [
            'Full-stack development',
            'Team setup & mentoring',
            'Sprint planning & delivery',
            'CI/CD & DevOps',
        ],
        idealFor: 'Ideal for: MVPs, rebuilds, team augmentation',
    },
    {
        title: 'Operations & Scale',
        accent: 'var(--clr-green)',
        description: 'For growing companies that need structure, process, and technical operations at scale.',
        bullets: [
            'Engineering process design',
            'Hiring & onboarding',
            'Performance monitoring',
            'Incident management',
        ],
        idealFor: 'Ideal for: Series A+, scaling teams, post-launch',
    },
];
---

<section class="services" id="services">
    <div class="services__header">
        <p class="services__overline">
            <span class="services__overline-plain">What I </span><span class="services__overline-accent">offer</span>
        </p>
        <h2 class="services__headline">My Services</h2>
        <p class="services__description">From early-stage product discovery to scaling engineering organisations — I provide hands-on technical leadership tailored to where your business is today and where it needs to go.</p>
    </div>

    <div class="services__cards">
        {services.map((service) => (
            <div class="services__card">
                <div class="services__card-accent" style={`background: ${service.accent};`}></div>
                <h3 class="services__card-title">{service.title}</h3>
                <p class="services__card-description">{service.description}</p>
                <ul class="services__card-bullets">
                    {service.bullets.map((bullet) => (
                        <li class="services__card-bullet" style={`--accent: ${service.accent};`}>
                            {bullet}
                        </li>
                    ))}
                </ul>
                <p class="services__card-ideal">{service.idealFor}</p>
            </div>
        ))}
    </div>
</section>

<style lang="scss">
    .services {
        display: flex;
        flex-direction: column;
        padding: 96px 144px;

        &__header {
            max-width: 560px;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 3rem;
        }

        &__overline {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 20px;
            color: var(--clr-text-primary);
        }

        &__overline-plain {
            color: var(--clr-text-primary);
        }

        &__overline-accent {
            font-weight: 700;
            color: var(--clr-blue);
        }

        &__headline {
            font-family: 'Anton', sans-serif;
            font-size: 4.5rem;
            color: var(--clr-text-primary);
            letter-spacing: -1.5px;
            line-height: 0.95;
        }

        &__description {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 16px;
            color: var(--clr-text-muted);
            line-height: 1.6;
            max-width: 500px;
        }

        &__cards {
            display: flex;
            flex-direction: row;
            gap: 24px;
        }

        &__card {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-dark);
            backdrop-filter: blur(14px);
            border-radius: 12px;
            padding: 32px 28px;
        }

        &__card-accent {
            width: 40px;
            height: 3px;
            border-radius: 2px;
            flex-shrink: 0;
        }

        &__card-title {
            font-family: 'Anton', sans-serif;
            font-size: 1.5rem;
            color: var(--clr-white);
            letter-spacing: -0.5px;
            line-height: 1.1;
        }

        &__card-description {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.9375rem;
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.6;
        }

        &__card-bullets {
            list-style: none;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        &__card-bullet {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.5);
            padding-left: 1rem;
            position: relative;

            &::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: var(--accent);
            }
        }

        &__card-ideal {
            font-family: 'SpaceGrotesk', sans-serif;
            font-size: 0.8125rem;
            font-style: italic;
            color: rgba(255, 255, 255, 0.4);
            margin-top: auto;
            padding-top: 0.5rem;
        }
    }

    @media (max-width: 1440px) {
        .services {
            padding: 96px 80px;
        }
    }

    @media (max-width: 768px) {
        .services {
            padding: 96px 2rem 48px 2rem;

            &__header {
                max-width: 100%;
            }

            &__headline {
                font-size: 3rem;
            }

            &__cards {
                flex-direction: column;
            }
        }
    }

    @media (max-width: 375px) {
        .services {
            padding: 96px 1.25rem 48px 1.25rem;
        }
    }
</style>
