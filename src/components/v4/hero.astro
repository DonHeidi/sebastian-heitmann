---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import picture from '../../assets/fb.jpg';
---

<section class="hero reveal">
    <div class="hero-content">
        <div class="hero-left">
            <p class="hero-overline">
                <span class="overline-plain">I turn </span><span class="overline-accent">outgrown processes</span><span class="overline-plain"> into </span><span class="overline-accent">systems that scale</span><span class="overline-plain">.</span>
            </p>

            <div class="hero-headline-group">
                <h1 class="hero-headline">Sebastian Heitmann</h1>
                <div class="hero-accent-rule"></div>
                <p class="hero-positioning">Fractional CTO & Product Engineer</p>
            </div>

            <div class="hero-body">
                <p class="hero-body-text">I help founders and product teams turn ambiguity into working software and scalable operations — without the overhead of a full-time CTO.</p>
            </div>

            <div class="hero-stats">
                <div class="hero-stats__item">
                    <span class="hero-stats__number hero-stats__number--accent">10+</span>
                    <span class="hero-stats__label">Years in Tech</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number">50+</span>
                    <span class="hero-stats__label">Projects Delivered</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number">8</span>
                    <span class="hero-stats__label">Industries</span>
                </div>
                <div class="hero-stats__divider"></div>
                <div class="hero-stats__item">
                    <span class="hero-stats__number">3</span>
                    <span class="hero-stats__label">Countries</span>
                </div>
            </div>

            <div class="hero-cta-row">
                <a class="hero-cta-primary" href="#contact">Book a Discovery Call</a>
                <a class="hero-cta-secondary" href="#services">See how I work →</a>
            </div>
        </div>

        <aside class="hero-aside">
            <Image
                loading="eager"
                class="hero-aside__photo"
                src={picture}
                alt="Sebastian Heitmann"
                width={280}
                height={340}
            />
            <div class="hero-aside__icons">
                <a href="https://www.linkedin.com/in/don-heidmann/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <Icon name="simple-icons:linkedin" width={28} height={28} />
                </a>
                <a href="https://github.com/DonHeidi" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    <Icon name="simple-icons:github" width={28} height={28} />
                </a>
                <a href="https://www.bluesky.com/e2e_developer" target="_blank" rel="noopener noreferrer" aria-label="Bluesky">
                    <Icon name="simple-icons:bluesky" width={24} height={24} />
                </a>
            </div>
        </aside>
    </div>
</section>

<style lang="scss">
    .hero {
        padding: 3.75rem 144px 4rem 144px;

        &-content {
            display: grid;
            grid-template-columns: 1fr 340px;
            column-gap: 80px;
            align-items: center;
        }

        &-left {
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        &-overline {
            font-family: 'Libre Baskerville', serif;
            font-size: 20px;
            line-height: 1.5;
            color: var(--clr-text-primary);

            .overline-plain {
                color: var(--clr-text-primary);
            }

            .overline-accent {
                color: var(--clr-accent);
                font-weight: 700;
            }
        }

        &-headline-group {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        &-headline {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 96px;
            font-weight: 400;
            line-height: 0.95;
            letter-spacing: -1px;
            color: var(--clr-text-primary);
        }

        &-accent-rule {
            width: 40px;
            height: 3px;
            background: var(--clr-accent);
        }

        &-positioning {
            font-family: 'Libre Baskerville', serif;
            font-style: italic;
            font-size: 24px;
            color: var(--clr-text-muted);
            line-height: 1.3;
        }

        &-body-text {
            font-family: 'Libre Baskerville', serif;
            font-size: 20px;
            line-height: 1.65;
            color: var(--clr-text-primary);
            max-width: 480px;
        }

        &-stats {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 1.5rem;

            &__item {
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }

            &__number {
                font-family: 'Bebas Neue', sans-serif;
                font-size: 48px;
                line-height: 1;
                color: var(--clr-text-primary);

                &--accent {
                    color: var(--clr-accent);
                }
            }

            &__label {
                font-family: 'Bebas Neue', sans-serif;
                font-size: 11px;
                letter-spacing: 0.15em;
                text-transform: uppercase;
                color: var(--clr-text-muted);
            }

            &__divider {
                width: 1px;
                height: 32px;
                background: var(--clr-border-light);
                flex-shrink: 0;
            }
        }

        &-cta-row {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.75rem;
        }

        &-cta-primary {
            text-decoration: none;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.125rem;
            letter-spacing: 0.08em;
            line-height: 1;
            color: var(--clr-white);
            background: var(--clr-accent);
            border-radius: 0;
            padding: 16px 40px;
            transition: background-color 0.2s ease;

            &:hover {
                background: #A80D25;
            }
        }

        &-cta-secondary {
            text-decoration: none;
            font-family: 'Libre Baskerville', serif;
            font-size: 1rem;
            color: var(--clr-text-primary);
            transition: opacity 0.2s ease;

            &:hover {
                opacity: 0.6;
            }
        }

        &-aside {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.5rem;

            &__photo {
                width: 100%;
                max-width: 280px;
                height: auto;
                border-radius: 0;
                object-fit: cover;
                filter: saturate(0.85) contrast(1.05);
                box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
            }

            &__icons {
                display: flex;
                flex-direction: row;
                justify-content: center;
                align-items: center;
                gap: 1.25rem;

                a {
                    color: var(--clr-text-primary);
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                    opacity: 0.5;
                    transition: opacity 0.2s ease;

                    &:hover {
                        opacity: 1;
                    }

                    :global(svg) {
                        color: var(--clr-text-primary);
                        fill: var(--clr-text-primary);
                    }
                }
            }
        }
    }

    @media (max-width: 1440px) {
        .hero {
            padding: 3.75rem 80px 4rem 80px;

            &-headline {
                font-size: clamp(3rem, 6vw, 96px);
            }
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 2rem;

            &-content {
                grid-template-columns: 1fr;
            }

            &-headline {
                font-size: 48px;
            }

            &-aside {
                order: -1;
                align-items: flex-start;

                &__photo {
                    max-width: 200px;
                }

                &__icons {
                    justify-content: flex-start;
                }
            }
        }
    }

    @media (max-width: 375px) {
        .hero {
            padding: 1.25rem;

            &-headline {
                font-size: 40px;
            }

            &-positioning {
                font-size: 18px;
            }

            &-overline {
                font-size: 16px;
            }

            &-cta-row {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            &-stats {
                flex-wrap: wrap;
                gap: 1rem;
            }
        }
    }
</style>
