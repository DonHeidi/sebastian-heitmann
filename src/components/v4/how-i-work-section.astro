---
import Typewriter from '../copy/typewriter.astro';

const steps = [
    {
        number: '01',
        title: 'Discovery',
        description: 'We start with your business context — goals, constraints, team, and timeline. No templates. I need to understand the real problem before proposing a solution.',
    },
    {
        number: '02',
        title: 'Strategy',
        description: 'I map out the technical approach, identify risks early, and align the plan with your business objectives. You get a clear roadmap, not a vague proposal.',
    },
    {
        number: '03',
        title: 'Delivery',
        description: 'Hands-on execution — building, shipping, and iterating. I work with your team or independently, in sprints, with full transparency and regular check-ins.',
    },
    {
        number: '04',
        title: 'Handoff',
        description: 'Every engagement ends with documentation, knowledge transfer, and systems your team can own. I build to leave, not to create dependency.',
    },
];
---

<section class="how-i-work reveal" id="process">
    <div class="how-i-work__header">
        <p class="how-i-work__overline">HOW I WORK</p>
        <Typewriter
            as="h3"
            text={[
                'Built to leave, not to stay ',
                'Clarity before momentum ',
                'Embedded, then handed over ',
            ]}
        />
        <p class="how-i-work__description">I work from the inside, create clarity early, and leave behind systems, knowledge, and structure your team can own without me.</p>
    </div>

    <div class="how-i-work__cards">
        {steps.map((step, i) => (
            <div class={`how-i-work__card stagger stagger-${i + 1}${i === 0 ? ' how-i-work__card--first' : ''}`}>
                <span class="how-i-work__card-number">{step.number}</span>
                <h3 class="how-i-work__card-title">{step.title}</h3>
                <p class="how-i-work__card-desc">{step.description}</p>
            </div>
        ))}
    </div>
</section>

<style lang="scss">
    :global(.headline) {
        font-family: 'Bebas Neue', sans-serif !important;
        color: var(--clr-text-primary) !important;
        font-size: 56px;
    }
    :global(.cursor) {
        background-color: var(--clr-text-primary) !important;
    }

    .how-i-work {
        padding: 64px 144px 80px;
        display: flex;
        flex-direction: column;
        gap: 48px;

        &__header {
            max-width: 800px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        &__overline {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--clr-text-muted);
        }

        &__description {
            font-family: 'Libre Baskerville', serif;
            font-size: 18px;
            color: var(--clr-text-muted);
            line-height: 1.6;
            max-width: 500px;
        }

        &__cards {
            display: flex;
            flex-direction: row;
            gap: 24px;
        }

        &__card {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 16px;
            border-radius: 0;
            background: #FFFFFF;
            border: 1px solid #1A1A18;
            padding: 32px 28px;
            position: relative;

            &--first {
                border-top: 3px solid var(--clr-accent);
            }
        }

        &__card-number {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 64px;
            line-height: 1;
            color: rgba(26, 26, 24, 0.08);
        }

        &__card-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 28px;
            color: var(--clr-text-primary);
            line-height: 1.1;
        }

        &__card-desc {
            font-family: 'Libre Baskerville', serif;
            font-size: 16px;
            color: var(--clr-text-muted);
            line-height: 1.65;
        }
    }

    @media (max-width: 768px) {
        .how-i-work {
            padding: 48px 2rem;

            &__cards {
                flex-direction: column;
            }
        }
    }

    @media (max-width: 375px) {
        .how-i-work {
            padding: 48px 1.25rem;
        }
    }
</style>
