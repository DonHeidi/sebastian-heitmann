---
import { Icon } from 'astro-icon/components';
---

<section class="contact reveal" id="contact">
    <div class="contact__header">
        <div class="contact__header-ref">
            <span class="contact__ref-code">SEC.04</span>
            <span class="contact__ref-line"></span>
        </div>
        <h2 class="contact__title">Initiate Contact</h2>
        <p class="contact__subtitle">Tell me about your project and I'll get back to you within 24 hours with an honest assessment of how I can help.</p>
    </div>

    <form class="contact__form" action="#" method="POST">
        <div class="contact__row">
            <div class="contact__field">
                <label class="contact__label" for="contact-name">NAME *</label>
                <input
                    class="contact__input"
                    type="text"
                    id="contact-name"
                    name="name"
                    placeholder="Your full name"
                    required
                />
            </div>
            <div class="contact__field">
                <label class="contact__label" for="contact-email">EMAIL *</label>
                <input
                    class="contact__input"
                    type="email"
                    id="contact-email"
                    name="email"
                    placeholder="your@email.com"
                    required
                />
            </div>
        </div>

        <div class="contact__row">
            <div class="contact__field">
                <label class="contact__label" for="contact-company">COMPANY</label>
                <input
                    class="contact__input"
                    type="text"
                    id="contact-company"
                    name="company"
                    placeholder="Your company"
                />
            </div>
            <div class="contact__field">
                <label class="contact__label" for="contact-plan">ENGAGEMENT TYPE</label>
                <div class="contact__select-wrapper">
                    <select
                        class="contact__select"
                        id="contact-plan"
                        name="plan"
                    >
                        <option value="" disabled selected>Select a plan</option>
                        <option value="hourly">Hourly Based Consulting</option>
                        <option value="prototype">Fixed Prototype Iterations</option>
                        <option value="retainer">Monthly CTO Retainer</option>
                        <option value="unsure">Not sure yet</option>
                    </select>
                    <Icon name="mdi:chevron-down" class="contact__select-icon" width={20} height={20} />
                </div>
            </div>
        </div>

        <div class="contact__field">
            <label class="contact__label" for="contact-message">MESSAGE *</label>
            <textarea
                class="contact__textarea"
                id="contact-message"
                name="message"
                placeholder="Describe your project, timeline, and what you need..."
                required
            ></textarea>
        </div>

        <button type="submit" class="contact__submit">
            TRANSMIT MESSAGE
        </button>
    </form>
</section>

<style lang="scss">
    .contact {
        padding: 80px 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 40px;

        &__header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            text-align: center;
        }

        &__header-ref {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 12px;
            margin-bottom: 0.25rem;
        }

        &__ref-code {
            font-family: 'Space Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            color: var(--clr-accent);
        }

        &__ref-line {
            width: 60px;
            height: 1px;
            background: var(--clr-border);
        }

        &__title {
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 5rem;
            color: var(--clr-text-primary);
            letter-spacing: -2px;
            line-height: 1;
            text-transform: uppercase;
        }

        &__subtitle {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 14px;
            color: var(--clr-text-muted);
            text-align: center;
            max-width: 480px;
            line-height: 1.6;
        }

        &__form {
            display: flex;
            flex-direction: column;
            gap: 16px;
            width: 100%;
            max-width: 820px;
        }

        &__row {
            display: flex;
            flex-direction: row;
            gap: 16px;
        }

        &__field {
            display: flex;
            flex-direction: column;
            gap: 6px;
            flex: 1;
        }

        &__label {
            font-family: 'Space Mono', monospace;
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--clr-text-muted);
        }

        &__input {
            height: 44px;
            padding: 0 16px;
            border-radius: 2px;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-light);
            color: var(--clr-text-primary);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 14px;
            outline: none;
            transition: border-color 0.2s;

            &::placeholder {
                color: var(--clr-text-muted);
                opacity: 0.5;
            }

            &:focus {
                border-color: var(--clr-accent);
                box-shadow: 0 0 0 1px rgba(0, 229, 160, 0.1);
            }
        }

        &__select-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        &__select {
            height: 44px;
            padding: 0 16px;
            border-radius: 2px;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-light);
            color: var(--clr-text-muted);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 14px;
            outline: none;
            appearance: none;
            -webkit-appearance: none;
            width: 100%;
            cursor: pointer;
            transition: border-color 0.2s;

            option {
                background: var(--clr-bg-surface);
                color: var(--clr-text-primary);
            }

            &:focus {
                border-color: var(--clr-accent);
                box-shadow: 0 0 0 1px rgba(0, 229, 160, 0.1);
            }
        }

        &__select-icon {
            position: absolute;
            right: 12px;
            pointer-events: none;
            color: var(--clr-text-muted);
            flex-shrink: 0;
        }

        &__textarea {
            height: 120px;
            padding: 12px 16px;
            border-radius: 2px;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border-light);
            color: var(--clr-text-primary);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 14px;
            outline: none;
            resize: vertical;
            line-height: 1.6;
            transition: border-color 0.2s;

            &::placeholder {
                color: var(--clr-text-muted);
                opacity: 0.5;
            }

            &:focus {
                border-color: var(--clr-accent);
                box-shadow: 0 0 0 1px rgba(0, 229, 160, 0.1);
            }
        }

        &__submit {
            width: fit-content;
            align-self: center;
            padding: 14px 48px;
            border-radius: 2px;
            background: var(--clr-accent);
            border: none;
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 16px;
            letter-spacing: 0.1em;
            color: var(--clr-bg-primary);
            cursor: pointer;
            transition: opacity 0.2s;

            &:hover {
                opacity: 0.85;
            }
        }
    }

    @media (max-width: 1440px) {
        .contact { padding: 80px; }
    }

    @media (max-width: 768px) {
        .contact {
            padding: 96px 2rem;

            &__row { flex-direction: column; }
            &__title { font-size: 3rem; }
        }
    }

    @media (max-width: 375px) {
        .contact {
            padding: 64px 1.25rem;

            &__title { font-size: 2.5rem; }
            &__subtitle { font-size: 13px; }
        }
    }
</style>
