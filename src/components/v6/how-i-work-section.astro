---
import Typewriter from '../copy/typewriter.astro';

const steps = [
    {
        number: '01',
        title: 'Discovery',
        description: 'We start with your business context — goals, constraints, team, and timeline. No templates. I need to understand the real problem before proposing a solution.',
    },
    {
        number: '02',
        title: 'Strategy',
        description: 'I map out the technical approach, identify risks early, and align the plan with your business objectives. You get a clear roadmap, not a vague proposal.',
    },
    {
        number: '03',
        title: 'Delivery',
        description: 'Hands-on execution — building, shipping, and iterating. I work with your team or independently, in sprints, with full transparency and regular check-ins.',
    },
    {
        number: '04',
        title: 'Handoff',
        description: 'Every engagement ends with documentation, knowledge transfer, and systems your team can own. I build to leave, not to create dependency.',
    },
];
---

<section class="how-i-work reveal" id="process">
    <div class="how-i-work__header">
        <div class="how-i-work__header-ref">
            <span class="how-i-work__ref-code">SEC.02</span>
            <span class="how-i-work__ref-line"></span>
        </div>
        <p class="how-i-work__overline">OPERATIONS PROTOCOL</p>
        <Typewriter
            as="h3"
            text={[
                'Built to leave, not to stay ',
                'Clarity before momentum ',
                'Embedded, then handed over ',
            ]}
        />
        <p class="how-i-work__description">I work from the inside, create clarity early, and leave behind systems, knowledge, and structure your team can own without me.</p>
    </div>

    <div class="how-i-work__cards">
        {steps.map((step, i) => (
            <div class={`how-i-work__card stagger stagger-${i + 1}`}>
                <div class="how-i-work__card-corner how-i-work__card-corner--tl"></div>
                <div class="how-i-work__card-corner how-i-work__card-corner--br"></div>
                <span class="how-i-work__card-number">{step.number}</span>
                <h3 class="how-i-work__card-title">{step.title}</h3>
                <p class="how-i-work__card-desc">{step.description}</p>
                <span class="how-i-work__card-status">
                    {i === 0 ? '● INIT' : i === 3 ? '◌ EXIT' : '◎ EXEC'}
                </span>
            </div>
        ))}
    </div>
</section>

<style lang="scss">
    :global(.headline) {
        font-family: 'Rajdhani', sans-serif !important;
        font-weight: 700 !important;
        color: var(--clr-text-primary) !important;
        font-size: 48px;
        text-transform: uppercase;
    }
    :global(.cursor) {
        background-color: var(--clr-accent) !important;
    }

    .how-i-work {
        padding: 64px 144px 80px;
        display: flex;
        flex-direction: column;
        gap: 48px;

        &__header {
            max-width: 800px;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        &__header-ref {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 12px;
            margin-bottom: 0.25rem;
        }

        &__ref-code {
            font-family: 'Space Mono', monospace;
            font-size: 10px;
            letter-spacing: 0.2em;
            color: var(--clr-accent);
        }

        &__ref-line {
            flex: 1;
            height: 1px;
            background: var(--clr-border);
            max-width: 120px;
        }

        &__overline {
            font-family: 'Space Mono', monospace;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.18em;
            color: var(--clr-text-muted);
        }

        &__description {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 14px;
            color: var(--clr-text-muted);
            line-height: 1.65;
            max-width: 500px;
        }

        &__cards {
            display: flex;
            flex-direction: row;
            gap: 16px;
        }

        &__card {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: var(--clr-bg-surface);
            border: 1px solid var(--clr-border);
            padding: 28px 24px;
            position: relative;
        }

        &__card-corner {
            position: absolute;
            width: 12px;
            height: 12px;
            pointer-events: none;

            &--tl {
                top: -1px; left: -1px;
                border-top: 2px solid var(--clr-accent);
                border-left: 2px solid var(--clr-accent);
            }

            &--br {
                bottom: -1px; right: -1px;
                border-bottom: 2px solid var(--clr-accent);
                border-right: 2px solid var(--clr-accent);
            }
        }

        &__card-number {
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 56px;
            line-height: 1;
            color: rgba(0, 229, 160, 0.08);
        }

        &__card-title {
            font-family: 'Rajdhani', sans-serif;
            font-weight: 700;
            font-size: 24px;
            color: var(--clr-text-primary);
            line-height: 1.1;
            text-transform: uppercase;
        }

        &__card-desc {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 13px;
            color: var(--clr-text-muted);
            line-height: 1.7;
            flex: 1;
        }

        &__card-status {
            font-family: 'Space Mono', monospace;
            font-size: 9px;
            letter-spacing: 0.15em;
            color: var(--clr-accent);
            opacity: 0.5;
            margin-top: auto;
        }
    }

    @media (max-width: 768px) {
        .how-i-work {
            padding: 48px 2rem;

            &__cards {
                flex-direction: column;
            }
        }
    }

    @media (max-width: 375px) {
        .how-i-work {
            padding: 48px 1.25rem;
        }
    }
</style>
