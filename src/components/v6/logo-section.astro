<section class="logobar">
    <div class="logobar__group">
        <p class="logobar__label">PREV. DEPLOYMENTS</p>
        <div class="logobar__names">
            <span class="logobar__name">Jung von Matt</span>
            <span class="logobar__name">Synergy</span>
            <span class="logobar__name">Granny &amp; Smith</span>
            <span class="logobar__name">OFFIS</span>
        </div>
    </div>

    <span class="logobar__divider">//</span>

    <div class="logobar__group">
        <p class="logobar__label">CURRENT OPS</p>
        <div class="logobar__names">
            <span class="logobar__name logobar__name--active">Pool Position GmbH</span>
            <span class="logobar__name logobar__name--active">mobilespace GmbH</span>
        </div>
    </div>
</section>

<style lang="scss">
    .logobar {
        border-top: 1px solid var(--clr-border);
        border-bottom: 1px solid var(--clr-border);
        background: var(--clr-bg-surface);
        padding: 24px 144px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 3rem;

        &__group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }

        &__label {
            font-family: 'Space Mono', monospace;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--clr-text-muted);
        }

        &__names {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2rem;
        }

        &__name {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 13px;
            color: var(--clr-text-primary);
            opacity: 0.3;
            white-space: nowrap;
            transition: opacity 0.3s ease;

            &:hover {
                opacity: 0.6;
            }

            &--active {
                opacity: 0.5;
                position: relative;

                &::before {
                    content: '';
                    display: inline-block;
                    width: 4px;
                    height: 4px;
                    border-radius: 50%;
                    background: var(--clr-accent);
                    margin-right: 8px;
                    vertical-align: middle;
                }
            }
        }

        &__divider {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            color: var(--clr-border);
            flex-shrink: 0;
        }
    }

    @media (max-width: 1440px) {
        .logobar { padding: 24px 80px; }
    }

    @media (max-width: 768px) {
        .logobar {
            padding: 24px 2rem;
            flex-direction: column;
            gap: 1.25rem;

            &__names {
                flex-wrap: wrap;
                justify-content: center;
                gap: 1rem 1.5rem;
            }
        }
    }

    @media (max-width: 375px) {
        .logobar {
            padding: 20px 1.25rem;

            &__name { font-size: 12px; }
        }
    }
</style>
