---
import { Icon } from 'astro-icon/components';
---

<nav class="nav">
    <a class="nav-logo" href="/v8/">sebastian-heitmann<span class="nav-logo__dot">.</span>dev</a>
    <a class="nav-cta" href="#contact">Book a Call</a>
</nav>

<style lang="scss">
    .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 28px 80px;
        max-width: 1440px;
        margin: 0 auto;

        &-logo {
            font-family: var(--v8-font-mono);
            font-size: 13px;
            letter-spacing: 0.02em;
            color: var(--v8-text-muted);
            text-decoration: none;
            transition: color 0.2s ease;

            &:hover {
                color: var(--v8-text);
            }

            &__dot {
                color: var(--v8-accent);
            }
        }

        &-cta {
            font-family: var(--v8-font-mono);
            font-size: 12px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--v8-text);
            text-decoration: none;
            padding: 10px 24px;
            border: 1px solid var(--v8-border);
            transition: border-color 0.2s ease, color 0.2s ease;

            &:hover {
                border-color: var(--v8-accent);
                color: var(--v8-accent);
            }
        }
    }

    @media (max-width: 768px) {
        .nav {
            padding: 20px 24px;
        }
    }
</style>
