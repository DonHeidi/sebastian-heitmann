---
type Props = {
    currentVersion: 'v1' | 'v2';
}

const { currentVersion } = Astro.props;
const isV1 = currentVersion === 'v1';
const targetHref = isV1 ? '/v2/' : '/';
const label = isV1 ? 'Manual Edition' : 'Original';
---

<a class:list={['version-switcher', { 'version-switcher--v1': isV1, 'version-switcher--v2': !isV1 }]} href={targetHref}>
    <span class="version-switcher__dot"></span>
    <span class="version-switcher__label">{label}</span>
</a>

<style lang="scss">
    .version-switcher {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 100vh;
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: opacity 0.2s ease, transform 0.2s ease;
        backdrop-filter: blur(12px);

        &:hover {
            opacity: 0.85;
            transform: translateY(-1px);
        }

        &__dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        &__label {
            line-height: 1;
        }

        &--v1 {
            font-family: 'Outfit', sans-serif;
            background: rgba(35, 30, 25, 0.85);
            border: 1px solid rgba(232, 226, 214, 0.12);
            color: rgba(232, 226, 214, 0.7);

            .version-switcher__dot {
                background: #3B82F6;
            }
        }

        &--v2 {
            font-family: 'IBM Plex Mono', monospace;
            background: rgba(17, 24, 39, 0.9);
            border: 1px solid rgba(59, 130, 246, 0.2);
            color: rgba(200, 214, 229, 0.7);

            .version-switcher__dot {
                background: #C45D3E;
            }
        }
    }
</style>
