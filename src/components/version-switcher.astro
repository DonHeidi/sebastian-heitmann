---
type Props = {
    currentVersion: 'v1' | 'v2' | 'v3' | 'v4';
}

const { currentVersion } = Astro.props;

const versions = [
    { id: 'v1', href: '/', label: 'Original' },
    { id: 'v2', href: '/v2/', label: 'Manual' },
    { id: 'v3', href: '/v3/', label: 'Cyberpunk' },
    { id: 'v4', href: '/v4/', label: 'Editorial' },
];

const otherVersions = versions.filter(v => v.id !== currentVersion);
---

<div class:list={['version-switcher', `version-switcher--${currentVersion}`]}>
    {otherVersions.map(v => (
        <a class:list={['version-switcher__link', `version-switcher__link--${v.id}`]} href={v.href}>
            <span class="version-switcher__dot"></span>
            <span class="version-switcher__label">{v.label}</span>
        </a>
    ))}
</div>

<style lang="scss">
    .version-switcher {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        display: flex;
        flex-direction: column;
        gap: 6px;

        &__link {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 100vh;
            text-decoration: none;
            font-size: 0.6875rem;
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            transition: opacity 0.2s ease, transform 0.2s ease;
            backdrop-filter: blur(12px);

            &:hover {
                opacity: 0.85;
                transform: translateX(-2px);
            }
        }

        &__dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        &__label {
            line-height: 1;
        }

        /* Link styles based on target version */
        &__link--v1 {
            background: rgba(35, 30, 25, 0.85);
            border: 1px solid rgba(232, 226, 214, 0.12);
            color: rgba(232, 226, 214, 0.7);
            font-family: 'Outfit', 'Rajdhani', 'IBM Plex Mono', sans-serif;

            .version-switcher__dot { background: #C45D3E; }
        }

        &__link--v2 {
            background: rgba(17, 24, 39, 0.9);
            border: 1px solid rgba(59, 130, 246, 0.2);
            color: rgba(200, 214, 229, 0.7);
            font-family: 'IBM Plex Mono', 'Outfit', monospace;

            .version-switcher__dot { background: #3B82F6; }
        }

        &__link--v3 {
            background: rgba(10, 10, 10, 0.9);
            border: 1px solid rgba(252, 227, 0, 0.2);
            color: rgba(252, 227, 0, 0.8);
            font-family: 'Rajdhani', 'Outfit', sans-serif;

            .version-switcher__dot { background: #FCE300; }
        }

        &__link--v4 {
            background: rgba(250, 250, 247, 0.95);
            border: 1px solid rgba(26, 26, 24, 0.15);
            color: rgba(26, 26, 24, 0.6);
            font-family: 'Libre Baskerville', serif;
            backdrop-filter: none;
            border-radius: 0;

            .version-switcher__dot { background: #C8102E; }
        }
    }
</style>
