---
import Navigation from '../../components/v6/navigation.astro';
import Hero from '../../components/v6/hero.astro';
import LogoSection from '../../components/v6/logo-section.astro';
import ServicesSection from '../../components/v6/services-section.astro';
import HowIWorkSection from '../../components/v6/how-i-work-section.astro';
import SuccessStoriesSection from '../../components/v6/success-stories-section.astro';
import ContactSection from '../../components/v6/contact-section.astro';
import Footer from '../../components/v6/footer.astro';
import VersionSwitcher from '../../components/version-switcher.astro';
---
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Sebastian Heitmann — Fractional CTO</title>
        <link rel="canonical" href="/">
    </head>
    <body>
        <div class="site-container">
            <Navigation />
            <Hero />
            <LogoSection />
            <ServicesSection />
            <HowIWorkSection />
            <SuccessStoriesSection />
            <ContactSection />
            <Footer />
        </div>
        <VersionSwitcher currentVersion="v6" />
    </body>
</html>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    });
</script>

<style lang="scss" is:global>
    @font-face {
        font-family: 'Rajdhani';
        font-style: normal;
        font-weight: 400;
        src: url('/fonts/Rajdhani-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'Rajdhani';
        font-style: normal;
        font-weight: 700;
        src: url('/fonts/Rajdhani-Bold.woff2') format('woff2');
    }
    @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 400;
        src: url('/fonts/IBMPlexMono-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'IBM Plex Mono';
        font-style: normal;
        font-weight: 700;
        src: url('/fonts/IBMPlexMono-Bold.woff2') format('woff2');
    }
    @font-face {
        font-family: 'Space Mono';
        font-style: normal;
        font-weight: 400;
        src: url('/fonts/SpaceMono-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'Space Mono';
        font-style: normal;
        font-weight: 700;
        src: url('/fonts/SpaceMono-Bold.woff2') format('woff2');
    }

    *, *::before, *::after { box-sizing: border-box; }
    * { margin: 0; }

    @media (prefers-reduced-motion: no-preference) {
        html { interpolate-size: allow-keywords; }
    }

    body {
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
    }
    img, picture, video, canvas, svg { display: block; max-width: 100%; }
    input, button, textarea, select { font: inherit; }
    p, h1, h2, h3, h4, h5, h6 { overflow-wrap: break-word; }
    p { text-wrap: pretty; }
    h1, h2, h3, h4, h5, h6 { text-wrap: balance; }
    #root, #__next { isolation: isolate; }

    :root {
        --clr-bg-primary: #0B0D12;
        --clr-bg-surface: #111520;
        --clr-bg-elevated: #161B28;
        --clr-text-primary: #D0D4DE;
        --clr-text-muted: rgba(208, 212, 222, 0.45);
        --clr-accent: #00E5A0;
        --clr-accent-dim: rgba(0, 229, 160, 0.12);
        --clr-warning: #FF6B35;
        --clr-border: rgba(0, 229, 160, 0.10);
        --clr-border-light: rgba(208, 212, 222, 0.08);
        --clr-white: #FFFFFF;
    }

    .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.revealed { opacity: 1; transform: translateY(0); }

    .stagger {
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
                    transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .revealed .stagger { opacity: 1; transform: translateY(0); }
    .stagger-1 { transition-delay: 0.1s; }
    .stagger-2 { transition-delay: 0.2s; }
    .stagger-3 { transition-delay: 0.3s; }
    .stagger-4 { transition-delay: 0.4s; }

    .typewriter-measure {
        position: fixed !important;
        top: -9999px;
        left: -9999px;
    }

    @media (prefers-reduced-motion: reduce) {
        .reveal, .stagger { opacity: 1; transform: none; transition: none; }
    }
</style>

<style lang="scss">
    body {
        background-color: #0B0D12;
        background-image:
            /* Engineering grid */
            repeating-linear-gradient(
                0deg,
                rgba(0, 229, 160, 0.02) 0px,
                rgba(0, 229, 160, 0.02) 1px,
                transparent 1px,
                transparent 80px
            ),
            repeating-linear-gradient(
                90deg,
                rgba(0, 229, 160, 0.02) 0px,
                rgba(0, 229, 160, 0.02) 1px,
                transparent 1px,
                transparent 80px
            ),
            /* Subtle accent glows */
            radial-gradient(circle at 85% 5%, rgba(0, 229, 160, 0.04) 0%, transparent 15%),
            radial-gradient(circle at 10% 40%, rgba(0, 229, 160, 0.025) 0%, transparent 12%),
            radial-gradient(circle at 70% 65%, rgba(255, 107, 53, 0.02) 0%, transparent 10%);
        min-height: 100vh;
        color: var(--clr-text-primary);
    }

    .site-container {
        max-width: 1440px;
        margin: 0 auto;
        position: relative;
    }
</style>
